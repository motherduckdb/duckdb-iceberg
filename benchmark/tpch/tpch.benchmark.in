# name: ${FILE_PATH}
# description: ${DESCRIPTION}
# group: [sf1]

argument sf 1

name Iceberg Q${QUERY_NUMBER_PADDED}
group tpch
subgroup sf${sf}

require avro

require parquet

require iceberg

require httpfs

require tpch

cache_file tpch_sf${sf}_iceberg.db

load
ATTACH ':memory:' AS mem;
USE mem;
CALL dbgen(sf=${sf});
CREATE SECRET (
    TYPE S3,
    KEY_ID 'admin',
    SECRET 'password',
    ENDPOINT '127.0.0.1:9000',
    URL_STYLE 'path',
    USE_SSL 0
);
ATTACH '' AS my_datalake (
    TYPE ICEBERG,
    CLIENT_ID 'admin',
    CLIENT_SECRET 'password',
    ENDPOINT 'http://127.0.0.1:8181',
    DEFAULT_SCHEMA 'default'
);
USE my_datalake;

reload
ATTACH '' AS my_datalake (
    TYPE ICEBERG,
    CLIENT_ID 'admin',
    CLIENT_SECRET 'password',
    ENDPOINT 'http://127.0.0.1:8181',
    DEFAULT_SCHEMA 'default'
);
DROP TABLE IF EXISTS my_datalake."default".customer;
DROP TABLE IF EXISTS my_datalake."default".lineitem;
DROP TABLE IF EXISTS my_datalake."default".nation;
DROP TABLE IF EXISTS my_datalake."default".orders;
DROP TABLE IF EXISTS my_datalake."default".part;
DROP TABLE IF EXISTS my_datalake."default".partsupp;
DROP TABLE IF EXISTS my_datalake."default".region;
DROP TABLE IF EXISTS my_datalake."default".supplier;
DROP SCHEMA IF EXISTS my_datalake."default";
CREATE SCHEMA IF NOT EXISTS my_datalake."default";
COPY FROM DATABASE mem TO my_datalake;
USE my_datalake;
DETACH mem;

run 
set enable_external_file_cache=false;
pragma tpch(${QUERY_NUMBER_PADDED});

result duckdb/extension/tpch/dbgen/answers/sf${sf}/q${QUERY_NUMBER_PADDED}.csv sf=${sf}