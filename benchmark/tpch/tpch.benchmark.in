# name: ${FILE_PATH}
# description: ${DESCRIPTION}
# group: [sf1]

argument sf 1

name Iceberg Q${QUERY_NUMBER_PADDED}
group tpch
subgroup sf${sf}

require avro

require parquet

require iceberg

require httpfs

require tpch

load
ATTACH ':memory:' AS mem;
USE mem;
CALL dbgen(sf=${sf});
CREATE SECRET (
    TYPE S3,
    KEY_ID 'admin',
    SECRET 'password',
    ENDPOINT '127.0.0.1:9000',
    URL_STYLE 'path',
    USE_SSL 0
);
ATTACH '' AS my_datalake (
    TYPE ICEBERG,
    CLIENT_ID 'admin',
    CLIENT_SECRET 'password',
    ENDPOINT 'http://127.0.0.1:8181',
);
create schema if not exists my_datalake.default;
DROP TABLE IF EXISTS my_datalake."default".customer;
DROP TABLE IF EXISTS my_datalake."default".lineitem;
DROP TABLE IF EXISTS my_datalake."default".nation;
DROP TABLE IF EXISTS my_datalake."default".orders;
DROP TABLE IF EXISTS my_datalake."default".part;
DROP TABLE IF EXISTS my_datalake."default".partsupp;
DROP TABLE IF EXISTS my_datalake."default".region;
DROP TABLE IF EXISTS my_datalake."default".supplier;
CREATE SCHEMA IF NOT EXISTS my_datalake."default";
create table my_datalake."default".customer as select * from customer;
create table my_datalake."default".lineitem as select * from lineitem;
create table my_datalake."default".nation as select * from nation;
create table my_datalake."default".orders as select * from orders;
create table my_datalake."default".part as select * from part;
create table my_datalake."default".partsupp as select * from partsupp;
create table my_datalake."default".region as select * from region;
create table my_datalake."default".supplier as select * from supplier;
USE my_datalake.default;
DETACH mem;
copy (select 'yes') to 'reload_run.csv';

run
set enable_external_file_cache=false;
USE my_datalake.default;
copy (show all tables) to 'show_tables.csv';
pragma tpch(${QUERY_NUMBER_PADDED});

result duckdb/extension/tpch/dbgen/answers/sf${sf}/q${QUERY_NUMBER_PADDED}.csv sf=${sf}
