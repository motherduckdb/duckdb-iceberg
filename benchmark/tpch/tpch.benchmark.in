# name: ${FILE_PATH}
# description: ${DESCRIPTION}
# group: [sf1]

name Iceberg Q${QUERY_NUMBER_PADDED}
group tpch
subgroup sf1

require avro

require parquet

require iceberg

require httpfs

require tpch

cache_file tpch_sf1_iceberg.db

load
CREATE SECRET (
    TYPE S3,
    KEY_ID 'admin',
    SECRET 'password',
    ENDPOINT '127.0.0.1:9000',
    URL_STYLE 'path',
    USE_SSL 0
);
ATTACH '' AS my_datalake (
    TYPE ICEBERG,
    CLIENT_ID 'admin',
    CLIENT_SECRET 'password',
    ENDPOINT 'http://127.0.0.1:8181',
    DEFAULT_SCHEMA 'default'
);
USE my_datalake;

reload
ATTACH '' AS my_datalake (
    TYPE ICEBERG,
    CLIENT_ID 'admin',
    CLIENT_SECRET 'password',
    ENDPOINT 'http://127.0.0.1:8181',
    DEFAULT_SCHEMA 'default'
);
USE my_datalake;

run duckdb/extension/tpch/dbgen/queries/q${QUERY_NUMBER_PADDED}.sql

result duckdb/extension/tpch/dbgen/answers/sf1/q${QUERY_NUMBER_PADDED}.csv sf=1
