{
  "description": "Use Polaris as Iceberg Rest Catalog.",
  "on_init": "create secret polaris_secret (TYPE ICEBERG, CLIENT_ID 'root',CLIENT_SECRET 's3cr3t',ENDPOINT 'http://0.0.0.0:8181/api/catalog'); attach 'quickstart_catalog' as my_datalake (type ICEBERG,ENDPOINT 'http://0.0.0.0:8181/api/catalog', default_region 'us-west-2'); Create schema if not exists my_datalake.default;",
