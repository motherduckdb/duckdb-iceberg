query I
SELECT count(*) > 0
FROM duckdb_logs_parsed('HTTP')
WHERE request.url = 'http://127.0.0.1:8181/v1/namespaces/default/tables/vended_direct_delete_refresh'
  AND request.type = 'GET'
  AND response.status = 'OK_200'
----
1

query I
SELECT count(*) > 0
FROM duckdb_logs_parsed('HTTP')
WHERE starts_with(request.url, 'http://127.0.0.1:9000/')
  AND request.type = 'DELETE'
  AND request.headers['Authorization'] LIKE '%OLD_DIRECT_DELETE_KEY%'
  AND (response.reason = 'Forbidden' OR response.status IS NULL)
----
1

query I
SELECT count(*) > 0
FROM duckdb_logs_parsed('HTTP')
WHERE starts_with(request.url, 'http://127.0.0.1:9000/')
  AND request.type = 'DELETE'
  AND request.headers['Authorization'] NOT LIKE '%OLD_DIRECT_DELETE_KEY%'
  AND response.status IN ('OK_200', 'NoContent_204')
----
1

