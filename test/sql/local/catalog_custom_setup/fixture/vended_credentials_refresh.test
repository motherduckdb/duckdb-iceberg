# DeleteObjects batches must be split by the effective scoped credentials, not
# just by bucket. The proxy rejects a batch containing both old partitions.
statement ok
CREATE OR REPLACE SECRET mixed_delete_root_secret (
    TYPE S3,
    KEY_ID 'MIXED_DELETE_ROOT_KEY',
    SECRET 'MIXED_DELETE_ROOT_KEY_SECRET',
    REGION 'us-east-1',
    ENDPOINT '127.0.0.1:9000',
    URL_STYLE 'path',
    USE_SSL 0,
    HTTP_PROXY '${VENDED_CREDENTIAL_REFRESH_PROXY}',
    SCOPE 's3://warehouse/vended_credentials_refresh/mixed_delete'
)

statement ok
CREATE OR REPLACE SECRET mixed_delete_a_secret (
    TYPE S3,
    KEY_ID 'MIXED_DELETE_A_KEY',
    SECRET 'MIXED_DELETE_A_KEY_SECRET',
    REGION 'us-east-1',
    ENDPOINT '127.0.0.1:9000',
    URL_STYLE 'path',
    USE_SSL 0,
    HTTP_PROXY '${VENDED_CREDENTIAL_REFRESH_PROXY}',
    SCOPE 's3://warehouse/vended_credentials_refresh/mixed_delete/part_col=a'
)

statement ok
CREATE OR REPLACE SECRET mixed_delete_b_secret (
    TYPE S3,
    KEY_ID 'MIXED_DELETE_B_KEY',
    SECRET 'MIXED_DELETE_B_KEY_SECRET',
    REGION 'us-east-1',
    ENDPOINT '127.0.0.1:9000',
    URL_STYLE 'path',
    USE_SSL 0,
    HTTP_PROXY '${VENDED_CREDENTIAL_REFRESH_PROXY}',
    SCOPE 's3://warehouse/vended_credentials_refresh/mixed_delete/part_col=b'
)

statement ok
COPY (
    SELECT 'a' AS part_col, 'old-a' AS value
    UNION ALL
    SELECT 'b' AS part_col, 'old-b' AS value
) TO 's3://warehouse/vended_credentials_refresh/mixed_delete' (FORMAT PARQUET, PARTITION_BY (part_col), OVERWRITE_OR_IGNORE TRUE)

statement ok
CALL truncate_duckdb_logs()

statement ok
COPY (
    SELECT 'c' AS part_col, 'new-c' AS value
) TO 's3://warehouse/vended_credentials_refresh/mixed_delete' (FORMAT PARQUET, PARTITION_BY (part_col), OVERWRITE)

query I
SELECT count(*) > 0
FROM duckdb_logs_parsed('HTTP')
WHERE request.url LIKE 'http://127.0.0.1:9000/warehouse/%delete%'
  AND request.type = 'POST'
  AND request.headers['Authorization'] LIKE '%MIXED_DELETE_A_KEY%'
  AND response.status = 'OK_200'
----
1

query I
SELECT count(*) > 0
FROM duckdb_logs_parsed('HTTP')
WHERE request.url LIKE 'http://127.0.0.1:9000/warehouse/%delete%'
  AND request.type = 'POST'
  AND request.headers['Authorization'] LIKE '%MIXED_DELETE_B_KEY%'
  AND response.status = 'OK_200'
----
1

statement ok
DROP SECRET mixed_delete_b_secret

statement ok
DROP SECRET mixed_delete_a_secret

statement ok
DROP SECRET mixed_delete_root_secret

# DeleteObjects batches must also be split by secret identity when currently
# expired scoped secrets have identical material but refresh to different keys.
statement ok
CREATE OR REPLACE SECRET mixed_refresh_delete_root_secret (
    TYPE S3,
    KEY_ID 'MIXED_DELETE_ROOT_KEY',
    SECRET 'MIXED_DELETE_ROOT_KEY_SECRET',
    REGION 'us-east-1',
    ENDPOINT '127.0.0.1:9000',
    URL_STYLE 'path',
    USE_SSL 0,
    HTTP_PROXY '${VENDED_CREDENTIAL_REFRESH_PROXY}',
    SCOPE 's3://warehouse/vended_credentials_refresh/mixed_delete_refresh'
)

statement ok
COPY (
    SELECT 'a' AS part_col, 'old-a' AS value
    UNION ALL
    SELECT 'b' AS part_col, 'old-b' AS value
) TO 's3://warehouse/vended_credentials_refresh/mixed_delete_refresh' (FORMAT PARQUET, PARTITION_BY (part_col), OVERWRITE_OR_IGNORE TRUE)

statement ok
