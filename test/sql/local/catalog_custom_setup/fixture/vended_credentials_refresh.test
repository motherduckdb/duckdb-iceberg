    USE_SSL 0,
    HTTP_PROXY '${VENDED_CREDENTIAL_REFRESH_PROXY}',
    SCOPE 's3://warehouse/vended_credentials_refresh/delete',
    REFRESH_INFO MAP {
        'catalog_name': 'vended_refresh',
        'schema': 'default',
        'table': 'vended_delete_refresh'
    }
)

statement ok
CALL truncate_duckdb_logs()

statement ok
COPY (SELECT 99 AS part_col, 'new' AS value) TO 's3://warehouse/vended_credentials_refresh/delete' (FORMAT PARQUET, PARTITION_BY (part_col), OVERWRITE)

