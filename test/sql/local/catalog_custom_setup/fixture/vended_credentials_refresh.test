# name: test/sql/local/catalog_custom_setup/fixture/vended_credentials_refresh.test
# description: vended Iceberg storage credentials refresh on S3 auth failures, including ranged reads
# group: [fixture]

require-env FIXTURE_SERVER_AVAILABLE

require-env VENDED_CREDENTIAL_REFRESH_PROXY

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages.
set ignore_error_messages

statement ok
SET enable_logging=true

statement ok
SET logging_level='debug'

statement ok
CALL enable_logging('HTTP')

statement ok
CREATE SECRET vended_refresh_http_proxy (
    TYPE HTTP,
    HTTP_PROXY '${VENDED_CREDENTIAL_REFRESH_PROXY}',
    HTTP_PROXY_USERNAME 'refresh_proxy_user',
    HTTP_PROXY_PASSWORD 'refresh_proxy_password',
    EXTRA_HTTP_HEADERS MAP {'x-refresh-test': 'present'}
)

statement ok
ATTACH '' AS vended_refresh (
    TYPE ICEBERG,
    ENDPOINT 'http://127.0.0.1:8181',
    AUTHORIZATION_TYPE 'oauth2',
    CLIENT_ID 'admin',
    CLIENT_SECRET 'password',
    OAUTH2_SERVER_URI 'http://127.0.0.1:8181/v1/oauth/tokens'
)

statement ok
CALL truncate_duckdb_logs()

query I
SELECT count(*) FROM vended_refresh.default.empty_table
----
0

query I
SELECT count(*) > 0
FROM duckdb_logs_parsed('HTTP')
WHERE request.url = 'http://127.0.0.1:8181/v1/namespaces/default/tables/empty_table'
  AND response.status = 'OK_200'
----
1

query I
SELECT count(*)
FROM duckdb_secrets(redact=false)
WHERE name LIKE '__internal_ic%empty_table%'
----
0

# Create the same scoped S3 secret shape that Iceberg vended credentials install.
# The refresh_info points back to the Iceberg catalog/table; on a 403, HTTPFS
# asks the Iceberg provider to re-vend credentials from the catalog.
statement ok
CREATE OR REPLACE SECRET vended_init_refresh_secret (
    TYPE S3,
    PROVIDER iceberg,
    KEY_ID 'OLD_INIT_KEY',
    SECRET 'OLD_INIT_KEY_SECRET',
    REGION 'us-east-1',
    ENDPOINT '127.0.0.1:9000',
    URL_STYLE 'path',
    USE_SSL 0,
    HTTP_PROXY '${VENDED_CREDENTIAL_REFRESH_PROXY}',
    SCOPE 's3://warehouse/vended_credentials_refresh/init',
    REFRESH_INFO MAP {
        'catalog_name': 'vended_refresh',
        'schema': 'default',
        'table': 'vended_init_refresh'
    }
)

statement ok
CALL truncate_duckdb_logs()

query IT
SELECT * FROM read_parquet('s3://warehouse/vended_credentials_refresh/init/data.parquet') ORDER BY ALL
----
1	foo
2	bar
3	baz

query I
SELECT count(*) > 0
FROM duckdb_logs_parsed('HTTP')
WHERE request.url = 'http://127.0.0.1:8181/v1/namespaces/default/tables/vended_init_refresh'
  AND response.status = 'OK_200'
----
1

query I
SELECT count(*) > 0
FROM duckdb_logs_parsed('HTTP')
WHERE starts_with(request.url, 'http://127.0.0.1:9000/')
  AND response.reason = 'Forbidden'
  AND request.headers['Authorization'] LIKE '%OLD_INIT_KEY%'
----
1

query I
SELECT count(*) > 0
FROM duckdb_logs_parsed('HTTP')
WHERE starts_with(request.url, 'http://127.0.0.1:9000/')
  AND response.status IN ('OK_200', 'PartialContent_206')
  AND request.headers['Authorization'] LIKE '%NEW_INIT_KEY%'
  AND request.headers['x-refresh-test'] = 'present'
----
1

query IIII
SELECT count(*),
       CAST(bool_or(secret_string LIKE '%key_id=NEW_INIT_KEY%') AS INTEGER),
       CAST(bool_or(secret_string LIKE '%http_proxy_username=refresh_proxy_user%') AS INTEGER),
       CAST(bool_or(secret_string LIKE '%x-refresh-test%') AS INTEGER)
FROM duckdb_secrets(redact=false)
WHERE name='vended_init_refresh_secret'
----
1	1	1	1

query I
SELECT count(*)
FROM duckdb_secrets(redact=false)
WHERE name='vended_init_refresh_secret'
  AND secret_string LIKE '%OLD_INIT_KEY%'
----
0

statement ok
CALL truncate_duckdb_logs()

# Register a second vended-style secret scoped to another object. Initial file
# access succeeds with OLD_RANGE_KEY. The proxy rejects the first ranged GET with
# 403, so a successful scan proves S3FileSystem::GetRangeRequest refreshed the
# vended secret and retried the range request.
statement ok
CREATE OR REPLACE SECRET vended_range_refresh_secret (
    TYPE S3,
    PROVIDER iceberg,
    KEY_ID 'OLD_RANGE_KEY',
    SECRET 'OLD_RANGE_KEY_SECRET',
    REGION 'us-east-1',
    ENDPOINT '127.0.0.1:9000',
    URL_STYLE 'path',
    USE_SSL 0,
    HTTP_PROXY '${VENDED_CREDENTIAL_REFRESH_PROXY}',
    SCOPE 's3://warehouse/vended_credentials_refresh/range',
    REFRESH_INFO MAP {
        'catalog_name': 'vended_refresh',
        'schema': 'default',
        'table': 'vended_range_refresh'
    }
)

statement ok
CALL truncate_duckdb_logs()

query I
SELECT count(*) FROM read_parquet('s3://warehouse/vended_credentials_refresh/range/data.parquet')
----
111968

query I
SELECT count(*) > 0
FROM duckdb_logs_parsed('HTTP')
WHERE request.url = 'http://127.0.0.1:8181/v1/namespaces/default/tables/vended_range_refresh'
  AND response.status = 'OK_200'
----
1

query I
SELECT count(*) > 0
FROM duckdb_logs_parsed('HTTP')
WHERE starts_with(request.url, 'http://127.0.0.1:9000/')
  AND request.url LIKE '%/vended_credentials_refresh/range/data.parquet'
  AND request.type = 'GET'
  AND request.headers['Range'] IS NOT NULL
  AND response.status IS NULL
  AND request.headers['Authorization'] LIKE '%OLD_RANGE_KEY%'
----
1

query I
SELECT count(*) > 0
FROM duckdb_logs_parsed('HTTP')
WHERE starts_with(request.url, 'http://127.0.0.1:9000/')
  AND request.url LIKE '%/vended_credentials_refresh/range/data.parquet'
  AND request.type = 'GET'
  AND request.headers['Range'] IS NOT NULL
  AND response.status = 'PartialContent_206'
  AND request.headers['Authorization'] LIKE '%NEW_RANGE_KEY%'
  AND request.headers['x-refresh-test'] = 'present'
----
1

query IIII
SELECT count(*),
       CAST(bool_or(secret_string LIKE '%key_id=NEW_RANGE_KEY%') AS INTEGER),
       CAST(bool_or(secret_string LIKE '%http_proxy_username=refresh_proxy_user%') AS INTEGER),
       CAST(bool_or(secret_string LIKE '%x-refresh-test%') AS INTEGER)
FROM duckdb_secrets(redact=false)
WHERE name='vended_range_refresh_secret'
----
1	1	1	1

query I
SELECT count(*)
FROM duckdb_secrets(redact=false)
WHERE name='vended_range_refresh_secret'
  AND secret_string LIKE '%OLD_RANGE_KEY%'
----
0

# HEAD refresh: opening a file starts with HEAD unless metadata is already known.
statement ok
CREATE OR REPLACE SECRET vended_head_refresh_secret (
    TYPE S3,
    PROVIDER iceberg,
    KEY_ID 'OLD_HEAD_KEY',
    SECRET 'OLD_HEAD_KEY_SECRET',
    REGION 'us-east-1',
    ENDPOINT '127.0.0.1:9000',
    URL_STYLE 'path',
    USE_SSL 0,
    HTTP_PROXY '${VENDED_CREDENTIAL_REFRESH_PROXY}',
    SCOPE 's3://warehouse/vended_credentials_refresh/head',
    REFRESH_INFO MAP {
        'catalog_name': 'vended_refresh',
        'schema': 'default',
        'table': 'vended_head_refresh'
    }
)

statement ok
CALL truncate_duckdb_logs()

query I
SELECT count(*) FROM read_parquet('s3://warehouse/vended_credentials_refresh/head/data.parquet')
----
3

query I
SELECT count(*) > 0
FROM duckdb_logs_parsed('HTTP')
WHERE request.url LIKE '%/vended_credentials_refresh/head/data.parquet'
  AND request.type = 'HEAD'
  AND request.headers['Authorization'] LIKE '%OLD_HEAD_KEY%'
  AND (response.reason = 'Forbidden' OR response.status IS NULL)
----
1

query I
SELECT count(*) > 0
FROM duckdb_logs_parsed('HTTP')
WHERE request.url LIKE '%/vended_credentials_refresh/head/data.parquet'
  AND request.type = 'HEAD'
  AND request.headers['Authorization'] LIKE '%NEW_HEAD_KEY%'
  AND response.status = 'OK_200'
  AND request.headers['x-refresh-test'] = 'present'
----
1

# Full GET refresh: force full downloads so the failing request is a GET without Range.
statement ok
CREATE OR REPLACE SECRET vended_get_refresh_secret (
    TYPE S3,
    PROVIDER iceberg,
    KEY_ID 'OLD_GET_KEY',
    SECRET 'OLD_GET_KEY_SECRET',
    REGION 'us-east-1',
    ENDPOINT '127.0.0.1:9000',
    URL_STYLE 'path',
    USE_SSL 0,
    HTTP_PROXY '${VENDED_CREDENTIAL_REFRESH_PROXY}',
    SCOPE 's3://warehouse/vended_credentials_refresh/get',
    REFRESH_INFO MAP {
        'catalog_name': 'vended_refresh',
        'schema': 'default',
        'table': 'vended_get_refresh'
    }
)

statement ok
CALL truncate_duckdb_logs()

statement ok
SET force_download=true

query I
SELECT count(*) FROM read_parquet('s3://warehouse/vended_credentials_refresh/get/data.parquet')
----
3

statement ok
SET force_download=false

query I
SELECT count(*) > 0
FROM duckdb_logs_parsed('HTTP')
WHERE request.url LIKE '%/vended_credentials_refresh/get/data.parquet'
  AND request.type = 'GET'
  AND request.headers['Range'] IS NULL
  AND request.headers['Authorization'] LIKE '%OLD_GET_KEY%'
  AND (response.reason = 'Forbidden' OR response.status IS NULL)
----
1

query I
SELECT count(*) > 0
FROM duckdb_logs_parsed('HTTP')
WHERE request.url LIKE '%/vended_credentials_refresh/get/data.parquet'
  AND request.type = 'GET'
