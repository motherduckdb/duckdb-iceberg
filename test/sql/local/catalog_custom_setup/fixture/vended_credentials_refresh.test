# name: test/sql/local/catalog_custom_setup/fixture/vended_credentials_refresh.test
# description: vended Iceberg storage credentials refresh on S3 auth failures, including ranged reads
# group: [fixture]

require-env FIXTURE_SERVER_AVAILABLE

require-env VENDED_CREDENTIAL_REFRESH_PROXY

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages.
set ignore_error_messages

statement ok
SET enable_logging=true

statement ok
SET logging_level='debug'

statement ok
CALL enable_logging('HTTP')

statement ok
CREATE SECRET vended_refresh_http_proxy (
    TYPE HTTP,
    HTTP_PROXY '${VENDED_CREDENTIAL_REFRESH_PROXY}'
)

statement ok
ATTACH '' AS vended_refresh (
    TYPE ICEBERG,
    ENDPOINT 'http://127.0.0.1:8181',
    AUTHORIZATION_TYPE 'oauth2',
    CLIENT_ID 'admin',
    CLIENT_SECRET 'password',
    OAUTH2_SERVER_URI 'http://127.0.0.1:8181/v1/oauth/tokens'
)

# Create the same scoped S3 secret shape that Iceberg vended credentials install.
# The refresh_info points back to the Iceberg catalog/table; on a 403, HTTPFS
# asks the Iceberg provider to re-vend credentials from the catalog.
statement ok
CREATE OR REPLACE SECRET vended_init_refresh_secret (
    TYPE S3,
    PROVIDER iceberg,
    KEY_ID 'OLD_INIT_KEY',
    SECRET 'OLD_INIT_KEY_SECRET',
    REGION 'us-east-1',
    ENDPOINT '127.0.0.1:9000',
    URL_STYLE 'path',
    USE_SSL 0,
    HTTP_PROXY '${VENDED_CREDENTIAL_REFRESH_PROXY}',
    SCOPE 's3://warehouse/vended_credentials_refresh/init',
    REFRESH_INFO MAP {
        'catalog_name': 'vended_refresh',
        'schema': 'default',
        'table': 'vended_init_refresh'
    }
)

statement ok
CALL truncate_duckdb_logs()

query IT
SELECT * FROM read_parquet('s3://warehouse/vended_credentials_refresh/init/data.parquet') ORDER BY ALL
----
1	foo
2	bar
3	baz

query I
SELECT count(*) > 0
FROM duckdb_logs_parsed('HTTP')
WHERE request.url = 'http://127.0.0.1:8181/v1/namespaces/default/tables/vended_init_refresh'
  AND response.status = 'OK_200'
----
1

query I
SELECT count(*) > 0
FROM duckdb_logs_parsed('HTTP')
WHERE starts_with(request.url, 'http://127.0.0.1:9000/')
  AND response.reason = 'Forbidden'
  AND request.headers['Authorization'] LIKE '%OLD_INIT_KEY%'
----
1

query I
SELECT count(*) > 0
FROM duckdb_logs_parsed('HTTP')
WHERE starts_with(request.url, 'http://127.0.0.1:9000/')
  AND response.status IN ('OK_200', 'PartialContent_206')
  AND request.headers['Authorization'] LIKE '%NEW_INIT_KEY%'
----
1

query II
SELECT count(*), CAST(bool_or(secret_string LIKE '%key_id=NEW_INIT_KEY%') AS INTEGER)
FROM duckdb_secrets(redact=false)
WHERE name='vended_init_refresh_secret'
----
1	1

query I
SELECT count(*)
FROM duckdb_secrets(redact=false)
WHERE name='vended_init_refresh_secret'
  AND secret_string LIKE '%OLD_INIT_KEY%'
----
0

statement ok
CALL truncate_duckdb_logs()

# Register a second vended-style secret scoped to another object. Initial file
# access succeeds with OLD_RANGE_KEY. The proxy rejects the first ranged GET with
# 403, so a successful scan proves S3FileSystem::GetRangeRequest refreshed the
# vended secret and retried the range request.
statement ok
CREATE OR REPLACE SECRET vended_range_refresh_secret (
    TYPE S3,
    PROVIDER iceberg,
    KEY_ID 'OLD_RANGE_KEY',
    SECRET 'OLD_RANGE_KEY_SECRET',
    REGION 'us-east-1',
    ENDPOINT '127.0.0.1:9000',
    URL_STYLE 'path',
    USE_SSL 0,
    HTTP_PROXY '${VENDED_CREDENTIAL_REFRESH_PROXY}',
    SCOPE 's3://warehouse/vended_credentials_refresh/range',
    REFRESH_INFO MAP {
        'catalog_name': 'vended_refresh',
        'schema': 'default',
        'table': 'vended_range_refresh'
    }
)

statement ok
CALL truncate_duckdb_logs()

query I
SELECT count(*) FROM read_parquet('s3://warehouse/vended_credentials_refresh/range/data.parquet')
----
111968

query I
SELECT count(*) > 0
FROM duckdb_logs_parsed('HTTP')
WHERE request.url = 'http://127.0.0.1:8181/v1/namespaces/default/tables/vended_range_refresh'
  AND response.status = 'OK_200'
----
1

query I
SELECT count(*) > 0
FROM duckdb_logs_parsed('HTTP')
WHERE starts_with(request.url, 'http://127.0.0.1:9000/')
  AND request.url LIKE '%/vended_credentials_refresh/range/data.parquet'
  AND request.type = 'GET'
  AND request.headers['Range'] IS NOT NULL
  AND response.status IS NULL
  AND request.headers['Authorization'] LIKE '%OLD_RANGE_KEY%'
----
1

query I
SELECT count(*) > 0
FROM duckdb_logs_parsed('HTTP')
WHERE starts_with(request.url, 'http://127.0.0.1:9000/')
  AND request.url LIKE '%/vended_credentials_refresh/range/data.parquet'
  AND request.type = 'GET'
  AND request.headers['Range'] IS NOT NULL
  AND response.status = 'PartialContent_206'
  AND request.headers['Authorization'] LIKE '%NEW_RANGE_KEY%'
----
1

query II
SELECT count(*), CAST(bool_or(secret_string LIKE '%key_id=NEW_RANGE_KEY%') AS INTEGER)
FROM duckdb_secrets(redact=false)
WHERE name='vended_range_refresh_secret'
----
1	1

query I
SELECT count(*)
FROM duckdb_secrets(redact=false)
WHERE name='vended_range_refresh_secret'
  AND secret_string LIKE '%OLD_RANGE_KEY%'
----
0

# If refresh produces the same credentials, HTTPFS must not spin on repeated
# refresh/retry attempts.
statement ok
CREATE OR REPLACE SECRET vended_same_bad_refresh_secret (
    TYPE S3,
    PROVIDER iceberg,
    KEY_ID 'OLD_SAME_BAD_KEY',
    SECRET 'OLD_SAME_BAD_KEY_SECRET',
    REGION 'us-east-1',
    ENDPOINT '127.0.0.1:9000',
    URL_STYLE 'path',
    USE_SSL 0,
    HTTP_PROXY '${VENDED_CREDENTIAL_REFRESH_PROXY}',
    SCOPE 's3://warehouse/vended_credentials_refresh/same_bad',
    REFRESH_INFO MAP {
        'catalog_name': 'vended_refresh',
        'schema': 'default',
        'table': 'vended_same_bad_refresh'
    }
)

statement ok
CALL truncate_duckdb_logs()

statement error
SELECT * FROM read_parquet('s3://warehouse/vended_credentials_refresh/same_bad/data.parquet')
----
<REGEX>:.*HTTP Error:.*403.*

query I
SELECT count(*) BETWEEN 1 AND 2
FROM duckdb_logs_parsed('HTTP')
WHERE request.url = 'http://127.0.0.1:8181/v1/namespaces/default/tables/vended_same_bad_refresh'
  AND response.status = 'OK_200'
----
1

# If refreshed range credentials also fail, HTTPFS should surface the second
# 403 after one range retry, not refresh forever.
statement ok
CREATE OR REPLACE SECRET vended_range_fail_refresh_secret (
    TYPE S3,
    PROVIDER iceberg,
    KEY_ID 'OLD_RANGE_FAIL_KEY',
    SECRET 'OLD_RANGE_FAIL_KEY_SECRET',
    REGION 'us-east-1',
    ENDPOINT '127.0.0.1:9000',
    URL_STYLE 'path',
    USE_SSL 0,
    HTTP_PROXY '${VENDED_CREDENTIAL_REFRESH_PROXY}',
    SCOPE 's3://warehouse/vended_credentials_refresh/range_fail',
    REFRESH_INFO MAP {
        'catalog_name': 'vended_refresh',
        'schema': 'default',
        'table': 'vended_range_fail_refresh'
    }
)

statement ok
CALL truncate_duckdb_logs()

statement error
SELECT * FROM read_parquet('s3://warehouse/vended_credentials_refresh/range_fail/data.parquet')
----
<REGEX>:.*HTTP Error:.*403.*

query I
SELECT count(*)
FROM duckdb_logs_parsed('HTTP')
WHERE request.url = 'http://127.0.0.1:8181/v1/namespaces/default/tables/vended_range_fail_refresh'
  AND response.status = 'OK_200'
----
1

query I
SELECT count(*) > 0
FROM duckdb_logs_parsed('HTTP')
WHERE starts_with(request.url, 'http://127.0.0.1:9000/')
  AND request.headers['Authorization'] LIKE '%NEW_RANGE_FAIL_KEY%'
  AND request.headers['Range'] IS NOT NULL
  AND response.status IS NULL
----
1

statement ok
DETACH vended_refresh
