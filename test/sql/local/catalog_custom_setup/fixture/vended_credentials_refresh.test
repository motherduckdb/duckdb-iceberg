# Delete refresh: COPY OVERWRITE removes old partition files via S3 DeleteObjects.
statement ok
CREATE OR REPLACE SECRET vended_delete_setup_secret (
    TYPE S3,
    KEY_ID 'NEW_DELETE_KEY',
    SECRET 'NEW_DELETE_KEY_SECRET',
    REGION 'us-east-1',
    ENDPOINT '127.0.0.1:9000',
    URL_STYLE 'path',
    USE_SSL 0,
    HTTP_PROXY '${VENDED_CREDENTIAL_REFRESH_PROXY}',
    SCOPE 's3://warehouse/vended_credentials_refresh/delete'
)

statement ok
COPY (SELECT 1 AS part_col, 'old' AS value) TO 's3://warehouse/vended_credentials_refresh/delete' (FORMAT PARQUET, PARTITION_BY (part_col), OVERWRITE_OR_IGNORE TRUE)

statement ok
DROP SECRET vended_delete_setup_secret

statement ok
