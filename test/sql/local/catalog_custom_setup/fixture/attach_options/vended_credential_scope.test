# name: test/sql/local/catalog_custom_setup/fixture/attach_options/vended_credential_scope.test
# description: vended storage credentials should be scoped to the Iceberg data path for writes
# group: [attach_options]

require-env FIXTURE_SERVER_AVAILABLE

require avro

require parquet

require iceberg

require httpfs

require aws

set ignore_error_messages

statement ok
CREATE SECRET (
    TYPE S3,
    KEY_ID 'admin',
    SECRET 'password',
    ENDPOINT '127.0.0.1:9000',
    URL_STYLE 'path',
    USE_SSL 0,
    REGION 'us-east-1'
);

statement ok
ATTACH '' AS sigv4_lake (
    TYPE ICEBERG,
    ENDPOINT 'http://127.0.0.1:8181',
    AUTHORIZATION_TYPE 'sigv4',
    SIGV4_SERVICE 'custom',
    SIGV4_REGION 'us-east-1'
);

statement ok
create schema if not exists sigv4_lake.default;

statement ok
drop table if exists sigv4_lake.default.test_vended_credential_scope;

statement ok
create table sigv4_lake.default.test_vended_credential_scope
with ('write.data.path' = 's3://warehouse/custom-data/test_vended_credential_scope')
as select 1 as id;

query I
select count(*) from sigv4_lake.default.test_vended_credential_scope;
----
1

# Autocommit scans release their transaction-scoped vended credentials when the
# statement transaction ends.
query I
select count(*)
from duckdb_secrets()
where name = '__internal_ic_sigv4_lake__default__test_vended_credential_scope';
----
0

statement ok
begin;

query I
select count(*) from sigv4_lake.default.test_vended_credential_scope;
----
1

query I
select count(*) > 0
from duckdb_secrets()
where name = '__internal_ic_sigv4_lake__default__test_vended_credential_scope'
  and storage = 'transaction'
  and list_contains(scope, 's3://warehouse/custom-data/test_vended_credential_scope/');
----
1

# Transaction secrets are invisible to other connections.
query I con1
select count(*)
from duckdb_secrets()
where name = '__internal_ic_sigv4_lake__default__test_vended_credential_scope';
----
0

statement ok
commit;

query I
select count(*)
from duckdb_secrets()
where name = '__internal_ic_sigv4_lake__default__test_vended_credential_scope';
----
0

# Rollback has the same structural cleanup behavior.
statement ok
begin;

query I
select count(*) from sigv4_lake.default.test_vended_credential_scope;
----
1

statement ok
rollback;

query I
select count(*)
from duckdb_secrets()
where name = '__internal_ic_sigv4_lake__default__test_vended_credential_scope';
----
0

statement ok
drop table if exists sigv4_lake.default.test_vended_credential_scope;
