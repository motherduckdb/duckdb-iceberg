# name: test/sql/local/catalog_custom_setup/fixture/transaction_local_entries_not_evicted.test
# description: Transaction-local table state must remain stable once touched, even when the shared staleness cache is evicted by commits on other connections
# group: [fixture]

require-env FIXTURE_SERVER_AVAILABLE

require avro

require parquet

require iceberg

require httpfs

require core_functions

set ignore_error_messages

statement ok
CREATE SECRET (
    TYPE S3,
    KEY_ID 'admin',
    SECRET 'password',
    ENDPOINT '127.0.0.1:9000',
    URL_STYLE 'path',
    USE_SSL 0
);

# Re-attach with staleness so cache eviction on commit is active
statement ok
ATTACH OR REPLACE '' AS my_datalake (
    TYPE ICEBERG,
    CLIENT_ID 'admin',
    CLIENT_SECRET 'password',
    ENDPOINT 'http://127.0.0.1:8181',
    MAX_TABLE_STALENESS '10 minutes'
);

statement ok
CREATE SCHEMA IF NOT EXISTS my_datalake.default;

statement ok
DROP TABLE IF EXISTS my_datalake.default.txn_local_test;

statement ok
CREATE TABLE my_datalake.default.txn_local_test (id INTEGER, val VARCHAR);

statement ok
INSERT INTO my_datalake.default.txn_local_test VALUES (1, 'seed');

# con1 begins an explicit transaction and touches the table,
# pinning the snapshot in its transaction-local state.
statement ok con1
BEGIN;

query IT con1
SELECT id, val FROM my_datalake.default.txn_local_test ORDER BY id;
----
1	seed

# External writes advance the server snapshot and evict the shared
# staleness cache (successful commits evict when MAX_TABLE_STALENESS is set).
statement ok
INSERT INTO my_datalake.default.txn_local_test VALUES (2, 'external_1');

statement ok
INSERT INTO my_datalake.default.txn_local_test VALUES (3, 'external_2');

# con1's transaction-local state must be unaffected by the shared cache evictions.
# It should still see only the original snapshot.
query IT con1
SELECT id, val FROM my_datalake.default.txn_local_test ORDER BY id;
----
1	seed

statement ok con1
COMMIT;

# Outside the transaction, the latest data is visible.
query IT
SELECT id, val FROM my_datalake.default.txn_local_test ORDER BY id;
----
1	seed
2	external_1
3	external_2

# Cleanup
statement ok
DROP TABLE IF EXISTS my_datalake.default.txn_local_test;
