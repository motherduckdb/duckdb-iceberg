# name: test/sql/local/irc_any_catalog/reads/partitioned_reads/truncate/truncate_varchar.test
# group: [truncate]

require avro

require parquet

require iceberg

require-env DUCKDB_ICEBERG_HAVE_GENERATED_DATA

require-env SECRETS_CREATED_AND_CATALOG_ATTACHED

statement ok
create view scan as select * from my_datalake.default.truncate_partitioned_varchar;

query I
select count(*) from scan;
----
5

# unconstrained query reads all files
query II
explain analyze select * from scan;
----
analyzed_plan	<REGEX>:.*Total Files Read: 3\s+.*

query I
select count(*) from scan where nested.data >= '🐯';
----
3

# query II
# explain analyze select * from scan where nested.data >= '🐯';
# ----
# analyzed_plan	<REGEX>:.*Total Files Read: 1\s+.*

query I
select count(*) from scan where nested.data = '☭☫☦︎';
----
1

# query II
# explain analyze select * from scan where nested.data = '☭☫☦︎';
# ----
# analyzed_plan	<REGEX>:.*Total Files Read: 1\s+.*
