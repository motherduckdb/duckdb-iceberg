# name: test/sql/local/irc_any_catalog/other_engines/test_create_partitioned_tables.test
# description: create and populate partitioned tables by various types in v2 and v3, for cross-engine read testing
# group: [other_engines]

require-env ICEBERG_SERVER_AVAILABLE

require-env SECRETS_CREATED_AND_CATALOG_ATTACHED

require avro

require parquet

require iceberg

require httpfs

require icu

statement ok
SET timezone='UTC';

# Do not ignore 'HTTP' error messages!
set ignore_error_messages


statement ok
create schema if not exists my_datalake.default;

# ============================================================
# INT
# ============================================================

statement ok
drop table if exists my_datalake.default.test_table_partitioned_by_int_format_version_2;

statement ok
CREATE TABLE my_datalake.default.test_table_partitioned_by_int_format_version_2 (id INT, val INT)
PARTITIONED BY (val)
WITH ('format-version' = 2);

statement ok
INSERT INTO my_datalake.default.test_table_partitioned_by_int_format_version_2 VALUES
    (1, 10), (2, 20), (3, 10), (4, 30);

statement ok
drop table if exists my_datalake.default.test_table_partitioned_by_int_format_version_3;

statement ok
CREATE TABLE my_datalake.default.test_table_partitioned_by_int_format_version_3 (id INT, val INT)
PARTITIONED BY (val)
WITH ('format-version' = 3);

statement ok
INSERT INTO my_datalake.default.test_table_partitioned_by_int_format_version_3 VALUES
    (1, 10), (2, 20), (3, 10), (4, 30);

