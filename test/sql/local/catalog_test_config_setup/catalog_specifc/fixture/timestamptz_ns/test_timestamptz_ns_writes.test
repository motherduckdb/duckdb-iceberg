	id INT DEFAULT 1,
	val TIMESTAMPTZ_NS DEFAULT '2021-06-20 16:45:00.987654321+02'::TIMESTAMPTZ_NS
) WITH ('format-version' = 3);

statement ok
INSERT INTO my_datalake.default.test_timestamptz_ns_write_default DEFAULT VALUES;

query II
