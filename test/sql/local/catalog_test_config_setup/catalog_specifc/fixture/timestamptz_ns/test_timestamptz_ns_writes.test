# name: test/sql/local/catalog_test_config_setup/catalog_specifc/fixture/timestamptz_ns/test_timestamptz_ns_writes.test
# description: Write v3 TIMESTAMPTZ_NS values, partition transforms, defaults, type evolution errors, and sort orders
# group: [timestamptz_ns]

require-env CATALOG_TEST_CONFIG_SETUP fixture

require avro

require parquet

require iceberg

require httpfs

require icu

statement ok
SET Calendar='gregorian';

statement ok
SET TimeZone='Europe/Amsterdam';

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
create schema if not exists my_datalake.default;

statement ok
drop table if exists my_datalake.default.test_timestamptz_ns_transforms;

statement ok
CREATE TABLE my_datalake.default.test_timestamptz_ns_transforms (id INT, val TIMESTAMPTZ_NS)
PARTITIONED BY (year(val), month(val), day(val), hour(val))
WITH ('format-version' = 3);

statement ok
INSERT INTO my_datalake.default.test_timestamptz_ns_transforms VALUES
    (1, '2020-01-15 09:30:00.123456789+01'::TIMESTAMPTZ_NS),
    (2, '2021-06-20 16:45:00.987654321+02'::TIMESTAMPTZ_NS),
    (3, '2022-03-10 23:15:00.000000001+01'::TIMESTAMPTZ_NS);

query II
SELECT id, val FROM my_datalake.default.test_timestamptz_ns_transforms ORDER BY id;
----
1	2020-01-15 09:30:00.123456789+01
2	2021-06-20 16:45:00.987654321+02
3	2022-03-10 23:15:00.000000001+01

query IIII
SELECT partition_field_name, partition_field_transform, lower_bound, upper_bound
FROM iceberg_partition_stats(my_datalake.default.test_timestamptz_ns_transforms)
ORDER BY partition_field_name;
----
day_val_2	day	18276	19061
hour_val_2	hour	438632	457486
month_val_2	month	600	626
year_val_2	year	50	52

query II
SELECT id, val FROM my_datalake.default.test_timestamptz_ns_transforms
WHERE val = '2021-06-20 16:45:00.987654321+02'::TIMESTAMPTZ_NS;
----
2	2021-06-20 16:45:00.987654321+02

statement ok
drop table if exists my_datalake.default.test_timestamptz_ns_bucket;

statement ok
CREATE TABLE my_datalake.default.test_timestamptz_ns_bucket (id INT, val TIMESTAMPTZ_NS)
PARTITIONED BY (bucket(4, val))
WITH ('format-version' = 3);

statement ok
INSERT INTO my_datalake.default.test_timestamptz_ns_bucket VALUES
    (1, '2020-01-15 09:30:00.123456789+01'::TIMESTAMPTZ_NS),
    (2, '2021-06-20 16:45:00.987654321+02'::TIMESTAMPTZ_NS),
    (3, '2022-03-10 23:15:00.000000001+01'::TIMESTAMPTZ_NS),
    (4, NULL);

query II
SELECT id, val FROM my_datalake.default.test_timestamptz_ns_bucket ORDER BY id;
----
1	2020-01-15 09:30:00.123456789+01
2	2021-06-20 16:45:00.987654321+02
3	2022-03-10 23:15:00.000000001+01
4	NULL

query IIII
SELECT partition_field_name, partition_field_transform, lower_bound, upper_bound
FROM iceberg_partition_stats(my_datalake.default.test_timestamptz_ns_bucket)
ORDER BY partition_field_name;
----
bucket_4__val_2	bucket[4]	2	3

statement ok
drop table if exists my_datalake.default.test_timestamptz_ns_alter_type;

statement ok
CREATE TABLE my_datalake.default.test_timestamptz_ns_alter_type (val DATE)
WITH ('format-version' = 3);

statement error
ALTER TABLE my_datalake.default.test_timestamptz_ns_alter_type ALTER val TYPE TIMESTAMPTZ_NS;
----
Catalog Error: Column 'val' of type 'DATE' can't be altered to type 'TIMESTAMPTZ_NS'

statement ok
