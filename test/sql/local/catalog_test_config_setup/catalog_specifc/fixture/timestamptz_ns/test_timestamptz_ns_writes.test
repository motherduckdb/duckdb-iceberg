statement ok
ALTER TABLE my_datalake.default.test_timestamptz_ns_sort_year
SET SORTED BY (year(val) ASC NULLS LAST, id ASC NULLS LAST);

statement ok
INSERT INTO my_datalake.default.test_timestamptz_ns_sort_year VALUES
    (4, '2022-03-10 23:15:00.000000001+01'::TIMESTAMPTZ_NS),
    (2, '2020-01-15 09:30:00.123456789+01'::TIMESTAMPTZ_NS),
    (3, '2021-06-20 16:45:00.987654321+02'::TIMESTAMPTZ_NS),
    (1, '2019-07-04 05:00:00.000000001+02'::TIMESTAMPTZ_NS);

query III
