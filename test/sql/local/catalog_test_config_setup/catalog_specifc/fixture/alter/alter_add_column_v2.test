# name: test/sql/local/catalog_test_config_setup/catalog_specifc/fixture/alter/alter_add_column_v2.test
# group: [alter]

require-env CATALOG_TEST_CONFIG_SETUP fixture

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
CREATE SCHEMA IF NOT EXISTS my_datalake.default;

statement ok
drop table if exists my_datalake.default.alter_add_column_table;

statement ok
CREATE TABLE my_datalake.default.alter_add_column_table WITH ('format-version' = 2) AS (select range a FROM range(10));

statement ok
ALTER TABLE my_datalake.default.alter_add_column_table ADD COLUMN b int;

query II
FROM my_datalake.default.alter_add_column_table;
----
0	NULL
1	NULL
2	NULL
3	NULL
4	NULL
5	NULL
6	NULL
7	NULL
8	NULL
9	NULL

statement error
