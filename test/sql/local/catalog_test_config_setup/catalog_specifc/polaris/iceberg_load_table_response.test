# name: test/sql/local/catalog_test_config_setup/catalog_specifc/polaris/iceberg_load_table_response.test
# description: test iceberg metadata function
# group: [polaris]

require-env CATALOG_TEST_CONFIG_SETUP

require-env POLARIS_SERVER_AVAILABLE

require avro

require parquet

require iceberg

require httpfs

statement ok
CREATE SCHEMA IF NOT EXISTS my_datalake.default;

statement ok
drop table if exists my_datalake.default.my_table;

statement ok
CREATE TABLE my_datalake.default.my_table WITH ('format-version' = 2) AS (select range a FROM range(100));

statement ok
FROM iceberg_load_table_response(my_datalake.default.my_table);


# metadata_location
statement ok
SELECT metadata_location FROM iceberg_load_table_response(my_datalake.default.my_table);


# metadata
query I
SELECT metadata."format-version" FROM iceberg_load_table_response(my_datalake.default.my_table);
----
2

query I
SELECT metadata."current-schema-id" FROM iceberg_load_table_response(my_datalake.default.my_table);
----
0

query I
SELECT metadata."schemas"[1]."fields"[1]."name" FROM iceberg_load_table_response(my_datalake.default.my_table);
----
a


# storage_credentials
query I
select storage_credentials[1].prefix FROM iceberg_load_table_response(my_datalake.default.my_table);
----
s3://bucket123/default/my_table


# request_url
query I
select request_url FROM iceberg_load_table_response(my_datalake.default.my_table);
----
http://0.0.0.0:8181/api/catalog/v1/quickstart_catalog/namespaces/default/tables/my_table
