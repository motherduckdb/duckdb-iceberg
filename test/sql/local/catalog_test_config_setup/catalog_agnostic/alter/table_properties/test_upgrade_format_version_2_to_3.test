# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/alter/table_properties/test_upgrade_format_version_2_to_3.test
# description: Test upgrading an iceberg table from format version 2 to 3.
# group: [table_properties]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

require core_functions

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
DROP TABLE IF EXISTS my_datalake.default.v2_to_v3_upgrade;

# Create table explicitly as V2
statement ok
CREATE TABLE my_datalake.default.v2_to_v3_upgrade (id INT, val VARCHAR) WITH ('format-version'=2);


# insert data and delete some with positional delete files
# Insert 10 rows into one parquet file (snapshot 1, sequence 1)
statement ok
INSERT INTO my_datalake.default.v2_to_v3_upgrade
    SELECT range AS id, 'row_' || range::VARCHAR AS val FROM range(10);

query II
SELECT id, val FROM my_datalake.default.v2_to_v3_upgrade ORDER BY id;
----
0	row_0
1	row_1
2	row_2
3	row_3
4	row_4
5	row_5
6	row_6
7	row_7
8	row_8
9	row_9

# V2 table: _row_id is NULL for all rows (row lineage not tracked in V2)
query I
SELECT _row_id FROM my_datalake.default.v2_to_v3_upgrade ORDER BY id;
----
NULL
NULL
NULL
NULL
NULL
NULL
NULL
NULL
NULL
NULL

# Delete even-id rows — writes a V2 positional delete file (snapshot 2, sequence 2)
statement ok
DELETE FROM my_datalake.default.v2_to_v3_upgrade WHERE id % 2 = 0;

# 1 positional delete file
query I
select count(*) from iceberg_metadata(my_datalake.default.v2_to_v3_upgrade) where manifest_content = 'DELETE' and file_path like '%-deletes.parquet';
----
1

# 5 rows remain after V2 positional delete
query II
SELECT id, val FROM my_datalake.default.v2_to_v3_upgrade ORDER BY id;
----
1	row_1
3	row_3
5	row_5
7	row_7
9	row_9

# Surviving V2 rows still have _row_id = NULL before any V3 write.
# Sequence 1 because the positional delete did not rewrite the data file.
query III
SELECT _last_updated_sequence_number, _row_id, id FROM my_datalake.default.v2_to_v3_upgrade ORDER BY id;
----
1	NULL	1
1	NULL	3
1	NULL	5
1	NULL	7
1	NULL	9

# Upgrade to V3
statement ok
ALTER TABLE my_datalake.default.v2_to_v3_upgrade SET ('format-version'=3);

# Immediately after upgrade — no V3 snapshot written yet — row IDs are still NULL
query III
SELECT _last_updated_sequence_number, _row_id, id FROM my_datalake.default.v2_to_v3_upgrade ORDER BY id;
----
1	NULL	1
1	NULL	3
1	NULL	5
1	NULL	7
1	NULL	9

# V3 Phase insert V3 rows

# Insert 5 new rows (snapshot 3, sequence 3).
# On this first V3 write, CacheExistingManifestList retroactively assigns
# first_row_id to the carried-forward V2 manifest.  The original parquet file
# held 10 rows (added_rows_count = 10), so the 5 surviving V2 rows receive their
# 0-based positions within that file as row IDs: 1, 3, 5, 7, 9.
# The 5 new V3 rows continue from row_id 10: row_ids 10–14.
statement ok
INSERT INTO my_datalake.default.v2_to_v3_upgrade
    SELECT 10 + range AS id, 'new_row_' || range::VARCHAR AS val FROM range(5);

# 10 rows total: 5 pre-upgrade + 5 post-upgrade
query II
SELECT id, val FROM my_datalake.default.v2_to_v3_upgrade ORDER BY id;
----
1	row_1
3	row_3
5	row_5
7	row_7
9	row_9
10	new_row_0
11	new_row_1
12	new_row_2
13	new_row_3
14	new_row_4

# New V3 rows start at row_id 10 (= added_rows_count of the V2 parquet file).
query IIII
SELECT _last_updated_sequence_number, _row_id, id, val
FROM my_datalake.default.v2_to_v3_upgrade ORDER BY id;
----
1	1	1	row_1
1	3	3	row_3
1	5	5	row_5
1	7	7	row_7
1	9	9	row_9
3	10	10	new_row_0
3	11	11	new_row_1
3	12	12	new_row_2
3	13	13	new_row_3
3	14	14	new_row_4

# _row_id can be used to filter rows — both for pre-upgrade (retroactive) and
# post-upgrade (native) row IDs
query II
SELECT id, val FROM my_datalake.default.v2_to_v3_upgrade WHERE _row_id = 3 ORDER BY id;
----
3	row_3

query II
SELECT id, val FROM my_datalake.default.v2_to_v3_upgrade WHERE _row_id = 12 ORDER BY id;
----
12	new_row_2

# V3 delete: deletion vector written for the V3 data file
# Delete by _row_id: removes rows 10 and 13 from the V3 parquet file in a single
# deletion vector write (snapshot 4, sequence 4)
statement ok
DELETE FROM my_datalake.default.v2_to_v3_upgrade WHERE _row_id IN (10, 13);

# 1 positional delete file (left over from v2)
query I
select count(*) from iceberg_metadata(my_datalake.default.v2_to_v3_upgrade) where manifest_content = 'DELETE' and file_path like '%-deletes.parquet';
----
1

# 1 deletion vector (left over from v2)
query I
select count(*) from iceberg_metadata(my_datalake.default.v2_to_v3_upgrade) where manifest_content = 'DELETE' and file_path like '%-deletes.puffin';
----
1

# 8 rows remain: 5 pre-upgrade + 3 post-upgrade
query II
SELECT id, val FROM my_datalake.default.v2_to_v3_upgrade ORDER BY id;
----
1	row_1
3	row_3
5	row_5
7	row_7
9	row_9
11	new_row_1
12	new_row_2
14	new_row_4

# The deletion vector does not rewrite the V3 data file, so surviving new rows
# retain sequence 3.  Pre-upgrade rows are unaffected and retain sequence 1.
query IIII
SELECT _last_updated_sequence_number, _row_id, id, val
FROM my_datalake.default.v2_to_v3_upgrade ORDER BY id;
----
1	1	1	row_1
1	3	3	row_3
1	5	5	row_5
1	7	7	row_7
1	9	9	row_9
3	11	11	new_row_1
3	12	12	new_row_2
3	14	14	new_row_4

# update all data
statement ok
UPDATE my_datalake.default.v2_to_v3_upgrade set id = id + 100 where 1=1;

statement ok
DROP TABLE my_datalake.default.v2_to_v3_upgrade;
