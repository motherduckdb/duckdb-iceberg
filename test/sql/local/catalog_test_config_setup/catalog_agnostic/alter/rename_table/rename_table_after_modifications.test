# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/alter/rename_table/rename_table_after_modifications.test
# group: [rename_table]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

require ducklake

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
set enable_logging=true

statement ok
set logging_level='debug'

statement ok
drop table if exists my_datalake.default.rename_table;

statement ok
drop table if exists my_datalake.default.renamed_table;

statement ok
begin transaction

statement ok
create table my_datalake.default.rename_table(
	a VARCHAR,
	b BOOLEAN
);

statement ok
insert into my_datalake.default.rename_table VALUES (
	'test', true
)

# FIXME: support renaming a table with outstanding updates
statement error
ALTER TABLE my_datalake.default.rename_table RENAME TO renamed_table
----
Catalog Error: This table (rename_table) was modified already, can't be renamed!

statement error
select * from my_datalake.default.renamed_table
----
Catalog Error: Table with name renamed_table does not exist!

statement ok
commit

statement error
select * from my_datalake.default.renamed_table
----
Catalog Error: Table with name renamed_table does not exist!

statement ok
begin transaction

query II
select * from my_datalake.default.rename_table
----
test	true

statement ok
ALTER TABLE my_datalake.default.rename_table RENAME TO renamed_table

query II
select * from my_datalake.default.renamed_table
----
test	true

statement error
select * from my_datalake.default.rename_table
----
Catalog Error: Table with name rename_table does not exist!

statement ok
commit

statement error
select * from my_datalake.default.rename_table
----
Catalog Error: Table with name rename_table does not exist!

query II
select * from my_datalake.default.renamed_table
----
test	true
