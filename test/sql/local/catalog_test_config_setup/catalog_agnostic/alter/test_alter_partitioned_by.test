# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/alter/test_alter_partitioned_by.test
# group: [alter]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
CALL enable_logging(level='warning');

statement ok
SET warnings_as_errors = True;

statement ok
drop table if exists my_datalake.default.alter_table_partitioned_identity_transform;

statement ok
CREATE TABLE my_datalake.default.alter_table_partitioned_identity_transform AS (select range a, range%2 b FROM range(10));

statement ok
Alter table my_datalake.default.alter_table_partitioned_identity_transform SET PARTITIONED BY (b);

statement ok
insert into my_datalake.default.alter_table_partitioned_identity_transform values (11, 20);

#TODO verify data_file structure

statement ok
drop table if exists my_datalake.default.alter_table_partitioned_identity_transform;

statement ok
drop table if exists my_datalake.default.alter_table_partitioned_date_transform;

statement ok
drop table if exists my_datalake.default.alter_table_partitioned_struct_identity;

statement ok
CREATE TABLE my_datalake.default.alter_table_partitioned_struct_identity (
	id INTEGER,
	payload STRUCT(
		category VARCHAR,
		nested STRUCT(ts TIMESTAMP)
	)
);

statement ok
ALTER TABLE my_datalake.default.alter_table_partitioned_struct_identity SET PARTITIONED BY (payload.category);

statement ok
insert into my_datalake.default.alter_table_partitioned_struct_identity values
	(1, {'category': 'alpha', 'nested': {'ts': '2020-01-01 01:02:03'::TIMESTAMP}}),
	(2, {'category': 'beta', 'nested': {'ts': '2021-02-02 02:03:04'::TIMESTAMP}});

query IT
SELECT
	id,
	payload.category
FROM my_datalake.default.alter_table_partitioned_struct_identity
ORDER BY id;
----
1	alpha
2	beta

query T
SELECT spec.fields[1].transform
FROM iceberg_load_table_response('my_datalake.default.alter_table_partitioned_struct_identity'),
unnest(metadata."partition-specs"::VARIANT[]) AS t(spec)
WHERE try_cast(spec."spec-id" AS INTEGER) = metadata."default-spec-id";
----
identity

statement ok
drop table if exists my_datalake.default.alter_table_partitioned_struct_transform;

statement ok
CREATE TABLE my_datalake.default.alter_table_partitioned_struct_transform (
	id INTEGER,
	payload STRUCT(
		category VARCHAR,
		nested STRUCT(ts TIMESTAMP)
	)
);

statement ok
ALTER TABLE my_datalake.default.alter_table_partitioned_struct_transform SET PARTITIONED BY (year(payload.nested.ts));

statement ok
insert into my_datalake.default.alter_table_partitioned_struct_transform values
	(1, {'category': 'alpha', 'nested': {'ts': '2020-01-01 01:02:03'::TIMESTAMP}}),
	(2, {'category': 'beta', 'nested': {'ts': '2021-02-02 02:03:04'::TIMESTAMP}});

query IT
SELECT
	id,
	payload.nested.ts
FROM my_datalake.default.alter_table_partitioned_struct_transform
ORDER BY id;
----
1	2020-01-01 01:02:03
2	2021-02-02 02:03:04

query T
SELECT spec.fields[1].transform
FROM iceberg_load_table_response('my_datalake.default.alter_table_partitioned_struct_transform'),
unnest(metadata."partition-specs"::VARIANT[]) AS t(spec)
WHERE try_cast(spec."spec-id" AS INTEGER) = metadata."default-spec-id";
----
year

