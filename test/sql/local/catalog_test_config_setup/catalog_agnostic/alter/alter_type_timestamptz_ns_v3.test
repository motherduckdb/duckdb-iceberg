# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/alter/alter_type_timestamptz_ns_v3.test
# group: [alter]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

set ignore_error_messages

statement ok
CREATE SCHEMA IF NOT EXISTS my_datalake.default;

statement ok
DROP TABLE IF EXISTS my_datalake.default.test_timestamptz_ns_alter_type;

statement ok
CREATE TABLE my_datalake.default.test_timestamptz_ns_alter_type (
	val DATE
) WITH ('format-version' = 3);

statement error
ALTER TABLE my_datalake.default.test_timestamptz_ns_alter_type ALTER val TYPE TIMESTAMPTZ_NS;
----
Catalog Error: Column 'val' of type 'DATE' can't be altered to type 'TIMESTAMPTZ_NS'

statement ok
DROP TABLE my_datalake.default.test_timestamptz_ns_alter_type;
