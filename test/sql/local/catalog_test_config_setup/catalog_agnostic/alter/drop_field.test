# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/alter/drop_field.test
# group: [alter]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

statement ok
SET default_transaction_invalidation_policy='SYNTACTIC_ERRORS_DO_NOT_INVALIDATE';

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
set enable_logging=true

statement ok
set logging_level='debug'

statement ok
drop table if exists my_datalake.default.drop_struct_field;

statement ok
create table my_datalake.default.drop_struct_field(
	col STRUCT(
		a VARCHAR,
		b BOOLEAN,
		nested STRUCT(d DATE),
		also_nested STRUCT(e VARCHAR, f BIGINT)
	),
	not_a_struct BOOLEAN
);

statement ok
insert into my_datalake.default.drop_struct_field VALUES (
	{
		'a': 'test',
		'b': false,
		'nested': {
			'd': '2012/8/19'::DATE
		},
		'also_nested': {
			'e': 'test',
			'f': 42
		}
	},
	false
);

# Path doesn't exist
statement error
ALTER TABLE my_datalake.default.drop_struct_field DROP COLUMN not_a_struct.b;
----
Catalog Error: The column ('not_a_struct.b') doesnt exist on the table 'drop_struct_field', DROP COLUMN failed to remove the field

# Path doesn't exist (partially)
statement error
ALTER TABLE my_datalake.default.drop_struct_field DROP COLUMN col.not_existant.path;
----
Catalog Error: The column ('col.not_existant.path') doesnt exist on the table 'drop_struct_field', DROP COLUMN failed to remove the field

# Can't delete last field!
statement error
ALTER TABLE my_datalake.default.drop_struct_field DROP COLUMN col.nested.d;
----
Catalog Error: Can't drop field 'col.nested.d' because it's the last field of the STRUCT!

statement ok
ALTER TABLE my_datalake.default.drop_struct_field DROP COLUMN col.b;

query I
select typeof(col) from my_datalake.default.drop_struct_field limit 1;
----
STRUCT(a VARCHAR, nested STRUCT(d DATE), also_nested STRUCT(e VARCHAR, f BIGINT))

# 'c' doesn't exist but it's fine because of the IF EXISTS clause
statement ok
ALTER TABLE my_datalake.default.drop_struct_field DROP COLUMN IF EXISTS col.c;

# Added the new field 'c' to 'col'
query I
select typeof(col) from my_datalake.default.drop_struct_field limit 1;
----
STRUCT(a VARCHAR, nested STRUCT(d DATE), also_nested STRUCT(e VARCHAR, f BIGINT))

statement ok
insert into my_datalake.default.drop_struct_field VALUES (
	{'a': 'hello world', 'nested': {'d': '1982/2/12'::DATE}}, true
)

# FIXME: 'also_nested' should be NULL (in row 1), as it gets backfilled without a DEFAULT
# but NULL is treated differently for now (hopefully we can fix this behavior later)
query II
select * from my_datalake.default.drop_struct_field order by all;
----
{'a': hello world, 'nested': {'d': 1982-02-12}, 'also_nested': {'e': NULL, 'f': NULL}}	true
{'a': test, 'nested': {'d': 2012-08-19}, 'also_nested': {'e': test, 'f': 42}}	false

# ---------- Drop field from nested struct ----------

# 'g' doesn't exist
statement error
ALTER TABLE my_datalake.default.drop_struct_field DROP COLUMN col.also_nested.g;
----
Catalog Error: The column ('col.also_nested.g') doesnt exist on the table 'drop_struct_field', DROP COLUMN failed to remove the field

statement ok
ALTER TABLE my_datalake.default.drop_struct_field DROP COLUMN col.also_nested.e;

query I
select typeof(col) from my_datalake.default.drop_struct_field limit 1;
----
STRUCT(a VARCHAR, nested STRUCT(d DATE), also_nested STRUCT(f BIGINT))

statement ok
insert into my_datalake.default.drop_struct_field VALUES (
	{
		'a': 'hello world',
		'nested': {
			'd': '1982/2/12'::DATE
		}
	},
	true
);

# FIXME: 'also_nested' should be NULL, as it gets backfilled without a DEFAULT
# but NULL is treated differently for now (hopefully we can fix this behavior later)
query II
select * from my_datalake.default.drop_struct_field order by all;
----
{'a': hello world, 'nested': {'d': 1982-02-12}, 'also_nested': {'f': NULL}}	true
{'a': hello world, 'nested': {'d': 1982-02-12}, 'also_nested': {'f': NULL}}	true
{'a': test, 'nested': {'d': 2012-08-19}, 'also_nested': {'f': 42}}	false

statement ok
ALTER TABLE my_datalake.default.drop_struct_field DROP COLUMN col.nested;

query I
select typeof(col) from my_datalake.default.drop_struct_field limit 1;
----
STRUCT(a VARCHAR, also_nested STRUCT(f BIGINT))

statement ok
insert into my_datalake.default.drop_struct_field VALUES (
	{
		'a': 'hello world'
	},
	true
);

# FIXME: 'also_nested' should be NULL, as it gets backfilled without a DEFAULT
# but NULL is treated differently for now (hopefully we can fix this behavior later)
query II
select * from my_datalake.default.drop_struct_field order by all;
----
{'a': hello world, 'also_nested': {'f': NULL}}	true
{'a': hello world, 'also_nested': {'f': NULL}}	true
{'a': hello world, 'also_nested': {'f': NULL}}	true
{'a': test, 'also_nested': {'f': 42}}	false
