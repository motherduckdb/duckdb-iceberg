# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/alter/add_column/alter_add_column_transaction_with_changes.test
# group: [add_column]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
CALL enable_logging(level='warning');

statement ok
SET warnings_as_errors = True;

statement ok
CREATE SCHEMA IF NOT EXISTS my_datalake.default;

statement ok
drop table if exists my_datalake.default.alter_add_column_same_txn_table;

statement ok
CREATE TABLE my_datalake.default.alter_add_column_same_txn_table AS (select range a FROM range(10));

statement ok
begin;

statement ok
DELETE FROM my_datalake.default.alter_add_column_same_txn_table WHERE a=1;

statement ok
INSERT INTO my_datalake.default.alter_add_column_same_txn_table VALUES (42);

statement ok
UPDATE my_datalake.default.alter_add_column_same_txn_table SET a=42 WHERE a=3;

statement ok
ALTER TABLE my_datalake.default.alter_add_column_same_txn_table ADD COLUMN b int;

query II
FROM my_datalake.default.alter_add_column_same_txn_table ORDER BY ALL;
----
0	NULL
2	NULL
4	NULL
5	NULL
6	NULL
7	NULL
8	NULL
9	NULL
42	NULL
42	NULL

statement ok
commit;

query II
FROM my_datalake.default.alter_add_column_same_txn_table ORDER BY ALL;
----
0	NULL
2	NULL
4	NULL
5	NULL
6	NULL
7	NULL
8	NULL
9	NULL
42	NULL
42	NULL