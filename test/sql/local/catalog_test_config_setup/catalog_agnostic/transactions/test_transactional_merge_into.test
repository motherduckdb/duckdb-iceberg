# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/transactions/test_transactional_merge_into.test
# description: MERGE INTO update+insert uses transaction-start metadata and conflicts at catalog commit
# group: [transactions]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

statement ok
CALL enable_logging(level='warning');

statement ok
SET warnings_as_errors = True;

# Do not ignore HTTP error messages.
set ignore_error_messages

statement ok
set enable_logging=true

statement ok
set logging_level='debug'

statement ok
drop table if exists my_datalake.default.multi_transaction_merge;

statement ok
create table my_datalake.default.multi_transaction_merge (
	id int,
	value int
);

# Create a snapshot before either concurrent transaction starts.
statement ok
insert into my_datalake.default.multi_transaction_merge values
	(0, 0);

statement ok con1
begin

statement ok con2
begin

# Advance the catalog head after con1's transaction has started.
statement ok con2
insert into my_datalake.default.multi_transaction_merge values
	(2, 2);

statement ok con2
commit

# con1 reads the table at its transaction-start snapshot.
query II con1
select * from my_datalake.default.multi_transaction_merge order by id;
----
0	0

# Build a single MERGE against stale catalog metadata. The first source row
# updates an existing row and the second inserts a new row.
query I con1
MERGE INTO my_datalake.default.multi_transaction_merge AS target
USING (VALUES
	(0, 50),
	(3, 3)
) AS source(id, value)
ON target.id = source.id
WHEN MATCHED THEN UPDATE SET value = source.value
WHEN NOT MATCHED THEN INSERT VALUES (source.id, source.value);
----
2

# Both MERGE actions are visible locally, while con2's newer row remains hidden.
query II con1
select * from my_datalake.default.multi_transaction_merge order by id;
----
0	50
3	3

# The client constructed the update from stale metadata; the catalog detects
# the stale parent snapshot and rejects the atomic update+insert at commit.
statement error con1
commit;
----
<REGEX>:.*branch main has changed: expected id.*

# Neither part of the rejected MERGE reached committed state.
query II
select * from my_datalake.default.multi_transaction_merge order by id;
----
0	0
2	2
