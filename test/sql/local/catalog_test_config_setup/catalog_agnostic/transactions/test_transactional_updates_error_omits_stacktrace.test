# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/transactions/test_transactional_updates_error_omits_stacktrace.test
# group: [transactions]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
set iceberg_use_metadata_log = true;

statement ok
set enable_logging=true

statement ok
set logging_level='debug'

# Perform an INSERT and COMMIT it so table has a snapshot id other transactions can find
statement ok
drop table if exists my_datalake.default.multi_transaction_update;

statement ok
create table my_datalake.default.multi_transaction_update (a int, b int);

# make sure the table has a snapshot id to start
statement ok
insert into my_datalake.default.multi_transaction_update select 0, 0;

statement ok con1
begin

statement ok con2
begin

statement ok con2
insert into my_datalake.default.multi_transaction_update select 2, 2;

statement ok con2
commit

# con1 should only see data from con1 and before (from transaction start of con1)
query II con1
select * from my_datalake.default.multi_transaction_update;
----
0	0

# The historical table information is now pinned in transaction state and remains stable on repeated lookup.
query II con1
select * from my_datalake.default.multi_transaction_update;
----
0	0

statement ok con1
update my_datalake.default.multi_transaction_update set a = 50;

query II con1
select * from my_datalake.default.multi_transaction_update;
----
50	0

statement error con1
commit;
----
<REGEX>:.*Failed to commit.*

query II
select * from my_datalake.default.multi_transaction_update order by all;
----
0	0
2	2
