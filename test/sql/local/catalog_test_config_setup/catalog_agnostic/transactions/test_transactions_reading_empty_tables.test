# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/transactions/test_transactions_reading_empty_tables.test
# group: [transactions]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

require icu

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
set iceberg_use_metadata_log = false;

statement ok
set enable_logging=true

statement ok
set logging_level='debug'

statement ok
SET TimeZone = 'PST';

# Perform an INSERT and COMMIT it
statement ok
drop table if exists my_datalake.default.multi_transaction_read_empty;


# create empty table
statement ok
create table my_datalake.default.multi_transaction_read_empty (a int, b int);

statement ok con1
begin

statement ok con2
begin

# con2 inserts
statement ok con2
insert into my_datalake.default.multi_transaction_read_empty select 2, 2;

statement ok con2
commit

# Without metadata-log reconstruction, con1 pins the complete metadata state
# resolved after con2's commit and sees its current snapshot.
query II con1
select * from my_datalake.default.multi_transaction_read_empty;
----
2	2

statement ok con1
rollback

# With metadata-log enabled, the pre-insert metadata file represents the empty
# transaction-start state completely, so the same sequence produces an empty scan.
statement ok
set iceberg_use_metadata_log = true;

statement ok
drop table if exists my_datalake.default.multi_transaction_read_reconstructed_empty;

statement ok
create table my_datalake.default.multi_transaction_read_reconstructed_empty (a int, b int);

statement ok con3
begin

statement ok con4
begin

statement ok con4
insert into my_datalake.default.multi_transaction_read_reconstructed_empty select 2, 2;

statement ok con4
commit

query I con3
select count(*) from my_datalake.default.multi_transaction_read_reconstructed_empty;
----
0

statement ok con3
rollback
