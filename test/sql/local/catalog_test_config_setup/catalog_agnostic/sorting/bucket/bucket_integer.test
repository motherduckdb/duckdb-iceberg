# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/sorting/bucket/bucket_integer.test
# group: [bucket]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
set threads=1;

statement ok
CREATE SCHEMA IF NOT EXISTS my_datalake.default;

statement ok
drop table if exists my_datalake.default.sort_bucket_integer;

statement ok
create table my_datalake.default.sort_bucket_integer (
	id int,
	val int
);

statement ok
alter table my_datalake.default.sort_bucket_integer set sorted by (
	bucket(4, val) asc nulls last,
	id asc nulls last
);

query T
SELECT sort_order.fields[1].transform
FROM iceberg_load_table_response(my_datalake.default.sort_bucket_integer),
unnest(metadata."sort-orders"::VARIANT[]) AS t(sort_order)
WHERE try_cast(sort_order."order-id" AS INTEGER) = metadata."default-sort-order-id";
----
bucket[4]

statement ok
insert into my_datalake.default.sort_bucket_integer
values
	(4, 100),
	(2, 0),
	(3, 55),
	(1, 10);

statement ok
set variable latest_manifest_sequence = (
	select max(manifest_sequence_number)
	from iceberg_metadata(my_datalake.default.sort_bucket_integer)
);

statement ok
set variable file_path = (
	select file_path
	from iceberg_metadata(my_datalake.default.sort_bucket_integer)
	where manifest_sequence_number = cast(getvariable('latest_manifest_sequence') as bigint)
	and manifest_content = 'DATA'
	and status = 'ADDED'
	limit 1
);

# Use the Iceberg scan handle and assert the exact physical row order by sorting
# on file_row_number.
query III
select iceberg_bucket(4, val) as sort_key, id, val
from my_datalake.default.sort_bucket_integer
where filename = getvariable('file_path')
order by file_row_number;
----
0	1	10
0	2	0
0	4	100
1	3	55

statement ok
drop table my_datalake.default.sort_bucket_integer;
