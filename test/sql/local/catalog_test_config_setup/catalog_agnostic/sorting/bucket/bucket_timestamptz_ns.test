# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/sorting/bucket/bucket_timestamptz_ns.test
# group: [bucket]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

require icu

statement ok
SET Calendar='gregorian';

statement ok
SET TimeZone='Europe/Amsterdam';

set ignore_error_messages

statement ok
set threads=1;

statement ok
CREATE SCHEMA IF NOT EXISTS my_datalake.default;

statement ok
DROP TABLE IF EXISTS my_datalake.default.sort_bucket_timestamptz_ns;

statement ok
CREATE TABLE my_datalake.default.sort_bucket_timestamptz_ns (
	id INT,
	ts TIMESTAMPTZ_NS
) WITH ('format-version' = 3);

statement ok
ALTER TABLE my_datalake.default.sort_bucket_timestamptz_ns
SET SORTED BY (bucket(4, ts) ASC NULLS LAST, id ASC NULLS LAST);

query T
SELECT sort_order.fields[1].transform
FROM iceberg_load_table_response(my_datalake.default.sort_bucket_timestamptz_ns),
unnest(metadata."sort-orders"::VARIANT[]) AS t(sort_order)
WHERE try_cast(sort_order."order-id" AS INTEGER) = metadata."default-sort-order-id";
----
bucket[4]

statement ok
INSERT INTO my_datalake.default.sort_bucket_timestamptz_ns VALUES
	(1, '2020-01-01 01:00:00+01'::TIMESTAMPTZ_NS),
	(2, '2020-01-01 02:00:00+01'::TIMESTAMPTZ_NS),
	(3, '2020-01-01 05:00:00+01'::TIMESTAMPTZ_NS),
	(4, '2020-01-01 10:00:00+01'::TIMESTAMPTZ_NS);

query IT
SELECT id, ts
FROM my_datalake.default.sort_bucket_timestamptz_ns
ORDER BY _row_id;
----
1	2020-01-01 01:00:00+01
2	2020-01-01 02:00:00+01
3	2020-01-01 05:00:00+01
4	2020-01-01 10:00:00+01

query IT
SELECT id, ts
FROM my_datalake.default.sort_bucket_timestamptz_ns
ORDER BY ts, id;
----
1	2020-01-01 01:00:00+01
2	2020-01-01 02:00:00+01
3	2020-01-01 05:00:00+01
4	2020-01-01 10:00:00+01

statement ok
DROP TABLE my_datalake.default.sort_bucket_timestamptz_ns;
