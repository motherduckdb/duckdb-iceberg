# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/sorting/hour/hour_struct_timestamp.test
# group: [hour]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
set threads=1;

statement ok
CREATE SCHEMA IF NOT EXISTS my_datalake.default;

statement ok
drop table if exists my_datalake.default.sort_hour_timestamp_struct_field;

statement ok
create table my_datalake.default.sort_hour_timestamp_struct_field (
	id int,
	nested STRUCT(
		filler VARCHAR,
		ts timestamp
	)
);

statement ok
alter table my_datalake.default.sort_hour_timestamp_struct_field set sorted by (
	hour(nested.ts) asc nulls last,
	id asc nulls last
);

query T
SELECT sort_order.fields[1].transform
FROM iceberg_load_table_response(my_datalake.default.sort_hour_timestamp_struct_field),
unnest(metadata."sort-orders"::VARIANT[]) AS t(sort_order)
WHERE try_cast(sort_order."order-id" AS INTEGER) = metadata."default-sort-order-id";
----
hour

statement ok
insert into my_datalake.default.sort_hour_timestamp_struct_field
values
	(4, {'ts': '2020-02-02 10:45:00'}),
	(2, {'ts': '2020-02-02 09:30:00'}),
	(3, {'ts': '2020-02-02 10:15:00'}),
	(1, {'ts': '2020-02-02 08:00:00'});

# Start transaction to keep necessary credentials in scope
statement ok
begin

statement ok
set variable latest_manifest_sequence = (
	select max(manifest_sequence_number)
	from iceberg_metadata(my_datalake.default.sort_hour_timestamp_struct_field)
);

statement ok
set variable file_path = (
	select file_path
	from iceberg_metadata(my_datalake.default.sort_hour_timestamp_struct_field)
	where manifest_sequence_number = cast(getvariable('latest_manifest_sequence') as bigint)
	and manifest_content = 'DATA'
	and status = 'ADDED'
	limit 1
);

# Read the parquet file back directly and assert the exact physical row order
# by sorting on file_row_number.
query IT
select id, nested.ts
from read_parquet(getvariable('file_path'), file_row_number=true)
order by file_row_number;
----
1	2020-02-02 08:00:00
2	2020-02-02 09:30:00
3	2020-02-02 10:15:00
4	2020-02-02 10:45:00

statement ok
drop table my_datalake.default.sort_hour_timestamp_struct_field;

statement ok
commit
