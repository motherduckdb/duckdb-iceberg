# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/sorting/identity/identity_struct_bool.test
# group: [identity]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

set ignore_error_messages

statement ok
set threads=1;

statement ok
CREATE SCHEMA IF NOT EXISTS my_datalake.default;

statement ok
drop table if exists my_datalake.default.sort_identity_bool_struct_field;

statement ok
create table my_datalake.default.sort_identity_bool_struct_field (
	id int,
	nested STRUCT(
		filler VARCHAR,
		sort_col boolean
	)
);

statement ok
alter table my_datalake.default.sort_identity_bool_struct_field set sorted by (
	nested.sort_col asc nulls last,
	id asc nulls last
);

statement ok
insert into my_datalake.default.sort_identity_bool_struct_field values
	(4, {'sort_col': true}),
	(2, {'sort_col': false}),
	(3, {'sort_col': true}),
	(1, {'sort_col': false});

# Start transaction to keep necessary credentials in scope
statement ok
begin

statement ok
set variable latest_manifest_sequence = (select max(manifest_sequence_number) from iceberg_metadata(my_datalake.default.sort_identity_bool_struct_field));

statement ok
set variable file_path = (
	select file_path from iceberg_metadata(my_datalake.default.sort_identity_bool_struct_field)
	where manifest_sequence_number = cast(getvariable('latest_manifest_sequence') as bigint)
	and manifest_content = 'DATA' and status = 'ADDED' limit 1
);

query II
select id, nested.sort_col from read_parquet(getvariable('file_path'), file_row_number=true) order by file_row_number;
----
1	false
2	false
3	true
4	true

statement ok
drop table my_datalake.default.sort_identity_bool_struct_field;

statement ok
commit
