# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/sorting/identity/identity_decimal_smallint.test
# group: [identity]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

set ignore_error_messages

statement ok
set threads=1;

statement ok
CREATE SCHEMA IF NOT EXISTS my_datalake.default;

statement ok
drop table if exists my_datalake.default.sort_identity_decimal_smallint;

statement ok
create table my_datalake.default.sort_identity_decimal_smallint (id int, sort_col decimal(4,1));

statement ok
alter table my_datalake.default.sort_identity_decimal_smallint set sorted by (sort_col asc nulls last, id asc nulls last);

statement ok
insert into my_datalake.default.sort_identity_decimal_smallint values
	(4, 2.0), (2, 1.0), (3, 3.0), (1, 1.0);

statement ok
set variable latest_manifest_sequence = (select max(manifest_sequence_number) from iceberg_metadata(my_datalake.default.sort_identity_decimal_smallint));

statement ok
set variable file_path = (
	select file_path from iceberg_metadata(my_datalake.default.sort_identity_decimal_smallint)
	where manifest_sequence_number = cast(getvariable('latest_manifest_sequence') as bigint)
	and manifest_content = 'DATA' and status = 'ADDED' limit 1
);

query II
select id, sort_col
from my_datalake.default.sort_identity_decimal_smallint
where filename = getvariable('file_path')
order by file_row_number;
----
1	1.0
2	1.0
4	2.0
3	3.0

statement ok
drop table my_datalake.default.sort_identity_decimal_smallint;
