# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/sorting/month/month_timestamp.test
# group: [month]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
set threads=1;

statement ok
CREATE SCHEMA IF NOT EXISTS my_datalake.default;

statement ok
drop table if exists my_datalake.default.sort_month_timestamp;

statement ok
create table my_datalake.default.sort_month_timestamp (
	id int,
	ts timestamp
);

statement ok
alter table my_datalake.default.sort_month_timestamp set sorted by (
	month(ts) asc nulls last,
	id asc nulls last
);

query T
SELECT sort_order.fields[1].transform
FROM iceberg_load_table_response(my_datalake.default.sort_month_timestamp),
unnest(metadata."sort-orders"::VARIANT[]) AS t(sort_order)
WHERE try_cast(sort_order."order-id" AS INTEGER) = metadata."default-sort-order-id";
----
month

statement ok
insert into my_datalake.default.sort_month_timestamp
values
	(4, '2020-02-20 10:00:00'),
	(2, '2019-12-31 05:00:00'),
	(3, '2020-02-01 09:00:00'),
	(1, '2020-01-04 03:00:00');

statement ok
set variable latest_manifest_sequence = (
	select max(manifest_sequence_number)
	from iceberg_metadata(my_datalake.default.sort_month_timestamp)
);

statement ok
set variable file_path = (
	select file_path
	from iceberg_metadata(my_datalake.default.sort_month_timestamp)
	where manifest_sequence_number = cast(getvariable('latest_manifest_sequence') as bigint)
	and manifest_content = 'DATA'
	and status = 'ADDED'
	limit 1
);

# Read the parquet file back directly and assert the exact physical row order
# by sorting on file_row_number.
query IT
select id, ts
from read_parquet(getvariable('file_path'), file_row_number=true)
order by file_row_number;
----
2	2019-12-31 05:00:00
1	2020-01-04 03:00:00
3	2020-02-01 09:00:00
4	2020-02-20 10:00:00

statement ok
drop table my_datalake.default.sort_month_timestamp;
