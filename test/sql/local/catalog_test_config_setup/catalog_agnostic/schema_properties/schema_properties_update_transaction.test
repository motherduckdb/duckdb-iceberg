# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/schema_properties/schema_properties_update_transaction.test
# group: [schema_properties]

require-env CATALOG_TEST_CONFIG_SETUP

statement ok
DROP SCHEMA IF EXISTS my_datalake.myschema123;

statement ok
CREATE SCHEMA IF NOT EXISTS my_datalake.myschema123;

query I
CALL remove_iceberg_schema_properties(my_datalake.myschema123, ['namespace_id']);
----
1

query II
FROM iceberg_schema_properties(my_datalake.myschema123) WHERE key != 'location' ORDER BY ALL;
----

statement ok
BEGIN;

query I
CALL set_iceberg_schema_properties(my_datalake.myschema123,
    {
    'myprop1' : '1',
    'myprop2' : '2',
    'myprop3' : '3',
    }
);
----
4

query II
FROM iceberg_schema_properties(my_datalake.myschema123) WHERE key != 'location' ORDER BY ALL;
----
myprop1	1
myprop2	2
myprop3	3

query I
CALL remove_iceberg_schema_properties(my_datalake.myschema123, ['myprop2']);
----
3

statement ok
COMMIT;

query II
FROM iceberg_schema_properties(my_datalake.myschema123) WHERE key != 'location' ORDER BY ALL;
----
myprop1	1
myprop3	3

# set/remove_iceberg_schema_properties mutate the catalog, so they must be rejected inside a read-only
# transaction. This only holds if the bind declares the modification (RegisterDBModify).
statement ok
BEGIN TRANSACTION READ ONLY;

statement error
CALL set_iceberg_schema_properties(my_datalake.myschema123, {'k' : 'v'});
----
<REGEX>:.*read-only.*

statement ok
ROLLBACK;

statement ok
BEGIN TRANSACTION READ ONLY;

statement error
CALL remove_iceberg_schema_properties(my_datalake.myschema123, ['myprop1']);
----
<REGEX>:.*read-only.*

statement ok
ROLLBACK;

#cleanup
statement ok
DROP SCHEMA my_datalake.myschema123;

