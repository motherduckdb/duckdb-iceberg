# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/create/default/test_create_default_timestamptz_ns.test
# group: [default]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

require icu

statement ok
SET TimeZone='Europe/Amsterdam';

statement ok
SET Calendar='gregorian';

set ignore_error_messages

statement ok
CREATE SCHEMA IF NOT EXISTS my_datalake.default;

statement ok
DROP TABLE IF EXISTS my_datalake.default.test_create_default_timestamptz_ns;

statement ok
CREATE TABLE my_datalake.default.test_create_default_timestamptz_ns (
	id INT DEFAULT 1,
	val TIMESTAMPTZ_NS DEFAULT '2021-06-20 16:45:00.987654321+02'::TIMESTAMPTZ_NS
) WITH ('format-version' = 3);

statement ok
INSERT INTO my_datalake.default.test_create_default_timestamptz_ns DEFAULT VALUES;

query II
SELECT id, val
FROM my_datalake.default.test_create_default_timestamptz_ns
ORDER BY id;
----
1	2021-06-20 16:45:00.987654321+02

statement ok
DROP TABLE my_datalake.default.test_create_default_timestamptz_ns;
