# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/create/default/test_create_default_struct_nested.test
# description: Regression for non-flat vector in ManifestListReader when manifest_list has many entries
# group: [default]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

# Struct nested within another struct within another struct

statement ok
drop table if exists my_datalake.default.nested_nested_tbl;

# NOTE: Since no engine/catalog supports the {} default for STRUCT, we write NULL (omit the initial-default) for STRUCT instead
# This changes the behavior matrix, and will need to be updated when support for {} is added
statement ok
create table my_datalake.default.nested_nested_tbl(
	col STRUCT(
		a VARCHAR,
		b STRUCT(
			v1 BIGINT,
			v2 STRUCT(
				f1 VARCHAR,
				f2 VARCHAR,
				f3 VARCHAR
			),
			v3 BIGINT
		),
		e BOOLEAN
	) DEFAULT {
		'a': 'test',
		'b': {
			'v1': 1000,
			'v2': {
				'f1': 'alpha',
				'f3': 'gamma'
			},
			'v3': -500
		},
		'e': NULL
	},
	col2 INTEGER
) WITH (
	'format-version'= 3
);

# col.b.in: -
# col.b.default: {}
# col.b.v2.f1.default: alpha
# col.b.v2.f2.default: -
# col.b.v2.f3.default: gamma
# col.b.v2.result: {'f1': alpha, 'f2': NULL, 'f3': gamma}
statement ok
insert into my_datalake.default.nested_nested_tbl (col2) VALUES (12)

query II
select * from my_datalake.default.nested_nested_tbl order by all;
----
{'a': test, 'b': {'v1': 1000, 'v2': {'f1': alpha, 'f2': NULL, 'f3': gamma}, 'v3': -500}, 'e': NULL}	12

# Only supply b.v2.f3 as NULL, overriding its default of gamma; f1 retains its default, f2 remains NULL

# col.b.in: {'v2': {'f3': NULL}}
# col.b.default: {}
# col.b.v2.f1.default: alpha
# col.b.v2.f2.default: -
# col.b.v2.f3.default: gamma
# col.b.v2.result: {'f1': alpha, 'f2': NULL, 'f3': NULL}
statement ok
insert into my_datalake.default.nested_nested_tbl BY NAME FROM
	VALUES (
		{
			'b': {
				'v2': {
					'f3': NULL
				}
			}
		},
		24
	) t(col, col2)

query II
select * from my_datalake.default.nested_nested_tbl order by all;
----
{'a': test, 'b': {'v1': 1000, 'v2': {'f1': alpha, 'f2': NULL, 'f3': gamma}, 'v3': -500}, 'e': NULL}	12
{'a': test, 'b': {'v1': 1000, 'v2': {'f1': alpha, 'f2': NULL, 'f3': NULL}, 'v3': -500}, 'e': NULL}	24

# Only supply b.v2.f2, which has no default; f1 and f3 retain their defaults

# col.b.in: {'v2': {'f2': 'world'}}
# col.b.default: {}
# col.b.v2.f1.default: alpha
# col.b.v2.f2.default: -
# col.b.v2.f3.default: gamma
# col.b.v2.result: {'f1': alpha, 'f2': world, 'f3': gamma}
statement ok
insert into my_datalake.default.nested_nested_tbl BY NAME FROM
	VALUES (
		{
			'b': {
				'v2': {
					'f2': 'world'
				}
			}
		},
		36
	) t(col, col2)

query II
select * from my_datalake.default.nested_nested_tbl order by all;
----
{'a': test, 'b': {'v1': 1000, 'v2': {'f1': alpha, 'f2': world, 'f3': gamma}, 'v3': -500}, 'e': NULL}	36
{'a': test, 'b': {'v1': 1000, 'v2': {'f1': alpha, 'f2': NULL, 'f3': gamma}, 'v3': -500}, 'e': NULL}	12
{'a': test, 'b': {'v1': 1000, 'v2': {'f1': alpha, 'f2': NULL, 'f3': NULL}, 'v3': -500}, 'e': NULL}	24

# Supply all three inner fields, fully overriding all defaults in v2

# col.b.in: {'v2': {'f1': 'foo', 'f2': 'bar', 'f3': 'baz'}}
# col.b.default: {}
# col.b.v2.f1.default: alpha
# col.b.v2.f2.default: -
# col.b.v2.f3.default: gamma
# col.b.v2.result: {'f1': foo, 'f2': bar, 'f3': baz}
statement ok
insert into my_datalake.default.nested_nested_tbl BY NAME FROM
	VALUES (
		{
			'b': {
				'v2': {
					'f1': 'foo',
					'f2': 'bar',
					'f3': 'baz'
				}
			}
		},
		48
	) t(col, col2)

query II
select * from my_datalake.default.nested_nested_tbl order by all;
----
{'a': test, 'b': {'v1': 1000, 'v2': {'f1': alpha, 'f2': world, 'f3': gamma}, 'v3': -500}, 'e': NULL}	36
{'a': test, 'b': {'v1': 1000, 'v2': {'f1': alpha, 'f2': NULL, 'f3': gamma}, 'v3': -500}, 'e': NULL}	12
{'a': test, 'b': {'v1': 1000, 'v2': {'f1': alpha, 'f2': NULL, 'f3': NULL}, 'v3': -500}, 'e': NULL}	24
{'a': test, 'b': {'v1': 1000, 'v2': {'f1': foo, 'f2': bar, 'f3': baz}, 'v3': -500}, 'e': NULL}	48
