# Struct nested within another struct

statement ok
drop table if exists my_datalake.default.nested_tbl;

# NOTE: Since no engine/catalog supports the {} default for STRUCT, we write NULL (omit the initial-default) for STRUCT instead
# This changes the behavior matrix, and will need to be updated when support for {} is added
statement ok
create table my_datalake.default.nested_tbl(
	col STRUCT(
		a VARCHAR,
		b STRUCT(
			c BIGINT,
			d BIGINT
		),
		e BOOLEAN
	) DEFAULT {
		'a': 'test',
		'b': {
			'c': 1000,
			'd': -500
		},
		'e': NULL
	},
	col2 INTEGER
) WITH (
	'format-version'= 3
);

# input: - (missing)
# col default: NULL
# result: NULL
statement ok
insert into my_datalake.default.nested_tbl (col2) VALUES (12)

query II
select * from my_datalake.default.nested_tbl order by all;
----
{'a': test, 'b': {'c': 1000, 'd': -500}, 'e': NULL}	12

# input: {'b': 42}
# col default: NULL
# col.a default: 'test'
# result: {'a': test, 'b': 42}
statement ok
insert into my_datalake.default.nested_tbl BY NAME FROM
	VALUES ({'b': 42}, 24) t(col, col2)

query II
select * from my_datalake.default.nested_tbl order by all;
----
{'a': test, 'b': 42}	24
{'a': test, 'b': NULL}	12
