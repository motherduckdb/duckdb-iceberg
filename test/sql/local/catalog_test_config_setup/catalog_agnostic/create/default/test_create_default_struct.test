# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/create/default/test_create_default_struct.test
# description: Regression for non-flat vector in ManifestListReader when manifest_list has many entries
# group: [default]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
drop table if exists my_datalake.default.tbl;

# NOTE: Since no engine/catalog supports the {} default for STRUCT, we write NULL (omit the initial-default) for STRUCT instead
# This changes the behavior matrix, and will need to be updated when support for {} is added
statement ok
create table my_datalake.default.tbl(
	col STRUCT(
		a VARCHAR,
		b INTEGER,
		c BLOB
	) DEFAULT {'a': 'test', 'b': NULL},
	col2 BLOB
) WITH (
	'format-version'= 3
);

# in: - (col not provided)
# col.default: {}
# col.a.default: 'test'
# col.b.default: NULL
# col.c.default: -
# result: {'a': test, 'b': NULL, 'c': NULL}
statement ok
insert into my_datalake.default.tbl (col2) VALUES ('\xaa\xff\xaa'), ('\xAA\xFF\xAA\xAA\xFF\xAA')

query II
select * from my_datalake.default.tbl order by all;
----
{'a': test, 'b': NULL, 'c': NULL}	\xAA\xFF\xAA
{'a': test, 'b': NULL, 'c': NULL}	\xAA\xFF\xAA\xAA\xFF\xAA

# in: {'b': 42}
# col.default: {}
# col.a.default: 'test'
# col.b.default: NULL
# col.c.default: -
# result: {'a': test, 'b': 42, 'c': NULL}
statement ok
insert into my_datalake.default.tbl 
	VALUES ({'b': 42}, NULL)

query II
select * from my_datalake.default.tbl order by all;
----
{'a': test, 'b': 42, 'c': NULL}	NULL
{'a': test, 'b': NULL, 'c': NULL}	\xAA\xFF\xAA
{'a': test, 'b': NULL, 'c': NULL}	\xAA\xFF\xAA\xAA\xFF\xAA

# in: {'c': '\xaa\xff\xaa'}
# col.default: {}
# col.a.default: 'test'
# col.b.default: NULL
# col.c.default: -
# result: {'a': test, 'b': NULL, 'c': '\xaa\xff\xaa'}
statement ok
insert into my_datalake.default.tbl 
	VALUES ({'c': '\xaa\xff\xaa'}, NULL)

query II
select * from my_datalake.default.tbl order by all;
----
{'a': test, 'b': 42, 'c': NULL}	NULL
{'a': test, 'b': NULL, 'c': \xAA\xFF\xAA}	NULL
{'a': test, 'b': NULL, 'c': NULL}	\xAA\xFF\xAA
{'a': test, 'b': NULL, 'c': NULL}	\xAA\xFF\xAA\xAA\xFF\xAA

# Struct nested within another struct

statement ok
drop table if exists my_datalake.default.nested_tbl;

# NOTE: Since no engine/catalog supports the {} default for STRUCT, we write NULL (omit the initial-default) for STRUCT instead
# This changes the behavior matrix, and will need to be updated when support for {} is added
statement ok
create table my_datalake.default.nested_tbl(
	col STRUCT(
		a VARCHAR,
		b STRUCT(
			v1 BIGINT,
			v2 BIGINT,
			v3 BIGINT
		),
		e BOOLEAN
	) DEFAULT {
		'a': 'test',
		'b': {
			'v1': 1000,
			'v3': -500
		},
		'e': NULL
	},
	col2 INTEGER
) WITH (
	'format-version'= 3
);

# col.b.in: -
# col.b.default: {}
# col.b.v1.default: 1000
# col.b.v2.default: -
# col.b.v3.default: -500
# col.b.result: {'v1': 1000, 'v2': NULL, 'v3': -500}
statement ok
insert into my_datalake.default.nested_tbl (col2) VALUES (12)

query II
select * from my_datalake.default.nested_tbl order by all;
----
{'a': test, 'b': {'v1': 1000, 'v2': NULL, 'v3': -500}, 'e': NULL}	12

# Only supply b.v3, which has a default of -500

# col.b.in: {'v3': NULL}
# col.b.default: {}
# col.b.v1.default: 1000
# col.b.v2.default: -
# col.b.v3.default: -500
# col.b.result: {'v1': 1000, 'v2': NULL, 'v3': NULL}
statement ok
insert into my_datalake.default.nested_tbl 
	VALUES (
		{
			'b': {
				'v3': NULL
			}
		},
		24
	)

query II
select * from my_datalake.default.nested_tbl order by all;
----
{'a': test, 'b': {'v1': 1000, 'v2': NULL, 'v3': -500}, 'e': NULL}	12
{'a': test, 'b': {'v1': 1000, 'v2': NULL, 'v3': NULL}, 'e': NULL}	24

# Only supply b.v2, which has no default

# col.b.in: {'v3': 42}
# col.b.default: {}
# col.b.v1.default: 1000
# col.b.v2.default: -
# col.b.v3.default: -500
# col.b.result: {'v1': 1000, 'v2': NULL, 'v3': 42}
statement ok
insert into my_datalake.default.nested_tbl 
	VALUES (
		{
			'b': {
				'v2': 250
			}
		},
		24
	)

query II
select * from my_datalake.default.nested_tbl order by all;
----
{'a': test, 'b': {'v1': 1000, 'v2': 250, 'v3': -500}, 'e': NULL}	24
{'a': test, 'b': {'v1': 1000, 'v2': NULL, 'v3': -500}, 'e': NULL}	12
{'a': test, 'b': {'v1': 1000, 'v2': NULL, 'v3': NULL}, 'e': NULL}	24

