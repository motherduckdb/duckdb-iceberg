# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/other_engines/partitions/truncate/test_append_truncate_int_for_insert.test
# description: DuckDB appends the exact same values Spark inserted into a truncate(10, value)
# group: [truncate]

#              table. Filtering on each value must return exactly 2 rows — one from Spark,
#              one from DuckDB — proving both ended up in the same partition.

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

# ---- Verify Spark's initial state ----
# Spark inserted values 1,11,21,...,91 (partition keys 0,10,...,90) plus NULL.

query I
select count(*) from my_datalake.default.truncate_partitioned_int_for_insert;
----
11

# ---- DuckDB inserts the same values Spark inserted, with new ids ----

statement ok
INSERT INTO my_datalake.default.truncate_partitioned_int_for_insert VALUES
    (101, 1),
    (102, 11),
    (103, 21),
    (104, 31),
    (105, 41),
    (106, 51),
    (107, 61),
    (108, 71),
    (109, 81),
    (110, 91),
    (111, NULL);

query I
select count(*) from my_datalake.default.truncate_partitioned_int_for_insert;
----
22

# ---- For each inserted value, exactly 2 rows should be visible ----
# One row from Spark (id 1-11) and one from DuckDB (id 101-111).
# If DuckDB wrote to the wrong partition the row would still be readable,
# but a follow-up pushdown test would catch incorrect manifest partition values.

query I
select count(*) from my_datalake.default.truncate_partitioned_int_for_insert where value = 1;
----
2

query I
select count(*) from my_datalake.default.truncate_partitioned_int_for_insert where value = 11;
----
2

query I
select count(*) from my_datalake.default.truncate_partitioned_int_for_insert where value = 21;
----
2

query I
select count(*) from my_datalake.default.truncate_partitioned_int_for_insert where value = 31;
----
2

query I
select count(*) from my_datalake.default.truncate_partitioned_int_for_insert where value = 41;
----
2

query I
select count(*) from my_datalake.default.truncate_partitioned_int_for_insert where value = 51;
----
2

query I
select count(*) from my_datalake.default.truncate_partitioned_int_for_insert where value = 61;
----
2

query I
select count(*) from my_datalake.default.truncate_partitioned_int_for_insert where value = 71;
----
2

query I
select count(*) from my_datalake.default.truncate_partitioned_int_for_insert where value = 81;
----
2

query I
select count(*) from my_datalake.default.truncate_partitioned_int_for_insert where value = 91;
----
2

query I
select count(*) from my_datalake.default.truncate_partitioned_int_for_insert where value is null;
----
2
