# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/other_engines/partitions/truncate/test_append_truncate_binary_for_insert.test
# description: DuckDB appends the exact same values Spark inserted into a truncate(2, value)
# group: [truncate]

#              BINARY table. Filtering on each value must return exactly 2 rows — one from Spark,
#              one from DuckDB — proving both ended up in the same partition.

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

# ---- Verify Spark's initial state ----
# Spark inserted 10 binary values with distinct first 2 bytes plus NULL.

query I
select count(*) from my_datalake.default.truncate_partitioned_binary_for_insert;
----
11

# ---- DuckDB inserts the same values Spark inserted, with new ids ----

statement ok
INSERT INTO my_datalake.default.truncate_partitioned_binary_for_insert VALUES
    (101, '\x01\x02\x03'::BLOB),
    (102, '\x02\x03\x04'::BLOB),
    (103, '\x03\x04\x05'::BLOB),
    (104, '\x04\x05\x06'::BLOB),
    (105, '\x05\x06\x07'::BLOB),
    (106, '\x06\x07\x08'::BLOB),
    (107, '\x07\x08\x09'::BLOB),
    (108, '\x08\x09\x0A'::BLOB),
    (109, '\x09\x00\x0A'::BLOB),
    (110, '\x0A\x00\x0B'::BLOB),
    (111, NULL);

query I
select count(*) from my_datalake.default.truncate_partitioned_binary_for_insert;
----
22

# ---- For each inserted value, exactly 2 rows should be visible ----
# One row from Spark (id 1-11) and one from DuckDB (id 101-111).

query I
select count(*) from my_datalake.default.truncate_partitioned_binary_for_insert where value = '\x01\x02\x03'::BLOB;
----
2

query I
select count(*) from my_datalake.default.truncate_partitioned_binary_for_insert where value = '\x02\x03\x04'::BLOB;
----
2

query I
select count(*) from my_datalake.default.truncate_partitioned_binary_for_insert where value = '\x03\x04\x05'::BLOB;
----
2

query I
select count(*) from my_datalake.default.truncate_partitioned_binary_for_insert where value = '\x04\x05\x06'::BLOB;
----
2

query I
select count(*) from my_datalake.default.truncate_partitioned_binary_for_insert where value = '\x05\x06\x07'::BLOB;
----
2

query I
select count(*) from my_datalake.default.truncate_partitioned_binary_for_insert where value = '\x06\x07\x08'::BLOB;
----
2

query I
select count(*) from my_datalake.default.truncate_partitioned_binary_for_insert where value = '\x07\x08\x09'::BLOB;
----
2

query I
select count(*) from my_datalake.default.truncate_partitioned_binary_for_insert where value = '\x08\x09\x0A'::BLOB;
----
2

query I
select count(*) from my_datalake.default.truncate_partitioned_binary_for_insert where value = '\x09\x00\x0A'::BLOB;
----
2

query I
select count(*) from my_datalake.default.truncate_partitioned_binary_for_insert where value = '\x0A\x00\x0B'::BLOB;
----
2

query I
select count(*) from my_datalake.default.truncate_partitioned_binary_for_insert where value is null;
----
2
