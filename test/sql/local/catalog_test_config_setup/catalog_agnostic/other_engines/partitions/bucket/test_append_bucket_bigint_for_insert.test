# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/other_engines/partitions/bucket/test_append_bucket_bigint_for_insert.test
# description: DuckDB appends the exact same values Spark inserted into a bucket(4, value)
# group: [bucket]

#              BIGINT table. Filtering on each value must return exactly 2 rows — one from Spark,
#              one from DuckDB — proving both ended up in the same partition.

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

# ---- Verify Spark's initial state ----
# Spark inserted values 1-10 (BIGINT, spread across 4 buckets) plus NULL.

query I
select count(*) from my_datalake.default.bucket_partitioned_bigint_for_insert;
----
11

statement ok
set variable manifest_list_path = (select manifest_list from iceberg_snapshots(my_datalake.default.bucket_partitioned_bigint_for_insert) order by sequence_number desc limit 1);

statement ok
set variable manifest_file_path = (select manifest_path from read_avro(getvariable('manifest_list_path')) order by sequence_number desc limit 1);

# ---- DuckDB inserts the same values Spark inserted, with new ids ----

statement ok
INSERT INTO my_datalake.default.bucket_partitioned_bigint_for_insert VALUES
    (101, 1::BIGINT),
    (102, 2::BIGINT),
    (103, 3::BIGINT),
    (104, 4::BIGINT),
    (105, 5::BIGINT),
    (106, 6::BIGINT),
    (107, 7::BIGINT),
    (108, 8::BIGINT),
    (109, 9::BIGINT),
    (110, 10::BIGINT),
    (111, NULL);

query I
select count(*) from my_datalake.default.bucket_partitioned_bigint_for_insert;
----
22

# ---- For each inserted value, exactly 2 rows should be visible ----
# One row from Spark (id 1-11) and one from DuckDB (id 101-111).

query I
select count(*) from my_datalake.default.bucket_partitioned_bigint_for_insert where value = 1;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_bigint_for_insert where value = 2;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_bigint_for_insert where value = 3;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_bigint_for_insert where value = 4;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_bigint_for_insert where value = 5;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_bigint_for_insert where value = 6;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_bigint_for_insert where value = 7;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_bigint_for_insert where value = 8;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_bigint_for_insert where value = 9;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_bigint_for_insert where value = 10;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_bigint_for_insert where value is null;
----
2
