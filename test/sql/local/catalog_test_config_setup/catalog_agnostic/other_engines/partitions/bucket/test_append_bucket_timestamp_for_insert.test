# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/other_engines/partitions/bucket/test_append_bucket_timestamp_for_insert.test
# description: DuckDB appends the exact same values Spark inserted into a bucket(4, value)
# group: [bucket]

#              TIMESTAMP table. Filtering on each value must return exactly 2 rows — one from Spark,
#              one from DuckDB — proving both ended up in the same partition.

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

# ---- Verify Spark's initial state ----
# Spark inserted 10 timestamps (2023-01-01 through 2023-10-01, spread across 4 buckets) plus NULL.

query I
select count(*) from my_datalake.default.bucket_partitioned_timestamp_for_insert;
----
11

statement ok
set variable manifest_list_path = (select manifest_list from iceberg_snapshots(my_datalake.default.bucket_partitioned_timestamp_for_insert) order by sequence_number desc limit 1);

statement ok
set variable manifest_file_path = (select manifest_path from read_avro(getvariable('manifest_list_path')) order by sequence_number desc limit 1);

# ---- DuckDB inserts the same values Spark inserted, with new ids ----

statement ok
INSERT INTO my_datalake.default.bucket_partitioned_timestamp_for_insert VALUES
    (101, '2023-01-01 00:00:00'::TIMESTAMP),
    (102, '2023-02-01 00:00:00'::TIMESTAMP),
    (103, '2023-03-01 00:00:00'::TIMESTAMP),
    (104, '2023-04-01 00:00:00'::TIMESTAMP),
    (105, '2023-05-01 00:00:00'::TIMESTAMP),
    (106, '2023-06-01 00:00:00'::TIMESTAMP),
    (107, '2023-07-01 00:00:00'::TIMESTAMP),
    (108, '2023-08-01 00:00:00'::TIMESTAMP),
    (109, '2023-09-01 00:00:00'::TIMESTAMP),
    (110, '2023-10-01 00:00:00'::TIMESTAMP),
    (111, NULL);

query I
select count(*) from my_datalake.default.bucket_partitioned_timestamp_for_insert;
----
22

# ---- For each inserted value, exactly 2 rows should be visible ----
# One row from Spark (id 1-11) and one from DuckDB (id 101-111).

query I
select count(*) from my_datalake.default.bucket_partitioned_timestamp_for_insert where value = '2023-01-01 00:00:00'::TIMESTAMP;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_timestamp_for_insert where value = '2023-02-01 00:00:00'::TIMESTAMP;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_timestamp_for_insert where value = '2023-03-01 00:00:00'::TIMESTAMP;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_timestamp_for_insert where value = '2023-04-01 00:00:00'::TIMESTAMP;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_timestamp_for_insert where value = '2023-05-01 00:00:00'::TIMESTAMP;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_timestamp_for_insert where value = '2023-06-01 00:00:00'::TIMESTAMP;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_timestamp_for_insert where value = '2023-07-01 00:00:00'::TIMESTAMP;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_timestamp_for_insert where value = '2023-08-01 00:00:00'::TIMESTAMP;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_timestamp_for_insert where value = '2023-09-01 00:00:00'::TIMESTAMP;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_timestamp_for_insert where value = '2023-10-01 00:00:00'::TIMESTAMP;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_timestamp_for_insert where value is null;
----
2
