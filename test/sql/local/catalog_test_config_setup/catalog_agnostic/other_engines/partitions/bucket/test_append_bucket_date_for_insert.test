# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/other_engines/partitions/bucket/test_append_bucket_date_for_insert.test
# description: DuckDB appends the exact same values Spark inserted into a bucket(4, value)
# group: [bucket]

#              DATE table. Filtering on each value must return exactly 2 rows — one from Spark,
#              one from DuckDB — proving both ended up in the same partition.

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

# ---- Verify Spark's initial state ----
# Spark inserted 10 dates (2020-01-01 through 2020-10-01, spread across 4 buckets) plus NULL.

query I
select count(*) from my_datalake.default.bucket_partitioned_date_for_insert;
----
11

statement ok
set variable manifest_list_path = (select manifest_list from iceberg_snapshots(my_datalake.default.bucket_partitioned_date_for_insert) order by sequence_number desc limit 1);

statement ok
set variable manifest_file_path = (select manifest_path from read_avro(getvariable('manifest_list_path')) order by sequence_number desc limit 1);

# ---- DuckDB inserts the same values Spark inserted, with new ids ----

statement ok
INSERT INTO my_datalake.default.bucket_partitioned_date_for_insert VALUES
    (101, '2020-01-01'::DATE),
    (102, '2020-02-01'::DATE),
    (103, '2020-03-01'::DATE),
    (104, '2020-04-01'::DATE),
    (105, '2020-05-01'::DATE),
    (106, '2020-06-01'::DATE),
    (107, '2020-07-01'::DATE),
    (108, '2020-08-01'::DATE),
    (109, '2020-09-01'::DATE),
    (110, '2020-10-01'::DATE),
    (111, NULL);

query I
select count(*) from my_datalake.default.bucket_partitioned_date_for_insert;
----
22

# ---- For each inserted value, exactly 2 rows should be visible ----
# One row from Spark (id 1-11) and one from DuckDB (id 101-111).

query I
select count(*) from my_datalake.default.bucket_partitioned_date_for_insert where value = '2020-01-01'::DATE;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_date_for_insert where value = '2020-02-01'::DATE;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_date_for_insert where value = '2020-03-01'::DATE;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_date_for_insert where value = '2020-04-01'::DATE;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_date_for_insert where value = '2020-05-01'::DATE;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_date_for_insert where value = '2020-06-01'::DATE;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_date_for_insert where value = '2020-07-01'::DATE;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_date_for_insert where value = '2020-08-01'::DATE;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_date_for_insert where value = '2020-09-01'::DATE;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_date_for_insert where value = '2020-10-01'::DATE;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_date_for_insert where value is null;
----
2
