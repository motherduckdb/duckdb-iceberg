# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/other_engines/partitions/bucket/test_append_bucket_int_for_insert.test
# description: DuckDB appends the exact same values Spark inserted into a bucket(4, value)
# group: [bucket]

#              INTEGER table. Filtering on each value must return exactly 2 rows — one from Spark,
#              one from DuckDB — proving both ended up in the same partition.

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

# ---- Verify Spark's initial state ----
# Spark inserted values 1-10 (spread across 4 buckets) plus NULL.

query I
select count(*) from my_datalake.default.bucket_partitioned_int_for_insert;
----
11

# ---- DuckDB inserts the same values Spark inserted, with new ids ----

statement ok
INSERT INTO my_datalake.default.bucket_partitioned_int_for_insert VALUES
    (101, 1),
    (102, 2),
    (103, 3),
    (104, 4),
    (105, 5),
    (106, 6),
    (107, 7),
    (108, 8),
    (109, 9),
    (110, 10),
    (111, NULL);

query I
select count(*) from my_datalake.default.bucket_partitioned_int_for_insert;
----
22

# ---- For each inserted value, exactly 2 rows should be visible ----
# One row from Spark (id 1-11) and one from DuckDB (id 101-111).
# If DuckDB computed a different bucket the row would still be readable,
# but it would be written to the wrong partition directory and manifest entry.

query I
select count(*) from my_datalake.default.bucket_partitioned_int_for_insert where value = 1;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_int_for_insert where value = 2;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_int_for_insert where value = 3;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_int_for_insert where value = 4;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_int_for_insert where value = 5;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_int_for_insert where value = 6;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_int_for_insert where value = 7;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_int_for_insert where value = 8;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_int_for_insert where value = 9;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_int_for_insert where value = 10;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_int_for_insert where value is null;
----
2
