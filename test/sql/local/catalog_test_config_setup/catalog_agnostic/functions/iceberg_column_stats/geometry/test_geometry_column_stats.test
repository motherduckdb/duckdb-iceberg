# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/functions/iceberg_column_stats/geometry/test_geometry_column_stats.test
# group: [geometry]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

require json

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
set enable_logging=true

statement ok
set logging_level='debug'

# GEOMETRY columns have no scalar min/max. iceberg_column_stats reports the per-axis
# bounding box as a JSON object in the lower_bound / upper_bound columns:
# {"bbox_x":..,"bbox_y":..,"bbox_z":..,"bbox_m":..}. Absent Z/M axes are JSON null.
# Callers wanting a single axis can cast the string to JSON, e.g. (lower_bound::JSON ->> '$.bbox_x').

# --- XY ------------------------------------------------------------------

statement ok
drop table if exists my_datalake.default.geom_stats_xy;

statement ok
create table my_datalake.default.geom_stats_xy (g GEOMETRY) with ('format-version'='3');

statement ok
insert into my_datalake.default.geom_stats_xy VALUES
    ('POINT(1 2)'::GEOMETRY),
    ('POINT(5 7)'::GEOMETRY),
    ('LINESTRING(-3 -4, 10 10)'::GEOMETRY);

query III
select column_name, lower_bound, upper_bound
from iceberg_column_stats(my_datalake.default.geom_stats_xy);
----
g	{"bbox_x":-3.0,"bbox_y":-4.0,"bbox_z":null,"bbox_m":null}	{"bbox_x":10.0,"bbox_y":10.0,"bbox_z":null,"bbox_m":null}

# --- XYZ -----------------------------------------------------------------

statement ok
drop table if exists my_datalake.default.geom_stats_xyz;

statement ok
create table my_datalake.default.geom_stats_xyz (g GEOMETRY) with ('format-version'='3');

statement ok
insert into my_datalake.default.geom_stats_xyz VALUES
    ('POINT Z (1 2 3)'::GEOMETRY),
    ('POINT Z (5 7 9)'::GEOMETRY),
    ('LINESTRING Z (5 5 5, 10 10 10)'::GEOMETRY);

query III
select column_name, lower_bound, upper_bound
from iceberg_column_stats(my_datalake.default.geom_stats_xyz);
----
g	{"bbox_x":1.0,"bbox_y":2.0,"bbox_z":3.0,"bbox_m":null}	{"bbox_x":10.0,"bbox_y":10.0,"bbox_z":10.0,"bbox_m":null}

# --- XYM -----------------------------------------------------------------
# The writer pads the Z slot with ±infinity for XYM, so bbox_z is reported as JSON null
# (HasZ() == false) while bbox_m carries the M extent.

statement ok
drop table if exists my_datalake.default.geom_stats_xym;

statement ok
create table my_datalake.default.geom_stats_xym (g GEOMETRY) with ('format-version'='3');

statement ok
insert into my_datalake.default.geom_stats_xym VALUES
    ('POINT M (1 2 3)'::GEOMETRY),
    ('POINT M (5 7 9)'::GEOMETRY);

query III
select column_name, lower_bound, upper_bound
from iceberg_column_stats(my_datalake.default.geom_stats_xym);
----
g	{"bbox_x":1.0,"bbox_y":2.0,"bbox_z":null,"bbox_m":3.0}	{"bbox_x":5.0,"bbox_y":7.0,"bbox_z":null,"bbox_m":9.0}

# --- XYZM ----------------------------------------------------------------

statement ok
drop table if exists my_datalake.default.geom_stats_xyzm;

statement ok
create table my_datalake.default.geom_stats_xyzm (g GEOMETRY) with ('format-version'='3');

statement ok
insert into my_datalake.default.geom_stats_xyzm VALUES
    ('POINT ZM (1 2 3 4)'::GEOMETRY),
    ('POINT ZM (5 7 9 11)'::GEOMETRY);

query III
select column_name, lower_bound, upper_bound
from iceberg_column_stats(my_datalake.default.geom_stats_xyzm);
----
g	{"bbox_x":1.0,"bbox_y":2.0,"bbox_z":3.0,"bbox_m":4.0}	{"bbox_x":5.0,"bbox_y":7.0,"bbox_z":9.0,"bbox_m":11.0}

# The bounds are valid JSON, so individual axes are queryable by casting to JSON.
query III
select ((lower_bound::JSON::VARIANT).bbox_x)::DOUBLE,
       ((upper_bound::JSON::VARIANT).bbox_z)::DOUBLE,
       ((lower_bound::JSON::VARIANT).bbox_m)::DOUBLE
from iceberg_column_stats(my_datalake.default.geom_stats_xyzm);
----
1.0	9.0	4.0

# --- All-NULL geometry ---------------------------------------------------
# No bbox_* keys are written, so there is no bounding box to report and the
# scalar bounds stay NULL.

statement ok
drop table if exists my_datalake.default.geom_stats_null;

statement ok
create table my_datalake.default.geom_stats_null (g GEOMETRY) with ('format-version'='3');

statement ok
insert into my_datalake.default.geom_stats_null VALUES (NULL), (NULL), (NULL);

query III
select column_name, lower_bound, upper_bound
from iceberg_column_stats(my_datalake.default.geom_stats_null);
----
g	NULL	NULL

# --- Mixed table: non-geometry columns keep scalar bounds ----------------

statement ok
drop table if exists my_datalake.default.geom_stats_mixed;

statement ok
create table my_datalake.default.geom_stats_mixed (id INTEGER, g GEOMETRY) with ('format-version'='3');

statement ok
insert into my_datalake.default.geom_stats_mixed VALUES
    (1, 'POINT(1 2)'::GEOMETRY),
    (2, 'POINT(5 7)'::GEOMETRY);

# The geometry column reports its bounding box as JSON; the scalar column reports
# scalar bounds as before.
query III
select column_name, lower_bound, upper_bound
from iceberg_column_stats(my_datalake.default.geom_stats_mixed) order by column_name;
----
g	{"bbox_x":1.0,"bbox_y":2.0,"bbox_z":null,"bbox_m":null}	{"bbox_x":5.0,"bbox_y":7.0,"bbox_z":null,"bbox_m":null}
id	1	2
