# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/functions/test_iceberg_bucket.test
# description: Test iceberg_bucket scalar function against Iceberg spec hash vectors
# group: [functions]

# Spec: https://iceberg.apache.org/spec/#appendix-b-32-bit-hash-requirements

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

# ---- NULL handling ----
# Iceberg spec: all transforms return null for null input

query I
SELECT iceberg_bucket(16, NULL);
----
NULL

query I
SELECT iceberg_bucket(16, NULL);
----
NULL

query I
SELECT iceberg_bucket(16, NULL);
----
NULL

query I
SELECT iceberg_bucket(16, NULL);
----
NULL

# ---- Return type is always INTEGER ----

query I
SELECT typeof(iceberg_bucket(16, 42::INTEGER));
----
INTEGER

query I
SELECT typeof(iceberg_bucket(16, 42::BIGINT));
----
INTEGER

query I
SELECT typeof(iceberg_bucket(16, 'hello'));
----
INTEGER

query I
SELECT typeof(iceberg_bucket(16, '2023-01-01'::DATE));
----
INTEGER

query I
SELECT typeof(iceberg_bucket(16, '2023-01-01'::TIMESTAMP));
----
INTEGER

query I
SELECT typeof(iceberg_bucket(16, '2023-01-01'::TIMESTAMPTZ));
----
INTEGER

query I
SELECT typeof(iceberg_bucket(16, '2023-01-01 00:00:00.123456789'::TIMESTAMP_NS));
----
INTEGER

query I
SELECT typeof(iceberg_bucket(16, '2023-01-01 00:00:00.123456789+00'::TIMESTAMPTZ_NS));
----
INTEGER

query I
SELECT typeof(iceberg_bucket(16, '\x01\x02'::BLOB));
----
INTEGER

# ---- Spec test vectors ----
# hash(0L) = 1669671676  =>  (& 0x7FFFFFFF) % 16 = 12
query I
SELECT iceberg_bucket(16, 0);
----
12

# hash(0L) = 1669671676  =>  (& 0x7FFFFFFF) % 100 = 76
query I
SELECT iceberg_bucket(100, 0);
----
76

# INTEGER is sign-extended to BIGINT before hashing, so same result
query I
SELECT iceberg_bucket(100, 0);
----
76

# hash("iceberg") = 1210000089  =>  (& 0x7FFFFFFF) % 100 = 89
query I
SELECT iceberg_bucket(100, 'iceberg');
----
89

# hash(date("2017-11-16")) = hash(17486L) = -653330422
# (-653330422 & 0x7FFFFFFF) % 100 = 1494153226 % 100 = 26
query I
SELECT iceberg_bucket(100, '2017-11-16'::DATE);
----
26

# TIMESTAMP_NS follows the Iceberg timestamp_ns hash vectors, which floor nanos to micros before hashing.
query II
SELECT
	iceberg_bucket(16, '2017-11-16T22:31:08.000000001'::TIMESTAMP_NS),
	iceberg_bucket(16, '2017-11-16T22:31:08.000001001'::TIMESTAMP_NS);
----
7	6

# TIMESTAMPTZ_NS follows the same instant-based hash vectors.
query II
SELECT
	iceberg_bucket(16, '2017-11-16T14:31:08.000000001-08:00'::TIMESTAMPTZ_NS),
	iceberg_bucket(16, '2017-11-16T14:31:08.000001001-08:00'::TIMESTAMPTZ_NS);
----
7	6

# ---- Result is always in range [0, num_buckets) ----

query I
SELECT bool_and(iceberg_bucket(16, range) BETWEEN 0 AND 15)
FROM range(1000);
----
true

query I
SELECT bool_and(iceberg_bucket(4, range) BETWEEN 0 AND 3)
FROM range(1000);
----
true

query I
SELECT bool_and(iceberg_bucket(7, range) BETWEEN 0 AND 6)
FROM range(1000);
----
true

# ---- Deterministic: same input always yields same bucket ----

query I
SELECT count(DISTINCT iceberg_bucket(8, v)) = count(DISTINCT iceberg_bucket(8, v))
FROM (SELECT range AS v FROM range(100)) t;
----
true


statement error
SELECT iceberg_bucket(0, 1000);
----
<REGEX>:.*modulo must be a positive integer.*
