# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/logging/test_partition_read_logic_month.test
# group: [logging]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

require icu

statement ok
SET default_transaction_invalidation_policy='SYNTACTIC_ERRORS_DO_NOT_INVALIDATE';

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
set enable_logging=true

statement ok
SET TimeZone = 'UTC';

statement ok
call enable_logging('Iceberg');

query I
select ts from my_datalake.default.day_partitioned_table where ts = '2025-01-04 00:00:00'::TIMESTAMP;
----
2025-01-04 00:00:00+00
2025-01-04 00:00:00+00
2025-01-04 00:00:00+00

# FIXME: used to be 3, test is most likely broken now
query I
select count(*) from duckdb_logs() where type = 'Iceberg' and regexp_matches(message, '.*skipped.*data_file.*partition column.*with transform.*does not match filter.*ts=.*2025-01-04 00:00:00\+00.*');
----
0
