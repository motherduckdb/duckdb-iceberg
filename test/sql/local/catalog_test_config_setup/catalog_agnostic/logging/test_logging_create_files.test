# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/logging/test_logging_create_files.test
# group: [logging]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

require icu

statement ok
call enable_logging('Iceberg');

statement ok
SET default_transaction_invalidation_policy='SYNTACTIC_ERRORS_DO_NOT_INVALIDATE';

# To guarantee that files have more consistent characteristics both on
# CI and locally
statement ok
Set threads=1;

statement ok
drop table if exists my_datalake.default.test_logging_create_table;

statement ok
drop table if exists my_datalake.default.test_logging_create_table_large;

statement ok
create table my_datalake.default.test_logging_create_table WITH 
	('write.target-file-size-bytes'='1000000', 'write.parquet.compression-codec'='zstd') 
as select range a from range(10000);


query I
select count(*) from duckdb_logs() where type = 'Iceberg' and regexp_matches(message, 'Iceberg INSERT, wrote data_file.*record_count=.*');
----
1

statement ok
call truncate_duckdb_logs();

# write multiple files in one insert
statement ok
create table my_datalake.default.test_logging_create_table_large WITH 
	('write.target-file-size-bytes'='1000000', 'write.parquet.compression-codec'='zstd') 
as select range a from range(10000000);

query I
select count(*) from duckdb_logs() where type = 'Iceberg' and regexp_matches(message, 'Iceberg INSERT, wrote data_file.*record_count=.*');
----
11

statement ok
call truncate_duckdb_logs();

statement ok
drop table if exists my_datalake.default.test_logging_create_table_large;

# write multiple files in one insert
statement ok
create table my_datalake.default.test_logging_create_table_large WITH 
	('write.target-file-size-bytes'='1000000', 'write.parquet.compression-codec'='zstd') 
as select range a from range(100000000);

query I
select count(*) from duckdb_logs() where type = 'Iceberg' and regexp_matches(message, 'Iceberg INSERT, wrote data_file.*record_count=.*');
----
105
