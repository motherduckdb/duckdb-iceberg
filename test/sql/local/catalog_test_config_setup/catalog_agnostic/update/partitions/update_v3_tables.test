# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/update/partitions/update_v3_tables.test
# description: Test update on v3 partitioned iceberg tables
# group: [partitions]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
CALL enable_logging('HTTP');

statement ok
set logging_level='debug'

statement ok
DROP TABLE IF EXISTS my_datalake.default.test_update_partitioned_v3;

statement ok
CREATE TABLE my_datalake.default.test_update_partitioned_v3 (id INT, val VARCHAR) PARTITIONED BY (id) WITH ('format-version'=3);

statement ok
INSERT INTO my_datalake.default.test_update_partitioned_v3 VALUES (1, 'a'), (1, 'b'), (2, 'c'), (2, 'd'), (3, 'e');

query II
SELECT * FROM my_datalake.default.test_update_partitioned_v3 ORDER BY id, val;
----
1	a
1	b
2	c
2	d
3	e

query I
UPDATE my_datalake.default.test_update_partitioned_v3 SET val = 'updated' WHERE id = 1;
----
2

query II
SELECT * FROM my_datalake.default.test_update_partitioned_v3 ORDER BY id, val;
----
1	updated
1	updated
2	c
2	d
3	e

query I
UPDATE my_datalake.default.test_update_partitioned_v3 SET val = 'changed' WHERE id = 2 AND val = 'c';
----
1

query II
SELECT * FROM my_datalake.default.test_update_partitioned_v3 ORDER BY id, val;
----
1	updated
1	updated
2	changed
2	d
3	e

statement ok
DROP TABLE my_datalake.default.test_update_partitioned_v3;

