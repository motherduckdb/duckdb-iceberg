# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/update/partitions/update_truncate_tables_v3.test
# description: Test update on v3 iceberg tables partitioned by truncate transform (INT, BIGINT, VARCHAR)
# group: [partitions]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
CALL enable_logging('HTTP');

statement ok
set logging_level='debug'

# ---- TRUNCATE / INT — update non-partition column ----
# truncate(10, id): ids 0-9 → partition 0, ids 10-19 → partition 10, ids 20-29 → partition 20

statement ok
DROP TABLE IF EXISTS my_datalake.default.test_update_truncate_int_v3;

statement ok
CREATE TABLE my_datalake.default.test_update_truncate_int_v3 (id INT, val VARCHAR)
PARTITIONED BY (truncate(10, id)) WITH ('format-version'=3);

statement ok
INSERT INTO my_datalake.default.test_update_truncate_int_v3 VALUES
    (1, 'a'), (5, 'b'), (11, 'c'), (15, 'd'), (21, 'e');

query II
SELECT * FROM my_datalake.default.test_update_truncate_int_v3 ORDER BY id;
----
1	a
5	b
11	c
15	d
21	e

# Update val for all rows in truncate partition 0 (ids 1 and 5)
query I
UPDATE my_datalake.default.test_update_truncate_int_v3 SET val = 'updated' WHERE id < 10;
----
2

query II
SELECT * FROM my_datalake.default.test_update_truncate_int_v3 ORDER BY id;
----
1	updated
5	updated
11	c
15	d
21	e

# Update by non-partition predicate
query I
UPDATE my_datalake.default.test_update_truncate_int_v3 SET val = 'changed' WHERE val = 'd';
----
1

query II
SELECT * FROM my_datalake.default.test_update_truncate_int_v3 ORDER BY id;
----
1	updated
5	updated
11	c
15	changed
21	e

statement ok
DROP TABLE my_datalake.default.test_update_truncate_int_v3;

# ---- TRUNCATE / INT — update partition column (moves rows to new truncate partition) ----

statement ok
DROP TABLE IF EXISTS my_datalake.default.test_update_truncate_int_v3_partcol_v3;

statement ok
CREATE TABLE my_datalake.default.test_update_truncate_int_v3_partcol_v3 (id INT, val VARCHAR)
PARTITIONED BY (truncate(10, id)) WITH ('format-version'=3);

statement ok
INSERT INTO my_datalake.default.test_update_truncate_int_v3_partcol_v3 VALUES
    (1, 'a'), (5, 'b'), (11, 'c'), (21, 'd');

# Move id=1 and id=5 (partition 0) to id=50 and id=55 (partition 50)
query I
UPDATE my_datalake.default.test_update_truncate_int_v3_partcol_v3 SET id = id + 49 WHERE id < 10;
----
2

# Old truncate partition (0) returns no rows
query II
SELECT * FROM my_datalake.default.test_update_truncate_int_v3_partcol_v3 WHERE id < 10 ORDER BY id;
----

# New truncate partition (50) contains the updated rows
query II
SELECT * FROM my_datalake.default.test_update_truncate_int_v3_partcol_v3 WHERE id >= 50 AND id < 60 ORDER BY id;
----
50	a
54	b

# Full scan
query II
SELECT * FROM my_datalake.default.test_update_truncate_int_v3_partcol_v3 ORDER BY id;
----
11	c
21	d
50	a
54	b

statement ok
DROP TABLE my_datalake.default.test_update_truncate_int_v3_partcol_v3;

# ---- TRUNCATE / BIGINT — update non-partition column ----

statement ok
DROP TABLE IF EXISTS my_datalake.default.test_update_truncate_bigint_v3;

statement ok
CREATE TABLE my_datalake.default.test_update_truncate_bigint_v3 (id INT, val BIGINT, label VARCHAR)
PARTITIONED BY (truncate(10, val)) WITH ('format-version'=3);

statement ok
INSERT INTO my_datalake.default.test_update_truncate_bigint_v3 VALUES
    (1, 3::BIGINT,  'a'),
    (2, 8::BIGINT,  'b'),
    (3, 12::BIGINT, 'c'),
    (4, 17::BIGINT, 'd');

query III
SELECT * FROM my_datalake.default.test_update_truncate_bigint_v3 ORDER BY id;
----
1	3	a
2	8	b
3	12	c
4	17	d

# ids 1 and 2 share truncate partition 0 (values 3 and 8 both truncate to 0)
query I
UPDATE my_datalake.default.test_update_truncate_bigint_v3 SET label = 'updated' WHERE val < 10;
----
2

query III
SELECT * FROM my_datalake.default.test_update_truncate_bigint_v3 ORDER BY id;
----
1	3	updated
2	8	updated
3	12	c
4	17	d

statement ok
DROP TABLE my_datalake.default.test_update_truncate_bigint_v3;

# ---- TRUNCATE / VARCHAR — update non-partition column ----
# truncate(3, category): 'aardvark'/'aardwolf' → 'aar', 'bear'/'beaver' → 'bea', 'cat' → 'cat'

statement ok
DROP TABLE IF EXISTS my_datalake.default.test_update_truncate_varchar_v3;

statement ok
CREATE TABLE my_datalake.default.test_update_truncate_varchar_v3 (id INT, category VARCHAR, val VARCHAR)
PARTITIONED BY (truncate(3, category)) WITH ('format-version'=3);

statement ok
INSERT INTO my_datalake.default.test_update_truncate_varchar_v3 VALUES
    (1, 'aardvark', 'a'),
    (2, 'aardwolf', 'b'),
    (3, 'bear',     'c'),
    (4, 'beaver',   'd'),
    (5, 'cat',      'e');

query III
SELECT * FROM my_datalake.default.test_update_truncate_varchar_v3 ORDER BY id;
----
1	aardvark	a
2	aardwolf	b
3	bear	c
4	beaver	d
5	cat	e

# Update val for the 'aar' partition (both aardvark and aardwolf)
query I
UPDATE my_datalake.default.test_update_truncate_varchar_v3 SET val = 'updated' WHERE category LIKE 'aar%';
----
2

query III
SELECT * FROM my_datalake.default.test_update_truncate_varchar_v3 ORDER BY id;
----
1	aardvark	updated
2	aardwolf	updated
3	bear	c
4	beaver	d
5	cat	e

# Update by non-partition predicate
query I
UPDATE my_datalake.default.test_update_truncate_varchar_v3 SET val = 'changed' WHERE id = 4;
----
1

query III
SELECT * FROM my_datalake.default.test_update_truncate_varchar_v3 ORDER BY id;
----
1	aardvark	updated
2	aardwolf	updated
3	bear	c
4	beaver	changed
5	cat	e

statement ok
DROP TABLE my_datalake.default.test_update_truncate_varchar_v3;

# ---- TRUNCATE / VARCHAR — update partition column (moves rows to new truncate partition) ----

statement ok
DROP TABLE IF EXISTS my_datalake.default.test_update_truncate_varchar_v3_partcol_v3;

statement ok
CREATE TABLE my_datalake.default.test_update_truncate_varchar_v3_partcol_v3 (id INT, category VARCHAR, val VARCHAR)
PARTITIONED BY (truncate(3, category)) WITH ('format-version'=3);

statement ok
INSERT INTO my_datalake.default.test_update_truncate_varchar_v3_partcol_v3 VALUES
    (1, 'aardvark', 'a'),
    (2, 'aardwolf', 'b'),
    (3, 'bear',     'c');

# Move 'aar%' rows to 'zebra' — different truncate partition ('zeb')
query I
UPDATE my_datalake.default.test_update_truncate_varchar_v3_partcol_v3 SET category = 'zebra' WHERE category LIKE 'aar%';
----
2

# Old partition ('aar') returns no rows
query III
SELECT * FROM my_datalake.default.test_update_truncate_varchar_v3_partcol_v3 WHERE category LIKE 'aar%' ORDER BY id;
----

# New partition ('zeb') contains the updated rows
query III
SELECT * FROM my_datalake.default.test_update_truncate_varchar_v3_partcol_v3 WHERE category = 'zebra' ORDER BY id;
----
1	zebra	a
2	zebra	b

# Untouched partition is unchanged
query III
SELECT * FROM my_datalake.default.test_update_truncate_varchar_v3_partcol_v3 WHERE category = 'bear';
----
3	bear	c

# Full scan
query III
SELECT * FROM my_datalake.default.test_update_truncate_varchar_v3_partcol_v3 ORDER BY id;
----
1	zebra	a
2	zebra	b
3	bear	c

statement ok
DROP TABLE my_datalake.default.test_update_truncate_varchar_v3_partcol_v3;
