# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/update/partitions/update_temporal_transforms.test
# description: Test update on iceberg tables partitioned by year, month, day, and hour transforms
# group: [partitions]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
CALL enable_logging('HTTP');

statement ok
set logging_level='debug'

# ---- YEAR transform ----

statement ok
DROP TABLE IF EXISTS my_datalake.default.test_update_year;

statement ok
CREATE TABLE my_datalake.default.test_update_year (id INT, ts TIMESTAMP, val VARCHAR)
PARTITIONED BY (year(ts));

statement ok
INSERT INTO my_datalake.default.test_update_year VALUES
    (1, '2020-06-15 12:00:00'::TIMESTAMP, 'a'),
    (2, '2020-09-01 00:00:00'::TIMESTAMP, 'b'),
    (3, '2021-03-10 08:00:00'::TIMESTAMP, 'c'),
    (4, '2022-11-20 15:30:00'::TIMESTAMP, 'd');

query III
SELECT id, ts, val FROM my_datalake.default.test_update_year ORDER BY id;
----
1	2020-06-15 12:00:00	a
2	2020-09-01 00:00:00	b
3	2021-03-10 08:00:00	c
4	2022-11-20 15:30:00	d

query I
UPDATE my_datalake.default.test_update_year SET val = 'updated' WHERE ts < '2021-01-01'::TIMESTAMP;
----
2

query III
SELECT id, ts, val FROM my_datalake.default.test_update_year ORDER BY id;
----
1	2020-06-15 12:00:00	updated
2	2020-09-01 00:00:00	updated
3	2021-03-10 08:00:00	c
4	2022-11-20 15:30:00	d

statement ok
DROP TABLE my_datalake.default.test_update_year;

# ---- MONTH transform ----

statement ok
DROP TABLE IF EXISTS my_datalake.default.test_update_month;

statement ok
CREATE TABLE my_datalake.default.test_update_month (id INT, ts TIMESTAMP, val VARCHAR)
PARTITIONED BY (month(ts));

statement ok
INSERT INTO my_datalake.default.test_update_month VALUES
    (1, '2021-01-15 00:00:00'::TIMESTAMP, 'a'),
    (2, '2021-01-28 12:00:00'::TIMESTAMP, 'b'),
    (3, '2021-03-05 09:00:00'::TIMESTAMP, 'c'),
    (4, '2022-01-10 18:00:00'::TIMESTAMP, 'd');

query III
SELECT id, ts, val FROM my_datalake.default.test_update_month ORDER BY id;
----
1	2021-01-15 00:00:00	a
2	2021-01-28 12:00:00	b
3	2021-03-05 09:00:00	c
4	2022-01-10 18:00:00	d

query I
UPDATE my_datalake.default.test_update_month SET val = 'updated'
WHERE ts >= '2021-01-01'::TIMESTAMP AND ts < '2021-02-01'::TIMESTAMP;
----
2

query III
SELECT id, ts, val FROM my_datalake.default.test_update_month ORDER BY id;
----
1	2021-01-15 00:00:00	updated
2	2021-01-28 12:00:00	updated
3	2021-03-05 09:00:00	c
4	2022-01-10 18:00:00	d

statement ok
DROP TABLE my_datalake.default.test_update_month;

# ---- DAY transform ----

statement ok
DROP TABLE IF EXISTS my_datalake.default.test_update_day;

statement ok
CREATE TABLE my_datalake.default.test_update_day (id INT, dt DATE, val VARCHAR)
PARTITIONED BY (day(dt));

statement ok
INSERT INTO my_datalake.default.test_update_day VALUES
    (1, '2021-05-01'::DATE, 'a'),
    (2, '2021-05-01'::DATE, 'b'),
    (3, '2021-05-02'::DATE, 'c'),
    (4, '2021-05-03'::DATE, 'd');

query III
SELECT id, dt, val FROM my_datalake.default.test_update_day ORDER BY id;
----
1	2021-05-01	a
2	2021-05-01	b
3	2021-05-02	c
4	2021-05-03	d

query I
UPDATE my_datalake.default.test_update_day SET val = 'updated' WHERE dt = '2021-05-01'::DATE;
----
2

query III
SELECT id, dt, val FROM my_datalake.default.test_update_day ORDER BY id;
----
1	2021-05-01	updated
2	2021-05-01	updated
3	2021-05-02	c
4	2021-05-03	d

statement ok
DROP TABLE my_datalake.default.test_update_day;

# ---- HOUR transform ----

statement ok
DROP TABLE IF EXISTS my_datalake.default.test_update_hour;

statement ok
CREATE TABLE my_datalake.default.test_update_hour (id INT, ts TIMESTAMP, val VARCHAR)
PARTITIONED BY (hour(ts));

statement ok
INSERT INTO my_datalake.default.test_update_hour VALUES
    (1, '2021-05-01 10:00:00'::TIMESTAMP, 'a'),
    (2, '2021-05-01 10:30:00'::TIMESTAMP, 'b'),
    (3, '2021-05-01 11:00:00'::TIMESTAMP, 'c'),
    (4, '2021-05-01 12:00:00'::TIMESTAMP, 'd');

query III
SELECT id, ts, val FROM my_datalake.default.test_update_hour ORDER BY id;
----
1	2021-05-01 10:00:00	a
2	2021-05-01 10:30:00	b
3	2021-05-01 11:00:00	c
4	2021-05-01 12:00:00	d

query I
UPDATE my_datalake.default.test_update_hour SET val = 'updated'
WHERE ts >= '2021-05-01 10:00:00'::TIMESTAMP AND ts < '2021-05-01 11:00:00'::TIMESTAMP;
----
2

query III
SELECT id, ts, val FROM my_datalake.default.test_update_hour ORDER BY id;
----
1	2021-05-01 10:00:00	updated
2	2021-05-01 10:30:00	updated
3	2021-05-01 11:00:00	c
4	2021-05-01 12:00:00	d

statement ok
DROP TABLE my_datalake.default.test_update_hour;
