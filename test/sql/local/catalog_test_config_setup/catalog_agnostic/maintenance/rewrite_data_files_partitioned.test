# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/maintenance/rewrite_data_files_partitioned.test
# description: partition-local rewrite_data_files compaction check
# group: [maintenance]

require-env ICEBERG_SERVER_AVAILABLE

require-env SECRETS_CREATED_AND_CATALOG_ATTACHED

require avro

require parquet

require iceberg

require httpfs

set ignore_error_messages

statement ok
drop table if exists my_datalake.default.rewrite_partitioned;

statement ok
create table my_datalake.default.rewrite_partitioned (id INTEGER, category VARCHAR, payload VARCHAR)
partitioned by (category);

statement ok
insert into my_datalake.default.rewrite_partitioned values (1, 'a', 'a1'), (2, 'b', 'b1');

statement ok
insert into my_datalake.default.rewrite_partitioned values (3, 'a', 'a2'), (4, 'b', 'b2');

statement ok
insert into my_datalake.default.rewrite_partitioned values (5, 'a', 'a3'), (6, 'b', 'b3');

statement ok
insert into my_datalake.default.rewrite_partitioned values (7, 'a', 'a4'), (8, 'b', 'b4');

statement ok
insert into my_datalake.default.rewrite_partitioned values (9, 'a', 'a5'), (10, 'b', 'b5');

statement ok
insert into my_datalake.default.rewrite_partitioned values (11, 'a', 'a6'), (12, 'b', 'b6');

query I
select count(*) from my_datalake.default.rewrite_partitioned;
----
12

query II
select category, count(*) from my_datalake.default.rewrite_partitioned group by category order by category;
----
a	6
b	6

query I
select count(*)
from iceberg_metadata('my_datalake.default.rewrite_partitioned')
where content = 'DATA' and status <> 'DELETED';
----
12

query I
select count(*)
from iceberg_metadata('my_datalake.default.rewrite_partitioned')
where content = 'DATA' and status <> 'DELETED'
  and file_path like '%/category=%';
----
12

query III
call iceberg_rewrite_data_files('my_datalake.default.rewrite_partitioned');
----
12	2	<REGEX>:[1-9][0-9]*

query I
select count(*) from my_datalake.default.rewrite_partitioned;
----
12

query III
select id, category, payload from my_datalake.default.rewrite_partitioned order by id;
----
1	a	a1
2	b	b1
3	a	a2
4	b	b2
5	a	a3
6	b	b3
7	a	a4
8	b	b4
9	a	a5
10	b	b5
11	a	a6
12	b	b6

query I
select count(*)
from iceberg_metadata('my_datalake.default.rewrite_partitioned')
where content = 'DATA' and status <> 'DELETED';
----
2

query II
select category, count(*) from my_datalake.default.rewrite_partitioned group by category order by category;
----
a	6
b	6

query III
call iceberg_rewrite_data_files('my_datalake.default.rewrite_partitioned');
----
0	0	0

statement ok
drop table if exists my_datalake.default.rewrite_partitioned;
