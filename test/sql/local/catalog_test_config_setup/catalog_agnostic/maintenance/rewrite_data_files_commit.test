# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/maintenance/rewrite_data_files_commit.test
# description: end-to-end REPLACE snapshot compaction check
# group: [maintenance]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

require json

set ignore_error_messages

statement ok
drop table if exists my_datalake.default.rewrite_commit_basic;

statement ok
create table my_datalake.default.rewrite_commit_basic (id INTEGER, payload VARCHAR);

statement ok
insert into my_datalake.default.rewrite_commit_basic values (1, 'a'), (2, 'b');

statement ok
insert into my_datalake.default.rewrite_commit_basic values (3, 'c'), (4, 'd');

statement ok
insert into my_datalake.default.rewrite_commit_basic values (5, 'e'), (6, 'f');

statement ok
insert into my_datalake.default.rewrite_commit_basic values (7, 'g'), (8, 'h');

statement ok
insert into my_datalake.default.rewrite_commit_basic values (9, 'i'), (10, 'j');

statement ok
insert into my_datalake.default.rewrite_commit_basic values (11, 'k'), (12, 'l');

query I
select count(*) from my_datalake.default.rewrite_commit_basic;
----
12

query II
explain analyze select * from my_datalake.default.rewrite_commit_basic;
----
analyzed_plan	<REGEX>:.*Total Files Read: 6.*

statement ok
set variable pre_rewrite_total_file_size = (
	select json_extract_string(snap, '$.summary."total-files-size"')::BIGINT
	from (
		select unnest(json_extract(metadata::JSON, '$.snapshots[*]')) as snap
		from iceberg_load_table_response(my_datalake.default.rewrite_commit_basic)
	)
	order by json_extract_string(snap, '$."sequence-number"')::BIGINT desc
	limit 1
);

query III
call iceberg_rewrite_data_files('my_datalake.default.rewrite_commit_basic');
----
6	1	<REGEX>:[1-9][0-9]*

query III
select
	json_extract_string(snap, '$.summary."added-files-size"')::BIGINT > 0,
	json_extract_string(snap, '$.summary."removed-files-size"')::BIGINT > 0,
	json_extract_string(snap, '$.summary."total-files-size"')::BIGINT =
		getvariable('pre_rewrite_total_file_size') +
		json_extract_string(snap, '$.summary."added-files-size"')::BIGINT -
		json_extract_string(snap, '$.summary."removed-files-size"')::BIGINT
from (
	select unnest(json_extract(metadata::JSON, '$.snapshots[*]')) as snap
	from iceberg_load_table_response(my_datalake.default.rewrite_commit_basic)
)
where json_extract_string(snap, '$.summary.operation') = 'replace'
order by json_extract_string(snap, '$."sequence-number"')::BIGINT desc
limit 1;
----
true	true	true

query I
select count(*) from my_datalake.default.rewrite_commit_basic;
----
12

query II
select id, payload from my_datalake.default.rewrite_commit_basic order by id;
----
1	a
2	b
3	c
4	d
5	e
6	f
7	g
8	h
9	i
10	j
11	k
12	l

query II
explain analyze select * from my_datalake.default.rewrite_commit_basic;
----
analyzed_plan	<REGEX>:.*Total Files Read: 1.*

# Re-running the action is a no-op: only one input file remains, which is below
# `min_input_files`. Zero rewritten files.
query III
call iceberg_rewrite_data_files('my_datalake.default.rewrite_commit_basic');
----
0	0	0

statement ok
drop table if exists my_datalake.default.rewrite_commit_basic;
