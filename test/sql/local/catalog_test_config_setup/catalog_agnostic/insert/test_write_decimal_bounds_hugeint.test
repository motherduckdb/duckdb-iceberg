# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/insert/test_write_decimal_bounds_hugeint.test
# group: [insert]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

require icu

require core_functions

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
set enable_logging=true

statement ok
set logging_level='debug'

statement ok
SET TimeZone = 'UTC';


statement ok
drop table if exists my_datalake.default.duckdb_written_upper_lower_hugeint_bounds;

statement ok
create table my_datalake.default.duckdb_written_upper_lower_hugeint_bounds (
    id      INTEGER,
    val38_0 HUGEINT
);

# like spark table exercises sign extension edge cases at every byte boundary:
#   0, 1, -1                          -> 1 byte blobs
#   127, 128, -128, -129              -> 1-2 byte boundary
#   32768, -32768, -32769             -> 2-3 byte boundary
#   65535, -65536                     -> 2-3 byte boundary
#   BIGINT max/min and +/-1           -> 8-9 byte boundary
#   DECIMAL(38,0) max/min             -> full 16 byte blobs
statement ok
insert into my_datalake.default.duckdb_written_upper_lower_hugeint_bounds values
(1,  0),
(2,  1),
(3,  -1),
(4,  127),
(5,  128),
(6,  -128),
(7,  -129),
(8,  32768),
(9,  -32768),
(10, -32769),
(11, 65535),
(12, -65536),
(13, 9223372036854775807),
(14, 9223372036854775808),
(15, -9223372036854775808),
(16, -9223372036854775809),
(17, '99999999999999999999999999999999999999'::HUGEINT),
(18, '-99999999999999999999999999999999999999'::HUGEINT),
(19, NULL);

statement ok
set variable manifest_path_duckdb = (select manifest_path from iceberg_metadata(my_datalake.default.duckdb_written_upper_lower_hugeint_bounds) order by manifest_sequence_number desc limit 1);

statement ok
set variable manifest_path_spark = (select manifest_path from iceberg_metadata(my_datalake.default.spark_written_upper_lower_hugeint_bounds) order by manifest_sequence_number desc limit 1);

# compare lower_bounds and upper_bounds blobs between Duckdb and Spark manifests
query II nosort duckdb_hugeint_bounds
from (select unnest(map_keys(lower_bounds)) lower_keys, unnest(map_values(lower_bounds)) lower_vals, unnest(map_keys(upper_bounds)) upper_keys, unnest(map_values(upper_bounds)) upper_vals from (select unnest(data_file) from read_avro(getvariable('manifest_path_duckdb')))) where lower_keys in (2) order by all;

query II nosort duckdb_hugeint_bounds
from (select unnest(map_keys(lower_bounds)) lower_keys, unnest(map_values(lower_bounds)) lower_vals, unnest(map_keys(upper_bounds)) upper_keys, unnest(map_values(upper_bounds)) upper_vals from (select unnest(data_file) from read_avro(getvariable('manifest_path_spark')))) where lower_keys in (2) order by all;

query II nosort duckdb_hugeint_null_counts
select unnest(map_keys(null_value_counts)), unnest(map_values(null_value_counts)) from (select unnest(data_file) from read_avro(getvariable('manifest_path_duckdb'))) order by all;

query II nosort duckdb_hugeint_null_counts
select unnest(map_keys(null_value_counts)), unnest(map_values(null_value_counts)) from (select unnest(data_file) from read_avro(getvariable('manifest_path_spark'))) order by all;
