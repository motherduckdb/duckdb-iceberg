# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/insert/test_insert_into_sorted_table_fails.test
# group: [insert]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
set threads=1;

statement ok
set variable table_sort_order_id = (
	select metadata."default-sort-order-id"
	from iceberg_load_table_response(my_datalake.default.table_sort_order)
);

statement ok
insert into my_datalake.default.table_sort_order values
(900003, 30, 7001, 1, 1.00, 10.00, 0.00, 0.00, 'N', 'O', DATE '1998-01-01', DATE '1998-01-02', DATE '1998-01-03', 'DELIVER IN PERSON', 'MAIL', 'sorted_insert_marker'),
(900001, 40, 7002, 1, 1.00, 10.00, 0.00, 0.00, 'N', 'O', DATE '1998-01-01', DATE '1998-01-02', DATE '1998-01-03', 'DELIVER IN PERSON', 'MAIL', 'sorted_insert_marker'),
(900002, 10, 7003, 1, 1.00, 10.00, 0.00, 0.00, 'N', 'O', DATE '1998-01-01', DATE '1998-01-02', DATE '1998-01-03', 'DELIVER IN PERSON', 'MAIL', 'sorted_insert_marker'),
(900001, 10, 7004, 1, 1.00, 10.00, 0.00, 0.00, 'N', 'O', DATE '1998-01-01', DATE '1998-01-02', DATE '1998-01-03', 'DELIVER IN PERSON', 'MAIL', 'sorted_insert_marker'),
(900002, 20, 7005, 1, 1.00, 10.00, 0.00, 0.00, 'N', 'O', DATE '1998-01-01', DATE '1998-01-02', DATE '1998-01-03', 'DELIVER IN PERSON', 'MAIL', 'sorted_insert_marker'),
(900001, 30, 7006, 1, 1.00, 10.00, 0.00, 0.00, 'N', 'O', DATE '1998-01-01', DATE '1998-01-02', DATE '1998-01-03', 'DELIVER IN PERSON', 'MAIL', 'sorted_insert_marker');

query II
select l_orderkey, l_partkey
from my_datalake.default.table_sort_order
where l_comment = 'sorted_insert_marker'
order by l_orderkey, l_partkey;
----
900001	10
900001	30
900001	40
900002	10
900002	20
900003	30

statement ok
set variable snapshot_id = (
	select snapshot_id
	from iceberg_snapshots(my_datalake.default.table_sort_order)
	order by sequence_number desc
	limit 1
);

query I
select count(*)
from iceberg_metadata(my_datalake.default.table_sort_order, snapshot_from_id=getvariable('snapshot_id'))
where content = 'DATA' and status <> 'DELETED';
----
1

statement ok
set variable file_path = (
	select file_path
	from iceberg_metadata(my_datalake.default.table_sort_order, snapshot_from_id=getvariable('snapshot_id'))
	where content = 'DATA' and status <> 'DELETED'
	limit 1
);

statement ok
set variable manifest_path = (
	select manifest_path
	from iceberg_metadata(my_datalake.default.table_sort_order, snapshot_from_id=getvariable('snapshot_id'))
	where content = 'DATA' and status <> 'DELETED'
	limit 1
);

query I
with ordered_rows as (
	select
		filename,
		file_row_number,
		l_orderkey,
		l_partkey,
		lag(l_orderkey) over(partition by filename order by file_row_number) prev_orderkey,
		lag(l_partkey) over(partition by filename order by file_row_number) prev_partkey
	from read_parquet(getvariable('file_path'), filename=true, file_row_number=true)
)
select count(*)
from ordered_rows
where prev_orderkey is not null
and (l_orderkey < prev_orderkey or (l_orderkey = prev_orderkey and l_partkey < prev_partkey));
----
0

query I
select min(sort_order_id) = cast(getvariable('table_sort_order_id') as integer)
from (select unnest(data_file) from read_avro(getvariable('manifest_path')))
where sort_order_id is not null;
----
1

statement ok
delete from my_datalake.default.table_sort_order where l_comment = 'sorted_insert_marker';
