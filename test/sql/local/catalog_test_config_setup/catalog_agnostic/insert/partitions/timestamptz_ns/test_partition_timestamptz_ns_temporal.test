# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/insert/partitions/timestamptz_ns/test_partition_timestamptz_ns_temporal.test
# group: [timestamptz_ns]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

require icu

statement ok
SET Calendar='gregorian';

statement ok
SET TimeZone='Europe/Amsterdam';

set ignore_error_messages

statement ok
CREATE SCHEMA IF NOT EXISTS my_datalake.default;

statement ok
DROP TABLE IF EXISTS my_datalake.default.test_timestamptz_ns_temporal_transforms;

statement ok
CREATE TABLE my_datalake.default.test_timestamptz_ns_temporal_transforms (
	id INT,
	val TIMESTAMPTZ_NS
)
PARTITIONED BY (year(val), month(val), day(val), hour(val))
WITH ('format-version' = 3);

statement ok
INSERT INTO my_datalake.default.test_timestamptz_ns_temporal_transforms VALUES
	(1, '2020-01-15 09:30:00.123456789+01'::TIMESTAMPTZ_NS),
	(2, '2021-06-20 16:45:00.987654321+02'::TIMESTAMPTZ_NS),
	(3, '2022-03-10 23:15:00.000000001+01'::TIMESTAMPTZ_NS);

query II
SELECT id, val
FROM my_datalake.default.test_timestamptz_ns_temporal_transforms
ORDER BY id;
----
1	2020-01-15 09:30:00.123456789+01
2	2021-06-20 16:45:00.987654321+02
3	2022-03-10 23:15:00.000000001+01

query IIII
SELECT partition_field_name, partition_field_transform, lower_bound, upper_bound
FROM iceberg_partition_stats(my_datalake.default.test_timestamptz_ns_temporal_transforms)
ORDER BY partition_field_name;
----
day_val_2	day	18276	19061
hour_val_2	hour	438632	457486
month_val_2	month	600	626
year_val_2	year	50	52

query II
SELECT id, val
FROM my_datalake.default.test_timestamptz_ns_temporal_transforms
WHERE val = '2021-06-20 16:45:00.987654321+02'::TIMESTAMPTZ_NS;
----
2	2021-06-20 16:45:00.987654321+02

statement ok
DROP TABLE my_datalake.default.test_timestamptz_ns_temporal_transforms;
