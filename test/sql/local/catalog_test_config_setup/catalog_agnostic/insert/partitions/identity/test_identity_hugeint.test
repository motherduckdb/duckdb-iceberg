# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/insert/partitions/identity/test_identity_hugeint.test
# group: [identity]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
create schema if not exists my_datalake.default;

statement ok
drop table if exists my_datalake.default.test_identity_hugeint;

statement ok
CREATE TABLE my_datalake.default.test_identity_hugeint (id int, val HUGEINT)
PARTITIONED BY (val);

statement ok
insert into my_datalake.default.test_identity_hugeint
select range, (range % 3)::HUGEINT * 1000000000000000000::HUGEINT
from range(30);

statement ok
create table local_identity_hugeint as
select range as id, (range % 3)::HUGEINT * 1000000000000000000::HUGEINT as val
from range(30);

query II nosort expected_result
select * from local_identity_hugeint order by id;
----

query II nosort expected_result
select * from my_datalake.default.test_identity_hugeint order by id;
----

query I
select count(*) from my_datalake.default.test_identity_hugeint;
----
30

query I
select count(*) from my_datalake.default.test_identity_hugeint where val = 0;
----
10

query I
select count(*) from my_datalake.default.test_identity_hugeint where val = 1000000000000000000;
----
10

query I
select count(*) from my_datalake.default.test_identity_hugeint where val = 2000000000000000000;
----
10

statement ok
drop table if exists my_datalake.default.test_identity_hugeint_large;

statement ok
CREATE TABLE my_datalake.default.test_identity_hugeint_large (id int, val HUGEINT)
PARTITIONED BY (val);

statement ok
insert into my_datalake.default.test_identity_hugeint_large values
    (1, 17014118346046923173168730371588410572),
    (2, -17014118346046923173168730371588410572),
    (3, 0),
    (4, 17014118346046923173168730371588410572),
    (5, -17014118346046923173168730371588410572),
    (6, 0);

query II
select * from my_datalake.default.test_identity_hugeint_large order by id;
----
1	17014118346046923173168730371588410572
2	-17014118346046923173168730371588410572
3	0
4	17014118346046923173168730371588410572
5	-17014118346046923173168730371588410572
6	0


query I
select count(*) from my_datalake.default.test_identity_hugeint_large where val = 17014118346046923173168730371588410572;
----
2

query I
select count(*) from my_datalake.default.test_identity_hugeint_large where val = -17014118346046923173168730371588410572;
----
2

query I
select count(*) from my_datalake.default.test_identity_hugeint_large where val = 0;
----
2

# check that partition values in the manifest are stored as DECIMAL(38,0)
statement ok
set variable manifest_path_large = (select manifest_path from iceberg_metadata(my_datalake.default.test_identity_hugeint_large) order by manifest_sequence_number desc limit 1);

query I
select typeof(partition.identity_val_2) from (select unnest(data_file) from read_avro(getvariable('manifest_path_large'))) order by all;
----
DECIMAL(38,0)
DECIMAL(38,0)
DECIMAL(38,0)
