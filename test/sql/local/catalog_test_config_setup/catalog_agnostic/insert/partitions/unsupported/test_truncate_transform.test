# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/insert/partitions/unsupported/test_truncate_transform.test
# description: Test that TRUNCATE partition transform is rejected for INSERT
# group: [unsupported]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
create schema if not exists my_datalake.default;

statement ok
drop table if exists my_datalake.default.test_truncate_transform;

statement ok
CREATE TABLE my_datalake.default.test_truncate_transform (id int, val varchar);

statement ok
ALTER TABLE my_datalake.default.test_truncate_transform SET PARTITIONED BY (truncate(4, val));

statement ok
insert into my_datalake.default.test_truncate_transform select range, 'value_' || range::VARCHAR from range(10);

query I
select count(*) from my_datalake.default.test_truncate_transform;
----
10
