# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/insert/partitions/truncate/test_truncate_int.test
# description: Insert into a truncate-partitioned INTEGER table and verify round-trip
# group: [truncate]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
create schema if not exists my_datalake.default;

statement ok
drop table if exists my_datalake.default.test_truncate_int;

# truncate(10, id): values 0-9 -> 0, values 10-19 -> 10, etc.
# 30 rows across id 0..29 produces 3 distinct partition values: 0, 10, 20
statement ok
CREATE TABLE my_datalake.default.test_truncate_int (id int, val varchar)
PARTITIONED BY (truncate(10, id));

statement ok
insert into my_datalake.default.test_truncate_int
select range, 'val_' || range::VARCHAR from range(30);

statement ok
create table local_truncate_int as
select range as id, 'val_' || range::VARCHAR as val from range(30);

query II nosort expected_result
select * from local_truncate_int order by id;
----

query II nosort expected_result
select * from my_datalake.default.test_truncate_int order by id;
----

query I
select count(*) from my_datalake.default.test_truncate_int;
----
30

# Verify negative values are handled correctly (floor toward -infinity)
# truncate(-1, 10) = -10, truncate(-10, 10) = -10, truncate(-11, 10) = -20

statement ok
drop table if exists my_datalake.default.test_truncate_int_negative;

statement ok
CREATE TABLE my_datalake.default.test_truncate_int_negative (id int, val varchar)
PARTITIONED BY (truncate(10, id));

statement ok
insert into my_datalake.default.test_truncate_int_negative
values (-1, 'neg_1'), (-9, 'neg_9'), (-10, 'neg_10'), (-11, 'neg_11'), (-20, 'neg_20');

query II rowsort
select * from my_datalake.default.test_truncate_int_negative;
----
-1	neg_1
-10	neg_10
-11	neg_11
-20	neg_20
-9	neg_9
