# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/insert/partitions/truncate/test_truncate_bigint.test
# description: Insert into a truncate-partitioned BIGINT table and verify round-trip
# group: [truncate]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
create schema if not exists my_datalake.default;

statement ok
drop table if exists my_datalake.default.test_truncate_bigint;

# truncate(10, val): values 0-9 -> 0, values 10-19 -> 10, etc.
# 30 rows across val 0..29 produces 3 distinct partition values: 0, 10, 20
statement ok
CREATE TABLE my_datalake.default.test_truncate_bigint (id int, val bigint)
PARTITIONED BY (truncate(10, val));

statement ok
insert into my_datalake.default.test_truncate_bigint
select range, range::BIGINT from range(30);

statement ok
create table local_truncate_bigint as
select range as id, range::BIGINT as val from range(30);

query II nosort expected_result
select * from local_truncate_bigint order by id;
----

query II nosort expected_result
select * from my_datalake.default.test_truncate_bigint order by id;
----

query I
select count(*) from my_datalake.default.test_truncate_bigint;
----
30

# Verify negative values are handled correctly (floor toward -infinity)
# truncate(-1, 10) = -10, truncate(-10, 10) = -10, truncate(-11, 10) = -20

statement ok
drop table if exists my_datalake.default.test_truncate_bigint_negative;

statement ok
CREATE TABLE my_datalake.default.test_truncate_bigint_negative (id int, val bigint)
PARTITIONED BY (truncate(10, val));

statement ok
insert into my_datalake.default.test_truncate_bigint_negative
values (-1, -1::BIGINT), (-9, -9::BIGINT), (-10, -10::BIGINT), (-11, -11::BIGINT), (-20, -20::BIGINT);

query II rowsort
select * from my_datalake.default.test_truncate_bigint_negative;
----
-1	-1
-10	-10
-11	-11
-20	-20
-9	-9
