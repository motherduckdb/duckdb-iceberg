# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/insert/partitions/bucket/test_bucket_timestamptz_ns.test
# group: [bucket]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

require icu

statement ok
SET Calendar='gregorian';

statement ok
SET TimeZone='Europe/Amsterdam';

set ignore_error_messages

statement ok
CREATE SCHEMA IF NOT EXISTS my_datalake.default;

statement ok
DROP TABLE IF EXISTS my_datalake.default.test_timestamptz_ns_bucket;

statement ok
CREATE TABLE my_datalake.default.test_timestamptz_ns_bucket (
	id INT,
	val TIMESTAMPTZ_NS
)
PARTITIONED BY (bucket(4, val))
WITH ('format-version' = 3);

statement ok
INSERT INTO my_datalake.default.test_timestamptz_ns_bucket VALUES
	(1, '2020-01-15 09:30:00.123456789+01'::TIMESTAMPTZ_NS),
	(2, '2021-06-20 16:45:00.987654321+02'::TIMESTAMPTZ_NS),
	(3, '2022-03-10 23:15:00.000000001+01'::TIMESTAMPTZ_NS),
	(4, NULL);

query II
SELECT id, val
FROM my_datalake.default.test_timestamptz_ns_bucket
ORDER BY id;
----
1	2020-01-15 09:30:00.123456789+01
2	2021-06-20 16:45:00.987654321+02
3	2022-03-10 23:15:00.000000001+01
4	NULL

query IIII
SELECT partition_field_name, partition_field_transform, lower_bound, upper_bound
FROM iceberg_partition_stats(my_datalake.default.test_timestamptz_ns_bucket)
ORDER BY partition_field_name;
----
bucket_4__val_2	bucket[4]	2	3

statement ok
DROP TABLE my_datalake.default.test_timestamptz_ns_bucket;
