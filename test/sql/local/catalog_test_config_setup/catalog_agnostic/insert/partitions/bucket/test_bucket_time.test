# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/insert/partitions/bucket/test_bucket_time.test
# description: Insert into a bucket-partitioned TIME table and verify round-trip
# group: [bucket]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
create schema if not exists my_datalake.default;

statement ok
drop table if exists my_datalake.default.test_bucket_time;

statement ok
CREATE TABLE my_datalake.default.test_bucket_time (id int, val time)
PARTITIONED BY (bucket(4, val));

statement ok
insert into my_datalake.default.test_bucket_time
select range, make_time(range, 0, 0) from range(20);

statement ok
create table local_bucket_time as
select range as id, make_time(range, 0, 0) as val from range(20);

query II nosort expected_result
select * from local_bucket_time order by id;
----

query II nosort expected_result
select * from my_datalake.default.test_bucket_time order by id;
----

query I
select count(*) from my_datalake.default.test_bucket_time;
----
20
