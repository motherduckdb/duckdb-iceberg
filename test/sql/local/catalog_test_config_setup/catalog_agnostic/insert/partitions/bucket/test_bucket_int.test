# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/insert/partitions/bucket/test_bucket_int.test
# description: Insert into a bucket-partitioned INTEGER table and verify round-trip
# group: [bucket]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
create schema if not exists my_datalake.default;

statement ok
drop table if exists my_datalake.default.test_bucket_int;

statement ok
CREATE TABLE my_datalake.default.test_bucket_int (id int, val varchar)
PARTITIONED BY (bucket(4, id));

statement ok
insert into my_datalake.default.test_bucket_int
select range, 'val_' || range::VARCHAR from range(20);

statement ok
create table local_bucket_int as
select range as id, 'val_' || range::VARCHAR as val from range(20);

query II nosort expected_result
select * from local_bucket_int order by id;
----

query II nosort expected_result
select * from my_datalake.default.test_bucket_int order by id;
----

query I
select count(*) from my_datalake.default.test_bucket_int;
----
20
