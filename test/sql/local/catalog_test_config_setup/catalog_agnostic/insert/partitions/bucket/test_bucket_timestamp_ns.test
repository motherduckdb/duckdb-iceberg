# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/insert/partitions/bucket/test_bucket_timestamp_ns.test
# description: Insert into a bucket-partitioned TIMESTAMP_NS table and verify round-trip
# group: [bucket]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
create schema if not exists my_datalake.default;

statement ok
drop table if exists my_datalake.default.test_bucket_timestamp_ns;

statement ok
CREATE TABLE my_datalake.default.test_bucket_timestamp_ns (id int, val timestamp_ns)
PARTITIONED BY (bucket(4, val)) WITH ('format-version'=3);

statement ok
insert into my_datalake.default.test_bucket_timestamp_ns
select range, ('2020-01-01 00:00:00'::TIMESTAMP_NS + INTERVAL (range) HOUR) from range(20);

statement ok
create table local_bucket_timestamp_ns as
select range as id, ('2020-01-01 00:00:00'::TIMESTAMP_NS + INTERVAL (range) HOUR) as val from range(20);

query II nosort expected_result
select * from local_bucket_timestamp_ns order by id;
----

query II nosort expected_result
select * from my_datalake.default.test_bucket_timestamp_ns order by id;
----

query I
select count(*) from my_datalake.default.test_bucket_timestamp_ns;
----
20
