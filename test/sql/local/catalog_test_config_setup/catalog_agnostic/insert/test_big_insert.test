# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/insert/test_big_insert.test
# group: [insert]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
set enable_logging=true

statement ok
set logging_level='debug'

statement ok
DROP TABLE IF EXISTS my_datalake.default.insert_test_big;

statement ok
CREATE TABLE my_datalake.default.insert_test_big (
	col1 INTEGER,
	col2 VARCHAR(17)
) WITH (
    'format-version'='2',
    'write.update.mode'='merge-on-read',
    'write.parquet.compression-codec'='snappy'
);

# Default TARGET_FILE_SIZE = 500MB
# We create ~18MB of data
query I
INSERT INTO my_datalake.default.insert_test_big SELECT i, concat('thisisalongstring', i) FROM range(2000000) t(i)
----
2000000

query II
explain analyze select * from my_datalake.default.insert_test_big
----
analyzed_plan	<REGEX>:.*Total Files Read: 1.*
