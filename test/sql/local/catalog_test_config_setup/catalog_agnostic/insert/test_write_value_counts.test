# --- Struct/List/Map table with manifest avro verification ---
statement ok
DROP TABLE IF EXISTS my_datalake.default.duckdb_nested_types;

statement ok
CREATE TABLE my_datalake.default.duckdb_nested_types (
	id INT,
	name VARCHAR,
	address STRUCT(street VARCHAR, city VARCHAR, zip VARCHAR),
	phone_numbers VARCHAR[],
	metadata MAP(VARCHAR, VARCHAR)
);

statement ok
INSERT INTO my_datalake.default.duckdb_nested_types VALUES (
	1,
	'Alice',
	{'street': '123 Main St', 'city': 'Metropolis', 'zip': '12345'},
	['123-456-7890', '987-654-3210'],
	MAP(['age', 'membership'], ['30', 'gold'])
);

query II
SELECT column_name, value_count
FROM iceberg_column_stats(my_datalake.default.duckdb_nested_types)
WHERE column_name IN ('id', 'name', 'street', 'city', 'zip', 'element', 'key', 'value')
ORDER BY column_name;
----
city	1
element	2
id	1
key	2
name	1
street	1
value	2
zip	1

# Start transaction to keep necessary credentials in scope
statement ok
begin

statement ok
SET VARIABLE avro_file = (
	SELECT manifest_path FROM iceberg_metadata(my_datalake.default.duckdb_nested_types)
	ORDER BY manifest_sequence_number DESC LIMIT 1
);

# Same field-id caveat as above: compare sorted value_counts from the manifest,
# not map keys, so this passes across fixture, Nessie, and other catalogs.
query I
SELECT count(*) FROM (
	SELECT unnest(map_values(value_counts)) AS value_count
	FROM (SELECT unnest(data_file) FROM read_avro(getvariable('avro_file')))
);
----
8

query I
SELECT list_sort(list(value_count::BIGINT)) = [1, 1, 1, 1, 1, 2, 2, 2]::BIGINT[] FROM (
	SELECT unnest(map_values(value_counts)) AS value_count
	FROM (SELECT unnest(data_file) FROM read_avro(getvariable('avro_file')))
);
----
true

statement ok
commit

# --- Multi-row duckdb_nested_types (NULL struct, empty list, varying map sizes) ---
statement ok
DROP TABLE IF EXISTS my_datalake.default.duckdb_nested_types_multi;

statement ok
CREATE TABLE my_datalake.default.duckdb_nested_types_multi (
	id INT,
	name VARCHAR,
	address STRUCT(street VARCHAR, city VARCHAR, zip VARCHAR),
	phone_numbers VARCHAR[],
	metadata MAP(VARCHAR, VARCHAR)
);

statement ok
INSERT INTO my_datalake.default.duckdb_nested_types_multi VALUES
	(1, 'Alice', {'street': '123 Main St', 'city': 'Metropolis', 'zip': '12345'}, ['111-111-1111', '222-222-2222'], MAP(['age'], ['30'])),
	(2, 'Bob', {'street': '456 Oak Ave', 'city': 'Gotham', 'zip': '67890'}, ['333-333-3333'], MAP(['age', 'tier'], ['25', 'silver'])),
	(3, 'Carol', NULL, [], MAP(['status'], ['active']));

query IIII
SELECT column_name, column_type, value_count, null_value_count
FROM iceberg_column_stats(my_datalake.default.duckdb_nested_types_multi)
WHERE value_count IS NOT NULL
ORDER BY column_name, column_type, value_count;
----
city	VARCHAR	3	1
element	VARCHAR	4	1
id	INTEGER	3	0
key	VARCHAR	4	0
name	VARCHAR	3	0
street	VARCHAR	3	1
value	VARCHAR	4	0
zip	VARCHAR	3	1

# Start transaction to keep necessary credentials in scope
statement ok
begin

statement ok
SET VARIABLE manifest_nested_multi = (
	SELECT manifest_path FROM iceberg_metadata(my_datalake.default.duckdb_nested_types_multi)
	ORDER BY manifest_sequence_number DESC LIMIT 1
);

query I
SELECT count(*) FROM (
	SELECT unnest(map_values(value_counts)) AS value_count
	FROM (SELECT unnest(data_file) FROM read_avro(getvariable('manifest_nested_multi')))
);
----
8

query I
SELECT list_sort(list(value_count::BIGINT)) = [3, 3, 3, 3, 3, 4, 4, 4]::BIGINT[] FROM (
	SELECT unnest(map_values(value_counts)) AS value_count
	FROM (SELECT unnest(data_file) FROM read_avro(getvariable('manifest_nested_multi')))
);
----
true

statement ok
