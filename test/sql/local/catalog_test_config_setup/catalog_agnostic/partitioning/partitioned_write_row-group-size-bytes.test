# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/partitioning/partitioned_write_row-group-size-bytes.test
# group: [partitioning]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

set ignore_error_messages

statement ok
SET threads=1;

statement ok
SET preserve_insertion_order=false;

statement ok
drop table if exists my_datalake.default.my_table;

statement ok
CREATE TABLE my_datalake.default.my_table (
  user_id INT,
  partition_id INT
) PARTITIONED BY (partition_id) WITH (
  'write.parquet.row-group-size-bytes' = '200000'
);

query II
SELECT * FROM iceberg_table_properties(my_datalake.default.my_table)
WHERE key = 'write.parquet.row-group-size-bytes';
----
write.parquet.row-group-size-bytes	200000

statement ok
INSERT INTO my_datalake.default.my_table
SELECT i, i % 10
FROM range(100_000) t(i);

# Start transaction to keep necessary credentials in scope
statement ok
begin

statement ok
SET VARIABLE parquet_filepath = (
  SELECT file_path
  FROM iceberg_metadata(my_datalake.default.my_table)
  LIMIT 1
);

query I
SELECT count(row_group_bytes)
FROM parquet_metadata(getvariable('parquet_filepath'));
----
10

statement ok
commit

# Now test with human-readable format
statement ok
drop table if exists my_datalake.default.my_table;

statement ok
CREATE TABLE my_datalake.default.my_table (
  user_id INT,
  partition_id INT
) PARTITIONED BY (partition_id) WITH (
  'write.parquet.row-group-size-bytes' = '200KB'
);

# FIXME: to be good citizens, we should probably transform to a non-human-readable representation (not formatted with KB)
query II
SELECT * FROM iceberg_table_properties(my_datalake.default.my_table)
WHERE key = 'write.parquet.row-group-size-bytes';
----
write.parquet.row-group-size-bytes	200KB

statement ok
INSERT INTO my_datalake.default.my_table
SELECT i, i % 10
FROM range(100_000) t(i);

# Start transaction to keep necessary credentials in scope
statement ok
begin

statement ok
SET VARIABLE parquet_filepath = (
  SELECT file_path
  FROM iceberg_metadata(my_datalake.default.my_table)
  LIMIT 1
);

query I
SELECT count(row_group_bytes)
FROM parquet_metadata(getvariable('parquet_filepath'));
----
10

statement ok
commit
