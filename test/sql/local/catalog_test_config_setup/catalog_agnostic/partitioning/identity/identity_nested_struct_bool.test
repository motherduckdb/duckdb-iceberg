# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/partitioning/identity/identity_nested_struct_bool.test
# group: [identity]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

set ignore_error_messages

statement ok
set threads=1;

statement ok
CREATE SCHEMA IF NOT EXISTS my_datalake.default;

statement ok
drop table if exists my_datalake.default.partition_identity_bool_nested_struct_field;

statement ok
create table my_datalake.default.partition_identity_bool_nested_struct_field (
	id int,
	nested STRUCT(
		filler VARCHAR,
		deeper STRUCT (
			even_deeper STRUCT (
				deepest STRUCT(
					partition_col boolean
				)
			)
		)
	)
);

statement ok
alter table my_datalake.default.partition_identity_bool_nested_struct_field set partitioned by (
	nested.deeper.even_deeper.deepest.partition_col
);

statement ok
insert into my_datalake.default.partition_identity_bool_nested_struct_field values
	(4, {
		'deeper': {
			'even_deeper': {
				'deepest': {
					'partition_col': true
				}
			}
		}
	}),
	(2, {
		'deeper': {
			'even_deeper': {
				'deepest': {
					'partition_col': false
				}
			}
		}
	}),
	(3, {
		'deeper': {
			'even_deeper': {
				'deepest': {
					'partition_col': true
				}
			}
		}
	}),
	(1, {
		'deeper': {
			'even_deeper': {
				'deepest': {
					'partition_col': false
				}
			}
		}
	});

statement ok
set variable latest_manifest_sequence = (select max(manifest_sequence_number) from iceberg_metadata(my_datalake.default.partition_identity_bool_nested_struct_field));

# Verify that each written file contains only 1 distinct value
query I
with latest_files as (
	select file_path
	from iceberg_metadata(my_datalake.default.partition_identity_bool_nested_struct_field)
	where manifest_sequence_number = cast(getvariable('latest_manifest_sequence') as bigint)
	and manifest_content = 'DATA'
	and status = 'ADDED'
),
file_partition_counts as (
	select filename, count(distinct nested.deeper.even_deeper.deepest.partition_col) as partition_count
	from my_datalake.default.partition_identity_bool_nested_struct_field
	where filename in (select file_path from latest_files)
	group by filename
)
select
	(select count(*) from file_partition_counts where partition_count != 1) = 0
----
1

statement ok
drop table my_datalake.default.partition_identity_bool_nested_struct_field;
