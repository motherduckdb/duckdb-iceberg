# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/delete/test_delete_commit_retry.test
# description: A DELETE retries its commit when a concurrent APPEND landed first; it aborts when a concurrent commit removed/rewrote data it targets
# group: [delete]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' / conflict error messages!
set ignore_error_messages

# ----------------------------------------------------------------------------
# Concurrent APPEND: the delete's targeted data is untouched, so on the commit
# conflict it refreshes and re-applies against the new tip and succeeds.
# ----------------------------------------------------------------------------

statement ok
DROP TABLE IF EXISTS my_datalake.default.del_retry_append;

statement ok
CREATE TABLE my_datalake.default.del_retry_append (id INTEGER, name VARCHAR);

statement ok
INSERT INTO my_datalake.default.del_retry_append VALUES (1, 'a'), (2, 'b');

statement ok con1
begin

statement ok con1
DELETE FROM my_datalake.default.del_retry_append WHERE id = 1;

statement ok con2
begin

statement ok con2
INSERT INTO my_datalake.default.del_retry_append VALUES (3, 'c');

statement ok con2
commit

# con1 commits after con2 — the delete retries against the refreshed tip and lands.
statement ok con1
commit

# id=1 deleted, con2's append preserved.
query II
SELECT * FROM my_datalake.default.del_retry_append ORDER BY id;
----
2	b
3	c

statement ok
DROP TABLE my_datalake.default.del_retry_append;

# ----------------------------------------------------------------------------
# Concurrent DELETE on the same file: re-applying is unsafe (the concurrent
# commit added delete files / rewrote data), so the losing delete aborts with a
# clear conflict rather than silently clobbering.
# ----------------------------------------------------------------------------

statement ok
DROP TABLE IF EXISTS my_datalake.default.del_retry_conflict;

statement ok
CREATE TABLE my_datalake.default.del_retry_conflict (id INTEGER, name VARCHAR);

statement ok
INSERT INTO my_datalake.default.del_retry_conflict VALUES (1, 'a'), (2, 'b'), (3, 'c');

statement ok con3
begin

statement ok con3
DELETE FROM my_datalake.default.del_retry_conflict WHERE id = 1;

statement ok con4
begin

statement ok con4
DELETE FROM my_datalake.default.del_retry_conflict WHERE id = 2;

statement ok con4
commit

# con3 commits after con4 — a concurrent delete touched the same data, so con3
# aborts instead of re-applying unsafely.
statement error con3
commit
----
conflicts with a concurrent commit

# con4's delete applied; con3's did not.
query II
SELECT * FROM my_datalake.default.del_retry_conflict ORDER BY id;
----
1	a
3	c

statement ok
DROP TABLE my_datalake.default.del_retry_conflict;
