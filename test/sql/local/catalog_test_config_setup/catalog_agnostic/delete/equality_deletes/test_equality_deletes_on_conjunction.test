# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/delete/equality_deletes/test_equality_deletes_on_conjunction.test
# description: Test iceberg deletes
# group: [equality_deletes]

require-env CATALOG_TEST_CONFIG_SETUP

require-env EQUALITY_DELETE_WRITES_ENABLED 1

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
use my_datalake.default;

statement ok
set unsafe_and_disabled_for_iceberg_v3_enable_equality_deletes=true;

statement ok
drop table if exists equality_delete_on_conjunction;

statement ok
create table equality_delete_on_conjunction as select range a, range % 5 b, range % 10 c from range(21);

query III nosort before_delete
select * from equality_delete_on_conjunction where b = 4 and c = 4 order by a;

# generate equality delete file that uses a conjunction
statement ok
delete from equality_delete_on_conjunction where b = 4 and c = 4;

query II
select c, count(*) from equality_delete_on_conjunction group by all order by c;
----
0	3
1	2
2	2
3	2
5	2
6	2
7	2
8	2
9	2

statement ok
insert into equality_delete_on_conjunction values (4, 4, 4), (14, 4, 4);

# values are restored from before the delete, but we do not count them double/restored.
query III nosort before_delete
select * from equality_delete_on_conjunction where b = 4 and c = 4 order by a;

