# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/delete/partitions/delete_truncate_partitions.test
# description: Test delete from iceberg tables partitioned by truncate transform (INT, BIGINT, VARCHAR)
# group: [partitions]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
CALL enable_logging('HTTP');

statement ok
set logging_level='debug'

# ---- TRUNCATE / INT ----
# truncate(10, id): ids 0-9 → partition 0, ids 10-19 → partition 10, ids 20-29 → partition 20

statement ok
DROP TABLE IF EXISTS my_datalake.default.test_delete_truncate_int;

statement ok
CREATE TABLE my_datalake.default.test_delete_truncate_int (id INT, val VARCHAR)
PARTITIONED BY (truncate(10, id));

statement ok
INSERT INTO my_datalake.default.test_delete_truncate_int VALUES
    (1, 'a'), (5, 'b'), (11, 'c'), (15, 'd'), (21, 'e');

query II
SELECT * FROM my_datalake.default.test_delete_truncate_int ORDER BY id;
----
1	a
5	b
11	c
15	d
21	e

# Delete both rows in partition 0 (ids 1 and 5 both truncate to 0)
statement ok
DELETE FROM my_datalake.default.test_delete_truncate_int WHERE id < 10;

query II
SELECT * FROM my_datalake.default.test_delete_truncate_int ORDER BY id;
----
11	c
15	d
21	e

# Delete by non-partition column (row in partition 10)
statement ok
DELETE FROM my_datalake.default.test_delete_truncate_int WHERE val = 'd';

query II
SELECT * FROM my_datalake.default.test_delete_truncate_int ORDER BY id;
----
11	c
21	e

# Delete spanning multiple truncate partitions
statement ok
DELETE FROM my_datalake.default.test_delete_truncate_int WHERE id >= 10;

query I
SELECT COUNT(*) FROM my_datalake.default.test_delete_truncate_int;
----
0

statement ok
DROP TABLE my_datalake.default.test_delete_truncate_int;

# ---- TRUNCATE / BIGINT ----
# truncate(10, val): same floor-to-decade semantics as INT

statement ok
DROP TABLE IF EXISTS my_datalake.default.test_delete_truncate_bigint;

statement ok
CREATE TABLE my_datalake.default.test_delete_truncate_bigint (id INT, val BIGINT)
PARTITIONED BY (truncate(10, val));

statement ok
INSERT INTO my_datalake.default.test_delete_truncate_bigint VALUES
    (1, 1::BIGINT),
    (2, 7::BIGINT),
    (3, 11::BIGINT),
    (4, 19::BIGINT),
    (5, 25::BIGINT);

query II
SELECT * FROM my_datalake.default.test_delete_truncate_bigint ORDER BY id;
----
1	1
2	7
3	11
4	19
5	25

# ids 1 and 2 share truncate partition 0 (values 1 and 7 both truncate to 0)
statement ok
DELETE FROM my_datalake.default.test_delete_truncate_bigint WHERE val < 10;

query II
SELECT * FROM my_datalake.default.test_delete_truncate_bigint ORDER BY id;
----
3	11
4	19
5	25

statement ok
DELETE FROM my_datalake.default.test_delete_truncate_bigint WHERE id = 4;

query II
SELECT * FROM my_datalake.default.test_delete_truncate_bigint ORDER BY id;
----
3	11
5	25

statement ok
DROP TABLE my_datalake.default.test_delete_truncate_bigint;

# ---- TRUNCATE / VARCHAR ----
# truncate(3, category): 'aardvark' and 'aardwolf' → partition 'aar'
#                        'bear' and 'beaver' → partition 'bea'
#                        'cat' → partition 'cat'

statement ok
DROP TABLE IF EXISTS my_datalake.default.test_delete_truncate_varchar;

statement ok
CREATE TABLE my_datalake.default.test_delete_truncate_varchar (id INT, category VARCHAR, val VARCHAR)
PARTITIONED BY (truncate(3, category));

statement ok
INSERT INTO my_datalake.default.test_delete_truncate_varchar VALUES
    (1, 'aardvark', 'a'),
    (2, 'aardwolf', 'b'),
    (3, 'bear',     'c'),
    (4, 'beaver',   'd'),
    (5, 'cat',      'e');

query III
SELECT * FROM my_datalake.default.test_delete_truncate_varchar ORDER BY id;
----
1	aardvark	a
2	aardwolf	b
3	bear	c
4	beaver	d
5	cat	e

# Both 'aar%' rows share partition 'aar'
statement ok
DELETE FROM my_datalake.default.test_delete_truncate_varchar WHERE category LIKE 'aar%';

query III
SELECT * FROM my_datalake.default.test_delete_truncate_varchar ORDER BY id;
----
3	bear	c
4	beaver	d
5	cat	e

# Delete by non-partition column
statement ok
DELETE FROM my_datalake.default.test_delete_truncate_varchar WHERE val = 'd';

query III
SELECT * FROM my_datalake.default.test_delete_truncate_varchar ORDER BY id;
----
3	bear	c
5	cat	e

# Delete by category value spanning the remaining partitions
statement ok
DELETE FROM my_datalake.default.test_delete_truncate_varchar WHERE category IN ('bear', 'cat');

query I
SELECT COUNT(*) FROM my_datalake.default.test_delete_truncate_varchar;
----
0

statement ok
DROP TABLE my_datalake.default.test_delete_truncate_varchar;
