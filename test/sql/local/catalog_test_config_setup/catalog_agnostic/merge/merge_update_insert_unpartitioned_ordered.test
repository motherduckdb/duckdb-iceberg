# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/merge/merge_update_insert_unpartitioned_ordered.test
# description: MERGE INTO update+insert on an unpartitioned ordered table
# group: [merge]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
set threads=1;

statement ok
CREATE SCHEMA IF NOT EXISTS my_datalake.default;

statement ok
drop table if exists my_datalake.default.merge_update_insert_unpartitioned_ordered;

statement ok
create table my_datalake.default.merge_update_insert_unpartitioned_ordered (
	id int,
	p int,
	a int,
	b int
);

statement ok
alter table my_datalake.default.merge_update_insert_unpartitioned_ordered set sorted by (
	a asc nulls last,
	b asc nulls last
);

statement ok
set variable table_sort_order_id = (
	select metadata."default-sort-order-id"
	from iceberg_load_table_response(my_datalake.default.merge_update_insert_unpartitioned_ordered)
);

statement ok
insert into my_datalake.default.merge_update_insert_unpartitioned_ordered values
	(1, 1, 2, 20),
	(2, 1, 1, 30),
	(3, 2, 2, 10),
	(4, 2, 1, 40);

query I
MERGE INTO my_datalake.default.merge_update_insert_unpartitioned_ordered AS t
USING (VALUES
	(3, 2, 1, 5),
	(5, 1, 1, 10)
) AS s(id, p, a, b)
ON t.id = s.id
WHEN MATCHED THEN UPDATE SET
	p = s.p,
	a = s.a,
	b = s.b
WHEN NOT MATCHED THEN INSERT VALUES (s.id, s.p, s.a, s.b);
----
2

query IIII
select * from my_datalake.default.merge_update_insert_unpartitioned_ordered order by id;
----
1	1	2	20
2	1	1	30
3	2	1	5
4	2	1	40
5	1	1	10

# Start transaction to keep necessary credentials in scope
statement ok
begin

statement ok
set variable latest_manifest_sequence = (
	select max(manifest_sequence_number)
	from iceberg_metadata(my_datalake.default.merge_update_insert_unpartitioned_ordered)
);

statement ok
set variable manifest_path = (
	select manifest_path
	from iceberg_metadata(my_datalake.default.merge_update_insert_unpartitioned_ordered)
	where manifest_sequence_number = cast(getvariable('latest_manifest_sequence') as bigint)
	and manifest_content = 'DATA'
	and status = 'ADDED'
	limit 1
);

# Use the latest added file handles from the Iceberg scan itself so the test
# checks the physical row order DuckDB wrote, not the logical query order.
query I
with latest_files as (
	select file_path
	from iceberg_metadata(my_datalake.default.merge_update_insert_unpartitioned_ordered)
	where manifest_sequence_number = cast(getvariable('latest_manifest_sequence') as bigint)
	and manifest_content = 'DATA'
	and status = 'ADDED'
),
ordered_rows as (
	select
		filename,
		file_row_number,
		a,
		b,
		lag(a) over(partition by filename order by file_row_number) prev_a,
		lag(b) over(partition by filename order by file_row_number) prev_b
	from my_datalake.default.merge_update_insert_unpartitioned_ordered
	where filename in (select file_path from latest_files)
)
select count(*)
from ordered_rows
where prev_a is not null
and (a < prev_a or (a = prev_a and b < prev_b));
----
0

query I
select min(sort_order_id) = cast(getvariable('table_sort_order_id') as integer)
and max(sort_order_id) = cast(getvariable('table_sort_order_id') as integer)
from (select unnest(data_file) from read_avro(getvariable('manifest_path')))
where file_path in (
	select file_path
	from iceberg_metadata(my_datalake.default.merge_update_insert_unpartitioned_ordered)
	where manifest_sequence_number = cast(getvariable('latest_manifest_sequence') as bigint)
	and manifest_content = 'DATA'
	and status = 'ADDED'
)
and sort_order_id is not null;
----
1

statement ok
drop table my_datalake.default.merge_update_insert_unpartitioned_ordered;

statement ok
commit
