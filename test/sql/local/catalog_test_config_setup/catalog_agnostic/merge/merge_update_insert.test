# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/merge/merge_update_insert.test
# description: Test merge into with update/insert
# group: [merge]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
set enable_logging=true

statement ok
set logging_level='debug'

statement ok
DROP TABLE IF EXISTS my_datalake.default.Stock;

statement ok
DROP TABLE IF EXISTS my_datalake.default.Buy;

statement ok
CREATE TABLE my_datalake.default.Stock(
	item_id int,
	balance int
);

statement ok
insert into my_datalake.default.Stock values
	(10, 2200),
	(20, 1900)

statement ok
CREATE TABLE my_datalake.default.Buy(
	item_id int,
	volume int
);

statement ok
INSERT INTO my_datalake.default.Buy values
	(10, 1000),
	(30, 300);

query II
FROM my_datalake.default.Stock ORDER BY item_id
----
10	2200
20	1900

# update and insert
query I
MERGE INTO my_datalake.default.Stock AS s USING my_datalake.default.Buy AS b ON s.item_id = b.item_id
WHEN MATCHED THEN UPDATE SET balance = balance + b.volume
WHEN NOT MATCHED THEN INSERT VALUES (b.item_id, b.volume)
----
2

query II
FROM my_datalake.default.Stock ORDER BY item_id
----
10	3200
20	1900
30	300
