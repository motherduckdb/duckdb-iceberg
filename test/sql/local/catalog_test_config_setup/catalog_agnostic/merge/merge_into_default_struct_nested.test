# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/merge/merge_into_default_struct_nested.test
# description: Regression for nested default struct values during MERGE INTO
# group: [merge]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
set enable_logging=true

statement ok
set logging_level='debug'

statement ok
set disable_parquet_prefetching = true;

statement ok
set prefetch_all_parquet_files = false;

statement ok
DROP TABLE IF EXISTS my_datalake.default.nested_nested_tbl;

# NOTE: Since no engine/catalog supports the {} default for STRUCT, we write NULL (omit the initial-default) for STRUCT instead
# This changes the behavior matrix, and will need to be updated when support for {} is added
statement ok
CREATE TABLE my_datalake.default.nested_nested_tbl(
	id INTEGER,
	col STRUCT(
		a VARCHAR,
		b STRUCT(
			v1 BIGINT,
			v2 STRUCT(
				f1 VARCHAR,
				f2 VARCHAR,
				f3 VARCHAR
			),
			v3 BIGINT
		),
		e BOOLEAN
	) DEFAULT {
		'a': 'test',
		'b': {
			'v1': 1000,
			'v2': {
				'f1': 'alpha',
				'f3': 'gamma'
			},
			'v3': -500
		},
		'e': NULL
	},
	col2 INTEGER
) WITH (
	'format-version'= 3
);

statement ok
insert into my_datalake.default.nested_nested_tbl values
	(1, {
		'a': 'seed',
		'b': {
			'v1': 0,
			'v2': {
				'f1': 'seed',
				'f2': 'seed',
				'f3': 'seed'
			},
			'v3': 0
		},
		'e': false
	}, 12),
	(2, {
		'a': 'seed',
		'b': {
			'v1': 0,
			'v2': {
				'f1': 'seed',
				'f2': 'seed',
				'f3': 'seed'
			},
			'v3': 0
		},
		'e': false
	}, 24),
	(3, {
		'a': 'seed',
		'b': {
			'v1': 0,
			'v2': {
				'f1': 'seed',
				'f2': 'seed',
				'f3': 'seed'
			},
			'v3': 0
		},
		'e': false
	}, 36);

query I
MERGE INTO my_datalake.default.nested_nested_tbl AS t USING (
	VALUES
		(1, {'b': {'v2': {'f3': NULL}}}, 12),
		(4, {'b': {'v2': {'f3': NULL}}}, 48)
) AS s(id, col, col2) ON t.id = s.id
WHEN MATCHED THEN UPDATE SET col = s.col, col2 = s.col2
WHEN NOT MATCHED THEN INSERT VALUES (s.id, s.col, s.col2)
----
2

query III
select * from my_datalake.default.nested_nested_tbl where id = 1;
----
1	{'a': test, 'b': {'v1': 1000, 'v2': {'f1': alpha, 'f2': NULL, 'f3': NULL}, 'v3': -500}, 'e': NULL}	12

query III
select * from my_datalake.default.nested_nested_tbl where id = 4;
----
4	{'a': test, 'b': {'v1': 1000, 'v2': {'f1': alpha, 'f2': NULL, 'f3': NULL}, 'v3': -500}, 'e': NULL}	48

# Only supply b.v2.f2, which has no default; f1 and f3 retain their defaults

query I
MERGE INTO my_datalake.default.nested_nested_tbl AS t USING (
	VALUES
		(2, {'b': {'v2': {'f2': 'world'}}}, 24),
		(5, {'b': {'v2': {'f2': 'world'}}}, 60)
) AS s(id, col, col2) ON t.id = s.id
WHEN MATCHED THEN UPDATE SET col = s.col, col2 = s.col2
WHEN NOT MATCHED THEN INSERT VALUES (s.id, s.col, s.col2)
----
2

query III
select * from my_datalake.default.nested_nested_tbl where id = 2;
----
2	{'a': test, 'b': {'v1': 1000, 'v2': {'f1': alpha, 'f2': world, 'f3': gamma}, 'v3': -500}, 'e': NULL}	24

query III
select * from my_datalake.default.nested_nested_tbl where id = 5;
----
5	{'a': test, 'b': {'v1': 1000, 'v2': {'f1': alpha, 'f2': world, 'f3': gamma}, 'v3': -500}, 'e': NULL}	60

# Supply all three inner fields, fully overriding all defaults in v2

query I
MERGE INTO my_datalake.default.nested_nested_tbl AS t USING (
	VALUES
		(3, {
			'b': {
				'v2': {
					'f1': 'foo',
					'f2': 'bar',
					'f3': 'baz'
				}
			}
		}, 36),
		(6, {
			'b': {
				'v2': {
					'f1': 'foo',
					'f2': 'bar',
					'f3': 'baz'
				}
			}
		}, 72)
) AS s(id, col, col2) ON t.id = s.id
WHEN MATCHED THEN UPDATE SET col = s.col, col2 = s.col2
WHEN NOT MATCHED THEN INSERT VALUES (s.id, s.col, s.col2)
----
2

query III
select * from my_datalake.default.nested_nested_tbl where id = 3;
----
3	{'a': test, 'b': {'v1': 1000, 'v2': {'f1': foo, 'f2': bar, 'f3': baz}, 'v3': -500}, 'e': NULL}	36

query III
select * from my_datalake.default.nested_nested_tbl where id = 6;
----
6	{'a': test, 'b': {'v1': 1000, 'v2': {'f1': foo, 'f2': bar, 'f3': baz}, 'v3': -500}, 'e': NULL}	72
