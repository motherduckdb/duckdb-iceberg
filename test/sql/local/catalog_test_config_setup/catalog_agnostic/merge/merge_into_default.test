# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/merge/merge_into_default.test
# group: [merge]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
set enable_logging=true

statement ok
set logging_level='debug'

statement ok
DROP TABLE IF EXISTS my_datalake.default.Stock;

statement ok
CREATE TABLE my_datalake.default.Stock(
	item_id int,
	balance int DEFAULT 0
) WITH (
	'format-version'='3'
);

# explicit default
query I
MERGE INTO my_datalake.default.Stock USING (VALUES (10)) new_accounts(item_id) USING (item_id)
WHEN NOT MATCHED THEN INSERT VALUES (new_accounts.item_id, DEFAULT)
----
1

# column list
query I
MERGE INTO my_datalake.default.Stock USING (VALUES (20)) new_accounts(item_id) USING (item_id)
WHEN NOT MATCHED THEN INSERT (item_id) VALUES (new_accounts.item_id)
----
1

# default values
query I
MERGE INTO my_datalake.default.Stock USING (VALUES (30)) new_accounts(item_id) USING (item_id)
WHEN NOT MATCHED THEN INSERT DEFAULT VALUES
----
1

query II
FROM my_datalake.default.Stock order by all
----
10	0
20	0
NULL	0

statement ok
UPDATE my_datalake.default.Stock SET balance=100

# update default
query I
MERGE INTO my_datalake.default.Stock USING (VALUES (10)) reset_accounts(item_id) USING (item_id)
WHEN MATCHED THEN UPDATE SET balance=DEFAULT
WHEN NOT MATCHED THEN ERROR
----
1

query II
FROM my_datalake.default.Stock order by all
----
10	0
20	100
NULL	100
