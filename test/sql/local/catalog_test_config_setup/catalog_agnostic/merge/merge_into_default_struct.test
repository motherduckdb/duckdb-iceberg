# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/merge/merge_into_default_struct.test
# description: Regression for default struct values during MERGE INTO
# group: [merge]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
set enable_logging=true

statement ok
set logging_level='debug'

statement ok
set disable_parquet_prefetching = true;

statement ok
set prefetch_all_parquet_files = false;

statement ok
DROP TABLE IF EXISTS my_datalake.default.tbl;

# NOTE: Since no engine/catalog supports the {} default for STRUCT, we write NULL (omit the initial-default) for STRUCT instead
# This changes the behavior matrix, and will need to be updated when support for {} is added
statement ok
CREATE TABLE my_datalake.default.tbl(
	id INTEGER,
	col STRUCT(
		a VARCHAR,
		b INTEGER,
		c BLOB
	) DEFAULT {'a': 'hello', 'b': 42},
	col2 BLOB
) WITH (
	'format-version'='3'
);

statement ok
insert into my_datalake.default.tbl values
	(1, {'a': 'seed', 'b': 0, 'c': '\x01'}, NULL),
	(2, {'a': 'seed', 'b': 0, 'c': '\x02'}, NULL),
	(3, {'a': 'seed', 'b': 0, 'c': '\x03'}, NULL);

# explicit default
query I
MERGE INTO my_datalake.default.tbl AS t USING (
	VALUES
		(1, {'a': 'test'}, '\xaa\xff\xaa'),
		(4, {'a': 'test'}, '\xAA\xFF\xAA\xAA\xFF\xAA')
) AS s(id, col, col2) ON t.id = s.id
WHEN MATCHED THEN UPDATE SET col = s.col, col2 = s.col2
WHEN NOT MATCHED THEN INSERT VALUES (s.id, s.col, s.col2)
----
2

query III
select * from my_datalake.default.tbl where id = 1;
----
1	{'a': test, 'b': 42, 'c': NULL}	\xAA\xFF\xAA

query III
select * from my_datalake.default.tbl where id = 4;
----
4	{'a': test, 'b': 42, 'c': NULL}	\xAA\xFF\xAA\xAA\xFF\xAA

# column list
query I
MERGE INTO my_datalake.default.tbl AS t USING (
	VALUES
		(2, {'b': 21}, NULL),
		(5, {'b': 21}, NULL)
) AS s(id, col, col2) ON t.id = s.id
WHEN MATCHED THEN UPDATE SET col = s.col, col2 = s.col2
WHEN NOT MATCHED THEN INSERT (id, col, col2) VALUES (s.id, s.col, s.col2)
----
2

query III
select * from my_datalake.default.tbl where id = 2;
----
2	{'a': hello, 'b': 21, 'c': NULL}	NULL

query III
select * from my_datalake.default.tbl where id = 5;
----
5	{'a': hello, 'b': 21, 'c': NULL}	NULL

# default values
query I
MERGE INTO my_datalake.default.tbl AS t USING (
	VALUES
		(3, {'c': '\xaa\xff\xaa'}, NULL),
		(6, {'c': '\xaa\xff\xaa'}, NULL)
) AS s(id, col, col2) ON t.id = s.id
WHEN MATCHED THEN UPDATE SET col = s.col, col2 = s.col2
WHEN NOT MATCHED THEN INSERT (id, col, col2) VALUES (s.id, s.col, s.col2)
----
2

query III
select * from my_datalake.default.tbl where id = 3;
----
3	{'a': hello, 'b': 42, 'c': \xAA\xFF\xAA}	NULL

query III
select * from my_datalake.default.tbl where id = 6;
----
6	{'a': hello, 'b': 42, 'c': \xAA\xFF\xAA}	NULL

# DEFAULT NULL on a STRUCT currently materializes a struct whose fields are all NULL.

statement ok
drop table if exists my_datalake.default.tbl_default_null_struct;

statement ok
create table my_datalake.default.tbl_default_null_struct(
	id INTEGER,
	col STRUCT(
		a VARCHAR,
		b INTEGER,
		c STRUCT(
			x BIGINT
		)
	) DEFAULT NULL,
	col2 INTEGER
) WITH (
	'format-version' = 3
);

statement ok
insert into my_datalake.default.tbl_default_null_struct values
	(1, {'a': 'seed', 'b': 1, 'c': {'x': 11}}, 10),
	(2, {'a': 'seed', 'b': 2, 'c': {'x': 22}}, 20);

query I
MERGE INTO my_datalake.default.tbl_default_null_struct AS t USING (
	VALUES
		(1, 100),
		(3, 300)
) AS s(id, col2) ON t.id = s.id
WHEN MATCHED THEN UPDATE SET col = DEFAULT, col2 = s.col2
WHEN NOT MATCHED THEN INSERT VALUES (s.id, DEFAULT, s.col2)
----
2

# FIXME: 'c' should be NULL, but this needs support for {} first
query III
select * from my_datalake.default.tbl_default_null_struct where id = 1;
----
1	{'a': NULL, 'b': NULL, 'c': {'x': NULL}}	100

# FIXME: 'c' should be NULL, but this needs support for {} first
query III
select * from my_datalake.default.tbl_default_null_struct where id = 3;
----
3	{'a': NULL, 'b': NULL, 'c': {'x': NULL}}	300
