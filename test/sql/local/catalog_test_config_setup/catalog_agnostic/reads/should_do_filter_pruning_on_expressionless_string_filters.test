# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/reads/should_do_filter_pruning_on_expressionless_string_filters.test
# group: [reads]

require avro

require parquet

require iceberg

require-env CATALOG_TEST_CONFIG_SETUP

statement ok
create schema if not exists my_datalake.default;

statement ok
SET unsafe_enable_version_guessing = true;

statement ok
SET enable_logging=true;

statement ok
SET logging_level='trace';

query I
SELECT item_id FROM my_datalake.default.issue_791
WHERE
item_id = '20000000-0000-0000-0000-000000000002';
----
20000000-0000-0000-0000-000000000002


# Should skip files based on bound checks

# Verify exactly files -1-, -3-, -4- were skipped
query I
WITH skipped AS (
    SELECT message FROM duckdb_logs()
    WHERE type = 'Iceberg' AND message.contains('Iceberg Filter Pushdown, skipped ''data_file'':')
)
SELECT
    (SELECT count(*) FROM skipped) = 3
    AND (SELECT count(*) FROM skipped WHERE message.contains('-1-')) = 1
    AND (SELECT count(*) FROM skipped WHERE message.contains('-3-')) = 1
    AND (SELECT count(*) FROM skipped WHERE message.contains('-4-')) = 1;
----
true

statement ok
CALL truncate_duckdb_logs();

query I
SELECT item_id FROM my_datalake.default.issue_791
WHERE
item_id < '20000000-0000-0000-0000-000000000002';
----
10000000-0000-0000-0000-000000000001

# Desired behavior for each parquet file:
# 10000000-0000-0000-0000-000000000001  - should scan
# 20000000-0000-0000-0000-000000000002  - should scan (bound is prefix)
# 30000000-0000-0000-0000-0000000000033 - should skip
# 40000000-0000-0000-0000-00000000004   - should skip

# Iceberg truncates string bounds to 16 bytes (MAX_STRING_UPPERBOUND_LENGTH).
# The truncated lower_bound of file -2- ('20000000-0000-00') is a prefix of the constant,
# and a prefix is lexicographically less than the full string, so it can't be pruned.
# Only files -3- ('30...') and -4- ('40...') have truncated lower_bounds > the constant.
# Verify exactly files -3- and -4- were skipped
query I
WITH skipped AS (
    SELECT message FROM duckdb_logs()
    WHERE type = 'Iceberg' AND message.contains('Iceberg Filter Pushdown, skipped ''data_file'':')
)
SELECT
    (SELECT count(*) FROM skipped) = 2
    AND (SELECT count(*) FROM skipped WHERE message.contains('-3-')) = 1
    AND (SELECT count(*) FROM skipped WHERE message.contains('-4-')) = 1;
----
true

statement ok
CALL truncate_duckdb_logs();

query I
SELECT item_id FROM my_datalake.default.issue_791
WHERE
item_id <= '20000000-0000-0000-0000-000000000002';
----
10000000-0000-0000-0000-000000000001
20000000-0000-0000-0000-000000000002

# Same as <: truncated lower_bound of file -2- is a prefix of the constant, can't be pruned.
# Verify exactly files -3- and -4- were skipped
query I
WITH skipped AS (
    SELECT message FROM duckdb_logs()
    WHERE type = 'Iceberg' AND message.contains('Iceberg Filter Pushdown, skipped ''data_file'':')
)
SELECT
    (SELECT count(*) FROM skipped) = 2
    AND (SELECT count(*) FROM skipped WHERE message.contains('-3-')) = 1
    AND (SELECT count(*) FROM skipped WHERE message.contains('-4-')) = 1;
----
true

statement ok
CALL truncate_duckdb_logs();

query I
SELECT item_id FROM my_datalake.default.issue_791
WHERE
item_id >= '20000000-0000-0000-0000-000000000002';
----
20000000-0000-0000-0000-000000000002
30000000-0000-0000-0000-0000000000033
40000000-0000-0000-0000-00000000004

# Verify exactly file -1- was skipped
query I
WITH skipped AS (
    SELECT message FROM duckdb_logs()
    WHERE type = 'Iceberg' AND message.contains('Iceberg Filter Pushdown, skipped ''data_file'':')
)
SELECT
    (SELECT count(*) FROM skipped) = 1
    AND (SELECT count(*) FROM skipped WHERE message.contains('-1-')) = 1;
----
true

statement ok
CALL truncate_duckdb_logs();

query I
SELECT item_id FROM my_datalake.default.issue_791
WHERE
item_id > '20000000-0000-0000-0000-000000000002';
----
30000000-0000-0000-0000-0000000000033
40000000-0000-0000-0000-00000000004

# Verify exactly file -1- was skipped
query I
WITH skipped AS (
    SELECT message FROM duckdb_logs()
    WHERE type = 'Iceberg' AND message.contains('Iceberg Filter Pushdown, skipped ''data_file'':')
)
SELECT
    (SELECT count(*) FROM skipped) = 1
    AND (SELECT count(*) FROM skipped WHERE message.contains('-1-')) = 1;
----
true
