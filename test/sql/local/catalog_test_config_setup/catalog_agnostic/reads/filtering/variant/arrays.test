# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/reads/filtering/variant/arrays.test
# description: min/max bounds for shredded VARIANT fields that contain arrays. Per the Iceberg spec an
# group: [variant]

#              array's bound is keyed at the array field itself ("$['scores']") and covers every element.

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

require icu

require core_functions

set ignore_error_messages

# ------------------------------------------------------------------------------
# flat array field: bounds span every element across every row
# elements are 1..7, so the array field bound is [1, 7] regardless of row grouping
# ------------------------------------------------------------------------------

statement ok
drop table if exists my_datalake.default.variant_array_tbl;

statement ok
create table my_datalake.default.variant_array_tbl WITH ('format-version'=3) as from values
({'scores': [3, 1, 2]}::VARIANT),
({'scores': [7, 5, 6]}::VARIANT),
({'scores': [4]}::VARIANT) t(variant_col);

query I
select column_name from iceberg_column_stats(my_datalake.default.variant_array_tbl);
----
variant_col

# the "element" path segment is dropped: the bound is keyed at the array field and
# the lower/upper bounds are the min/max over all array elements (1 and 7)
query II
select lower_bound, upper_bound from iceberg_column_stats(my_datalake.default.variant_array_tbl);
----
{'$[\'scores\']': 1}	{'$[\'scores\']': 7}

# ------------------------------------------------------------------------------
# array of objects: the bound path identifies the nested field, still omitting
# the array "element" segment ("$['people']['age']")
# ------------------------------------------------------------------------------

statement ok
drop table if exists my_datalake.default.variant_array_obj_tbl;

statement ok
create table my_datalake.default.variant_array_obj_tbl WITH ('format-version'=3) as from values
({'people': [{'age': 25}, {'age': 40}]}::VARIANT),
({'people': [{'age': 30}]}::VARIANT),
({'people': [{'age': 18}, {'age': 55}]}::VARIANT) t(variant_col);

query II
select lower_bound, upper_bound from iceberg_column_stats(my_datalake.default.variant_array_obj_tbl);
----
{'$[\'people\'][\'age\']': 18}	{'$[\'people\'][\'age\']': 55}

# ------------------------------------------------------------------------------
# pruning: two data files with disjoint array ranges. A filter on a sibling scalar
# field still prunes, and the array bounds do not interfere with the scan.
# ------------------------------------------------------------------------------

statement ok
drop table if exists my_datalake.default.variant_array_prune_tbl;

# data file 1: scores 1..3, id low (1-3)
statement ok
create table my_datalake.default.variant_array_prune_tbl WITH ('format-version'='3') as from values
({'id': 1, 'scores': [1, 2, 3]}::VARIANT),
({'id': 2, 'scores': [2, 3]}::VARIANT),
({'id': 3, 'scores': [3]}::VARIANT) t(variant_col);

# data file 2: scores 10..30, id high (10-12)
statement ok
insert into my_datalake.default.variant_array_prune_tbl values
({'id': 10, 'scores': [10, 20]}::VARIANT),
({'id': 11, 'scores': [30]}::VARIANT),
({'id': 12, 'scores': [25, 15]}::VARIANT);

statement ok
call enable_logging('Iceberg');

# filter on the scalar 'id' field prunes data file 1 (max id = 3)
statement ok
select * from my_datalake.default.variant_array_prune_tbl where variant_col.id > 5;

query I
select count(*) from duckdb_logs() where type = 'Iceberg' and message like '%skipped%';
----
1

statement ok
CALL truncate_duckdb_logs();

# the surviving rows are correct
query I
select count(*) from my_datalake.default.variant_array_prune_tbl where variant_col.id > 5;
----
3
