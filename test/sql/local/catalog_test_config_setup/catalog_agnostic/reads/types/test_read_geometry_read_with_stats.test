# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/reads/types/test_read_geometry_read_with_stats.test
# group: [types]

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
SELECT COUNT(*) FROM iceberg_scan(
  'https://storage.googleapis.com/cartobq-iceberg-geo-testbed/v3_geometry/metadata/v1.metadata.json'
) WHERE ST_Intersects(geom, ST_MakeEnvelope(-125, 32, -115, 42));