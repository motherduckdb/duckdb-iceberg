# flag IS NULL
query IIII
select * from iceberg_scan('__WORKING_DIRECTORY__/data/persistent/null_stats/default/test_nulls', version='00003-9d6a621e-8a72-4190-a880-f6ca02e32b86') where flag IS NULL order by all
