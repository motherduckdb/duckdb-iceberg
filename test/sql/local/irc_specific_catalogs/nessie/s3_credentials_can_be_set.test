# name: test/sql/local/irc_specific_catalogs/nessie/s3_credentials_can_be_set.test
# group: [nessie]

require-env NESSIE_SERVER_AVAILABLE

require httpfs

require aws

require parquet

require avro

require iceberg

set ignore_error_messages

statement ok
SET ca_cert_file = '~/.mitmproxy/mitmproxy-ca-cert.pem';

statement ok
CREATE SECRET http_proxy (
    TYPE http,
    HTTP_PROXY 'http://localhost:8878'
);

statement ok
create secret my_secret (
    TYPE ICEBERG,
    CLIENT_ID 'client1',
    CLIENT_SECRET 's3cr3t',
    OAUTH2_SCOPE 'catalog sign',
    OAUTH2_SERVER_URI 'http://127.0.0.1:8080/realms/iceberg/protocol/openid-connect/token'
);

statement ok
ATTACH 'warehouse' AS nessie (TYPE 'iceberg', ENDPOINT 'http://127.0.0.1:19120/iceberg/', SECRET 'my_secret', ACCESS_DELEGATION_MODE 'none');

statement ok
CREATE SCHEMA IF NOT EXISTS nessie.demo;

statement ok
CREATE TABLE IF NOT EXISTS nessie.demo.users (id BIGINT, name VARCHAR);

# When ACCESS_DELEGATION_MODE 'none', we do not use the "config" returned by the load table information endpoint.
# Therefore, we have to set the s3 access settings here.

statement ok
SET s3_access_key_id='minioadmin';

statement ok
SET s3_secret_access_key='minioadmin';

statement ok
set s3_region='us-east-1';

statement ok
set s3_endpoint='127.0.0.1:9002';

statement ok
set s3_use_ssl=false;

statement ok
set s3_url_style='path';

statement ok
SELECT * FROM nessie.demo.users ORDER BY id;

statement ok
INSERT INTO nessie.demo.users VALUES (1, 'ada'), (2, 'grace');