# name: test/sql/local/partitioning/truncate/truncate_decimal.test
# group: [truncate]

require avro

require parquet

require iceberg

require-env DUCKDB_ICEBERG_HAVE_GENERATED_DATA

statement ok
create view scan as select * from ICEBERG_SCAN('__WORKING_DIRECTORY__/data/generated/iceberg/spark-local/default/truncate_partitioned_decimal');

query I
select count(*) from scan;
----
5

# unconstrained query reads all files
query II
explain analyze select * from scan;
----
analyzed_plan	<REGEX>:.*Total Files Read: 3\s+.*

query I
select count(*) from scan where nested.data >= '10.5'::decimal(10,2);
----
2

query II
explain analyze select * from scan where nested.data >= '10.5'::decimal(10,2);
----
analyzed_plan	<REGEX>:.*Total Files Read: 1\s+.*

query II
explain analyze select * from scan where nested.data = '10.9'::decimal(10,2);
----
analyzed_plan	<REGEX>:.*Total Files Read: 1\s+.*
