# name: test/sql/iceberg_to_ducklake.test_slow
# group: [sql]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

require ducklake

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
set enable_logging=true

statement ok
set logging_level='debug'

statement ok
ATTACH 'ducklake:duckdb:__TEST_DIR__/ducklake.duckdb' as my_ducklake (DATA_PATH '__TEST_DIR__/data_path');

statement ok
call iceberg_to_ducklake(
    'my_datalake',
    'my_ducklake',
    skip_tables := [
        'pyspark_iceberg_table_v2',
        'deletion_vectors',
        'variant_column',
        'simple_v3_table',
        'truncate_partitioned_varchar',
        'truncate_partitioned_decimal',
        'truncate_partitioned_binary',
        'truncate_partitioned_bigint',
        'row_lineage_test_upgraded_insert',
        'bucket_partitioned_bigint',
        'bucket_partitioned_timestamp',
        'bucket_partitioned_sparse_integer',
        'bucket_partitioned_decimal',
        'bucket_partitioned_date',
        'bucket_partitioned_string',
        'bucket_partitioned_binary',
        'bucket_partitioned_integer',
    ]
)

# These are empty, so they are omitted:
# - insert_all_types
# - simple_v3_table
# - test_not_null
# - tpch

# These have an ALTER at the end, with no new snapshot added afterwards
# Without a snapshot, that means the change isn't recorded by the conversion
# So the results will not match
# - schema_evolve_struct_in_list
# - schema_evolve_struct_in_map

foreach table_name lineitem_partitioned_l_shipmode_deletes all_types_table day_timestamp day_timestamptz empty_insert filtering_on_bounds complicated_partitioned_table filtering_on_partition_bounds issue_328 lineitem_001_deletes lineitem_partitioned_l_shipmode lineitem_sf_01_1_delete lineitem_sf_01_no_deletes lineitem_sf1_deletes many_adds_deletes nested_types pyspark_iceberg_table_v1 quickstart_table schema_evolve_float_to_double schema_evolve_int_to_bigint schema_evolve_struct schema_evolve_widen_decimal table_more_deletes table_partitioned table_unpartitioned table_with_deletes year_timestamp year_timestamptz

# Verify current state matches
query I rowsort expected_res
select * from my_datalake.default.${table_name}
----

query I rowsort expected_res
select * from my_ducklake.default.${table_name}
----

reset label expected_res

# table_name
endloop
